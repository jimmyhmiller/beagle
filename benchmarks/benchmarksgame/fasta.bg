namespace fasta

// The Computer Language Benchmarks Game
// https://salsa.debian.org/benchmarksgame-team/benchmarksgame/
//
// Beagle implementation — pure-Beagle string-builder version.
// No FFI, no unsafe primitives. The output buffer is a
// `beagle.string-builder` that grows geometrically; we flush by
// materializing a string and printing it once a chunk-sized chunk
// has accumulated.

use beagle.string-builder as sb
use beagle.mutable-array as arr
use beagle.builtin as builtin

let LINE_WIDTH = 60
let IM = 139968
let IA = 3877
let IC = 29573
// Flush threshold — keep chunks reasonably sized so we don't pile up
// the entire output before printing. ~64 KiB matches the FFI version's
// OUT_BUF_SIZE.
let FLUSH_AT = 65536

let ALU = "GGCCGGGCGCGGTGGCTCACGCCTGTAATCCCAGCACTTTGGGAGGCCGAGGCGGGCGGATCACCTGAGGTCAGGAGTTCGAGACCAGCCTGGCCAACATGGTGAAACCCCGTCTCTACTAAAAATACAAAAATTAGCCGGGCGTGGTGGCGCGCGCCTGTAATCCCAGCTACTCGGGAGGCTGAGGCAGGAGAATCGCTTGAACCCGGGAGGCGGAGGTTGCAGTGAGCCGAGATCGCGCCACTGCACTCCAGCCTGGGCGACAGAGCGAGACTCCGTCTCAAAAA"

// Pre-compute byte codes for a string into an Int-array, so the inner
// loop can do `arr/get` (no per-call type check, no string-indexing
// allocation) and pass the byte code straight to `append-byte!`.
fn make_byte_codes(s) {
    let len = length(s)
    let codes = arr/new-array(len)
    let mut i = 0
    while i < len {
        arr/write-field(codes, i, builtin/char-code(s[i]))
        i = i + 1
        null
    }
    codes
}

// IUB cumulative probabilities (scaled to IM)
fn make_iub_probs() {
    let probs = arr/new-array(15)
    arr/write-field(probs, 0, 37792)
    arr/write-field(probs, 1, 54588)
    arr/write-field(probs, 2, 71384)
    arr/write-field(probs, 3, 109176)
    arr/write-field(probs, 4, 111975)
    arr/write-field(probs, 5, 114774)
    arr/write-field(probs, 6, 117574)
    arr/write-field(probs, 7, 120373)
    arr/write-field(probs, 8, 123172)
    arr/write-field(probs, 9, 125972)
    arr/write-field(probs, 10, 128771)
    arr/write-field(probs, 11, 131570)
    arr/write-field(probs, 12, 134370)
    arr/write-field(probs, 13, 137169)
    arr/write-field(probs, 14, 139969)
    probs
}

fn make_homo_probs() {
    let probs = arr/new-array(4)
    arr/write-field(probs, 0, 42404)
    arr/write-field(probs, 1, 70117)
    arr/write-field(probs, 2, 97767)
    arr/write-field(probs, 3, 139968)
    probs
}

// Flush the builder if it's grown past the threshold. The to-string
// + print pair is one alloc + one syscall — the builder's storage
// stays put, so we keep the same growable backing array.
fn maybe_flush!(out) {
    if sb/length(out) >= FLUSH_AT {
        print(sb/to-string(out))
        sb/clear!(out)
        null
    } else {
        null
    }
}

// Repeated-ALU section. Walks the precomputed ALU code array
// cyclically, emitting newline-wrapped lines.
fn write_repeat_fasta(alu_codes, alu_len, size, out) {
    let mut alu_idx = 0
    let mut remaining = size
    while remaining > 0 {
        let line_len = if remaining < LINE_WIDTH { remaining } else { LINE_WIDTH }
        let mut col = 0
        while col < line_len {
            sb/append-byte!(out, arr/get(alu_codes, alu_idx))
            alu_idx = alu_idx + 1
            if alu_idx >= alu_len {
                alu_idx = 0
            }
            col = col + 1
            null
        }
        sb/append-byte!(out, 10)  // newline
        maybe_flush!(out)
        remaining = remaining - line_len
        null
    }
}

// Random-sequence section. Produces `size` characters drawn from
// `codes` according to cumulative probabilities `probs`. Returns the
// final seed so the next section can resume the PRNG.
fn write_random_fasta(codes, probs, probs_len, size, seed, add_final_newline, out) {
    let mut current_seed = seed
    let mut remaining = size
    while remaining > 0 {
        let line_len = if remaining < LINE_WIDTH { remaining } else { LINE_WIDTH }
        let mut col = 0
        while col < line_len {
            current_seed = (current_seed * IA + IC) - ((current_seed * IA + IC) / IM) * IM
            let mut idx = 0
            // linear search for the matching cumulative probability
            while idx < probs_len {
                if arr/get(probs, idx) > current_seed {
                    break()
                }
                idx = idx + 1
                null
            }
            if idx >= probs_len {
                idx = probs_len - 1
            }
            sb/append-byte!(out, arr/get(codes, idx))
            col = col + 1
            null
        }
        remaining = remaining - line_len
        if remaining > 0 || add_final_newline {
            sb/append-byte!(out, 10)
        }
        maybe_flush!(out)
        null
    }
    current_seed
}

fn run(n) {
    let alu_codes = make_byte_codes(ALU)
    let alu_len = length(ALU)
    let iub_codes = make_byte_codes("acgtBDHKMNRSVWY")
    let homo_codes = make_byte_codes("acgt")
    let iub_probs = make_iub_probs()
    let homo_probs = make_homo_probs()

    // One reusable output buffer for the whole run.
    let out = sb/new(FLUSH_AT * 2)

    sb/append!(out, ">ONE Homo sapiens alu\n")
    write_repeat_fasta(alu_codes, alu_len, n * 2, out)

    sb/append!(out, ">TWO IUB ambiguity codes\n")
    let seed2 = write_random_fasta(iub_codes, iub_probs, 15, n * 3, 42, true, out)

    sb/append!(out, ">THREE Homo sapiens frequency\n")
    write_random_fasta(homo_codes, homo_probs, 4, n * 5, seed2, false, out)

    if sb/length(out) > 0 {
        print(sb/to-string(out))
    }
    ""
}

fn main(args) {
    let n = if length(args) > 0 { to-number(get(args, 0)) } else { 10 }
    run(n)
    ""
}

// @beagle.core.snapshot
// >ONE Homo sapiens alu
// GGCCGGGCGCGGTGGCTCAC
// >TWO IUB ambiguity codes
// cttBtatcatatgctaKggNcataaaSatg
// >THREE Homo sapiens frequency
// taaatcttgtgcttcgttagaagtctcgactacgtgtagcctagtgtttg
