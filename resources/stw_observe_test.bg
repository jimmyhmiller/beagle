namespace stw_observe_test

// Validates the stop-the-world rendezvous primitive (runtime/stop-the-world)
// independently of GC: spawn worker threads that spin calling a Beagle
// function (so they repeatedly hit the function-entry safepoint), then have
// the main thread drive an STW. The rendezvous parks every worker before
// returning.
//
// Invariant under test: a stop-the-world is ALL-OR-NOTHING. It either parks
// every other registered thread or, if a GC is concurrently stopping the
// world, backs off and returns 0 — it must NEVER observe a *partial* stop
// (1 or 2 of our 3 workers), which would mean mutating shared state while a
// thread is still running. (An earlier version mis-subtracted for a
// non-registered coordinator and returned 2; that is the bug this guards.)
//
// Robustness notes:
//   * `busy` uses NON-tail recursion — a tail-recursive self call is TCO'd to
//     a jump that skips the entry-safepoint poll, so a tail-recursive worker
//     would never park and the rendezvous would hang. `r + 1` forces a real
//     entry (and safepoint) per call.
//   * the spin loop allocates NOTHING (pure `busy` + `deref`), so it never
//     itself triggers the GC that would make `stop-the-world` back off.
//   * the test DRAINS its workers before returning (so they don't linger into
//     a re-run under the tier-2 harness) and tolerates extra registered
//     threads (>= 3 rather than exactly 3), keeping the all-or-nothing check.

use beagle.runtime as runtime

fn busy(n) {
    if n <= 0 {
        0
    } else {
        let r = busy(n - 1)
        r + 1
    }
}

fn worker(stop, done) {
    if deref(stop) {
        swap!(done, fn(x) { x + 1 })
        0
    } else {
        busy(150)
        worker(stop, done)
    }
}

// Drive the STW `tries` times. Each result must be 0 (backed off to a
// concurrent GC — a correct, acceptable outcome) or >= 3 (parked at least our
// three workers) — NEVER a partial 1 or 2, which would mean the rendezvous
// returned while a thread was still running. That all-or-nothing property is
// the safety invariant under test. (We deliberately do NOT require a non-zero
// observation: under heavy GC churn — e.g. the tier-2 re-run harness — the STW
// may legitimately back off to a concurrent GC every time.)
fn observe_all_or_nothing(tries) {
    if tries <= 0 {
        0
    } else {
        let parked = runtime/stop-the-world()
        assert!(parked == 0 || parked >= 3)
        observe_all_or_nothing(tries - 1)
    }
}

// Spin (hitting safepoints) until `done` reaches `target`.
fn wait_done(done, target) {
    if deref(done) >= target {
        0
    } else {
        busy(150)
        wait_done(done, target)
    }
}

test "stop-the-world is all-or-nothing and parks every worker" {
    let stop = atom(false)
    let done = atom(0)

    let w = fn() { worker(stop, done) }
    thread(w)
    thread(w)
    thread(w)

    // The STW is all-or-nothing across every attempt (never a partial stop).
    observe_all_or_nothing(8)

    // Release the workers and wait for all three to actually exit, so they do
    // not linger into a subsequent run (e.g. the tier-2 re-run harness).
    reset!(stop, true)
    wait_done(done, 3)

    assert!(true)
}
