namespace reflect_source_test

use beagle.reflect as reflect

/// A friendly greeting function.
fn greet(name) {
    println("Hello, " + name)
}

fn add(x, y) {
    x + y
}

/// A 2-d point.
struct Point { x, y }

enum Color {
    Red,
    Green,
    Blue
}

fn main() {
    // Source text for a function with a docstring is reattached as `///` lines.
    let greet_src = reflect/source(greet)
    println(greet_src)
    println("---")

    // Source text for a function without a docstring is verbatim.
    println(reflect/source(add))
    println("---")

    // Struct source text (with reattached docstring).
    println(reflect/source(Point))
    println("---")

    // Enum source text.
    println(reflect/source(Color))
    println("---")

    // Source text for a struct INSTANCE returns the struct's source text.
    let p = Point { x: 1, y: 2 }
    println(reflect/source(p))
    println("---")

    // Source text for an enum variant returns the enum's source text.
    let c = Color.Red
    println(reflect/source(c))
    println("---")

    // Builtins have no source text — returns null.
    println(reflect/source(println))
    println("---")

    // Whole-namespace source: concatenated definitions in a stable order
    // (structs, then enums, then functions).
    let ns_src = reflect/namespace-source("reflect_source_test")
    println(ns_src)

    "done"
}

