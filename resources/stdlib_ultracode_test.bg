namespace stdlib_ultracode_test

// gc-always

use beagle.text as text
use beagle.iter as iter
use beagle.hash as hash
use beagle.textwrap as tw
use beagle.struct-pack as sp

fn main() {
    // text/format float precision + sign
    println(text/format("%.2f", [3.14159]) == "3.14")
    println(text/format("%f", [3.14159]) == "3.141590")
    println(text/format("%+d", [5]) == "+5")
    // iter combinatorics
    println(iter/combinations([1, 2, 3], 2) == [[1, 2], [1, 3], [2, 3]])
    println(length(iter/permutations([1, 2, 3])) == 6)
    println(iter/cartesian-product([[1, 2], [3, 4]]) == [[1, 3], [1, 4], [2, 3], [2, 4]])
    // hash md5/sha512 (exact vs python hashlib)
    println(hash/md5("abc") == "900150983cd24fb0d6963f7d28e17f72")
    println(hash/sha512("") == "cf83e1357eefb8bdf1542850d66d8007d620e4050b5715dc83f4a921d36ce9ce47d0d13c5d85f2b0ff8318d2877eec2f63b931bd47417a81a538327af927da3e")
    // textwrap
    println(tw/wrap("the quick brown fox", 9) == ["the quick", "brown fox"])
    // struct-pack
    println(sp/pack-u16-be(258) == [1, 2])
    println(sp/unpack-u32-be([1, 2, 3, 4], 0) == 16909060)
    // division without spaces (parser fix)
    let total = 100
    println(total/4 == 25)
}

