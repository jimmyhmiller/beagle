namespace map_dissoc_gc_test
// gc-always
test "dissoc under gc-always keeps remaining heap values valid" {
    let mut m = {}
    let mut i = 0
    while i < 40 { m = assoc(m, i, [i, i, i])  i = i + 1 }
    let mut k = 0
    while k < 40 {
        m = dissoc(m, k)
        if k + 1 < 40 { assert-eq!(get(m, k + 1), [k + 1, k + 1, k + 1]) }
        k = k + 1
    }
    assert-eq!(length(m), 0)
}
