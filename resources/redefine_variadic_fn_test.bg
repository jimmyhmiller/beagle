namespace redefine_variadic_fn_test

fn sum(...nums) {
    reduce(fn(acc, n) { acc + n }, 0, nums)
}

fn log(...args) {
    let msg = reduce(fn(acc, a) {
        if acc == "" { to-string(a) }
        else { acc ++ " " ++ to-string(a) }
    }, "", args)
    println(msg)
}

fn main() {
    // Original variadic functions
    println(sum(1, 2, 3))
    println(sum(10, 20, 30, 40))
    log("hello", "world", 42)

    // Redefine sum to multiply instead
    eval("
        fn sum(...nums) {
            reduce(fn(acc, n) { acc * n }, 1, nums)
        }
    ")

    println(sum(2, 3, 4))
    println(sum(10, 20))

    // Redefine log to add prefix
    eval("
        fn log(...args) {
            let msg = reduce(fn(acc, a) {
                acc ++ \" \" ++ to-string(a)
            }, \"[LOG]\", args)
            println(msg)
        }
    ")

    log("status:", "ok")
    log(1, 2, 3)

    // Redefine back to original sum
    eval("
        fn sum(...nums) {
            reduce(fn(acc, n) { acc + n }, 0, nums)
        }
    ")

    println(sum(1, 2, 3))
}

// @beagle.core.snapshot
// 6
// 100
// hello world 42
// 24
// 200
// [LOG] status: ok
// [LOG] 1 2 3
// 6
