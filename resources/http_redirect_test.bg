namespace http_redirect_test

use beagle.core as core
use beagle.socket as socket
use beagle.http as http

// The HTTP client follows 3xx redirects (Location header) up to :max-redirects.
// The server 302-redirects /start -> /target; the client's http/get should end up
// at /target. With :max-redirects 0, following is disabled and the 302 is returned.
//
// http/get opens one connection per request (Connection: close), so the followed
// case uses two server connections (/start -> 302, then /target -> 200) and the
// no-follow case one (/start -> 302). handle-connection is driven directly.

fn handler(req) {
    if req.path == "/start" {
        http/with-header(http/status-response(302, "redirecting"), "Location", "/target")
    } else {
        http/ok("arrived:" ++ req.path)
    }
}

fn main() {
    let port = 20000 + core/random-int(20000)
    let ready = atom(false)

    thread(fn() {
        let listener = socket/listen("127.0.0.1", port)
        reset!(ready, true)
        // conn 1: /start -> 302, conn 2: the followed /target -> 200,
        // conn 3: /start again for the no-follow case -> 302 (returned as-is).
        http/handle-connection(socket/accept(listener), handler, http/config-from-opts({}))
        http/handle-connection(socket/accept(listener), handler, http/config-from-opts({}))
        http/handle-connection(socket/accept(listener), handler, http/config-from-opts({}))
        socket/close-listener(listener)
    })

    loop {
        if deref(ready) { break(null) }
        core/sleep(1)
    }

    // Follows the redirect to /target.
    let followed = http/get("http://127.0.0.1:${port}/start")
    println("followed-status: " ++ to-string(unwrap!(followed).status))
    println("followed-body: " ++ unwrap!(followed).body)

    // :max-redirects 0 disables following -> the 302 itself.
    let raw = http/get("http://127.0.0.1:${port}/start", {:max-redirects 0})
    println("nofollow-status: " ++ to-string(unwrap!(raw).status))
    println("nofollow-location: " ++ to-string(http/header(unwrap!(raw), "location")))

    println("done")
}

// @beagle.core.snapshot
// followed-status: 200
// followed-body: arrived:/target
// nofollow-status: 302
// nofollow-location: /target
// done
