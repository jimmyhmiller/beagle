namespace priorityqueue_coverage_test

use beagle.priorityqueue as pq

// Drain a queue into a vector (smallest-first) without using pq-to-sorted-vec,
// so tests that target the queue mechanics don't lean on the helper.
fn drain(q) {
    let mut current = q
    let mut acc = []
    while pq/pq-empty?(current) == false {
        let r = pq/pq-pop(current)
        acc = push(acc, get(r, 0))
        current = get(r, 1)
    }
    acc
}

test "empty queue basics" {
    let q = pq/pq-new()
    assert!(pq/pq-empty?(q))
    assert-eq!(pq/pq-count(q), 0)
    assert-eq!(pq/pq-peek(q), null)
}

test "pq-pop on empty throws" {
    let q = pq/pq-new()
    assert-throws!(fn() { pq/pq-pop(q) })
}

test "single push count and peek" {
    let q = pq/pq-push(pq/pq-new(), 42)
    assert!(pq/pq-empty?(q) == false)
    assert-eq!(pq/pq-count(q), 1)
    assert-eq!(pq/pq-peek(q), 42)
}

test "min-heap orders smallest first" {
    let mut q = pq/pq-new()
    q = pq/pq-push(q, 5)
    q = pq/pq-push(q, 3)
    q = pq/pq-push(q, 8)
    q = pq/pq-push(q, 1)
    assert-eq!(pq/pq-peek(q), 1)
    assert-eq!(pq/pq-count(q), 4)
    assert-eq!(drain(q), [1, 3, 5, 8])
}

test "pq-pop returns [min, new-queue]" {
    let mut q = pq/pq-new()
    q = pq/pq-push(q, 7)
    q = pq/pq-push(q, 2)
    let r = pq/pq-pop(q)
    assert-eq!(get(r, 0), 2)
    let rest = get(r, 1)
    assert-eq!(pq/pq-count(rest), 1)
    assert-eq!(pq/pq-peek(rest), 7)
}

test "push is immutable - original unchanged" {
    let q0 = pq/pq-new()
    let q1 = pq/pq-push(q0, 10)
    assert!(pq/pq-empty?(q0))
    assert-eq!(pq/pq-count(q0), 0)
    assert-eq!(pq/pq-count(q1), 1)
}

test "pop is immutable - original unchanged" {
    let mut q = pq/pq-new()
    q = pq/pq-push(q, 4)
    q = pq/pq-push(q, 9)
    let countBefore = pq/pq-count(q)
    pq/pq-pop(q)
    assert-eq!(pq/pq-count(q), countBefore)
    assert-eq!(pq/pq-peek(q), 4)
}

test "duplicate values are preserved" {
    let mut q = pq/pq-new()
    q = pq/pq-push(q, 3)
    q = pq/pq-push(q, 3)
    q = pq/pq-push(q, 1)
    q = pq/pq-push(q, 3)
    assert-eq!(pq/pq-count(q), 4)
    assert-eq!(drain(q), [1, 3, 3, 3])
}

test "string ordering is lexicographic" {
    let mut q = pq/pq-new()
    q = pq/pq-push(q, "pear")
    q = pq/pq-push(q, "apple")
    q = pq/pq-push(q, "banana")
    assert-eq!(pq/pq-peek(q), "apple")
    assert-eq!(drain(q), ["apple", "banana", "pear"])
}

test "pq-new-max pops largest first" {
    let mut q = pq/pq-new-max()
    q = pq/pq-push(q, 5)
    q = pq/pq-push(q, 3)
    q = pq/pq-push(q, 8)
    q = pq/pq-push(q, 1)
    assert-eq!(pq/pq-peek(q), 8)
    assert-eq!(drain(q), [8, 5, 3, 1])
}

test "pq-new-with custom comparator (max-heap)" {
    let mut q = pq/pq-new-with(fn(a, b) { b - a })
    q = pq/pq-push(q, 2)
    q = pq/pq-push(q, 10)
    q = pq/pq-push(q, 6)
    assert-eq!(pq/pq-peek(q), 10)
    assert-eq!(drain(q), [10, 6, 2])
}

test "pq-new-with comparator on records" {
    // Order pairs [priority, label] by priority ascending.
    let cmp = fn(a, b) { get(a, 0) - get(b, 0) }
    let mut q = pq/pq-new-with(cmp)
    q = pq/pq-push(q, [3, "c"])
    q = pq/pq-push(q, [1, "a"])
    q = pq/pq-push(q, [2, "b"])
    assert-eq!(pq/pq-peek(q), [1, "a"])
    let r = pq/pq-pop(q)
    assert-eq!(get(r, 0), [1, "a"])
}

test "pq-from-vec heapifies, peek is min" {
    let q = pq/pq-from-vec([5, 3, 8, 1, 9, 2])
    assert-eq!(pq/pq-peek(q), 1)
    assert-eq!(pq/pq-count(q), 6)
}

test "pq-from-vec empty" {
    let q = pq/pq-from-vec([])
    assert!(pq/pq-empty?(q))
    assert-eq!(pq/pq-count(q), 0)
    assert-eq!(pq/pq-peek(q), null)
}

test "pq-from-vec single element" {
    let q = pq/pq-from-vec([42])
    assert-eq!(pq/pq-count(q), 1)
    assert-eq!(pq/pq-peek(q), 42)
}

test "pq-from-vec two elements orders correctly" {
    let q = pq/pq-from-vec([9, 4])
    assert-eq!(pq/pq-peek(q), 4)
    assert-eq!(drain(q), [4, 9])
}

test "pq-from-vec-with custom comparator" {
    let q = pq/pq-from-vec-with([5, 3, 8, 1], fn(a, b) { b - a })
    assert-eq!(pq/pq-peek(q), 8)
    assert-eq!(drain(q), [8, 5, 3, 1])
}

test "pq-to-sorted-vec sorts ascending" {
    let q = pq/pq-from-vec([5, 3, 8, 1, 9, 2])
    assert-eq!(pq/pq-to-sorted-vec(q), [1, 2, 3, 5, 8, 9])
}

test "pq-to-sorted-vec on empty is empty" {
    assert-eq!(pq/pq-to-sorted-vec(pq/pq-new()), [])
}

test "pq-to-sorted-vec does not mutate input" {
    let q = pq/pq-from-vec([4, 2, 7])
    pq/pq-to-sorted-vec(q)
    assert-eq!(pq/pq-count(q), 3)
    assert-eq!(pq/pq-peek(q), 2)
}

test "pop down to empty then peek null" {
    let mut q = pq/pq-push(pq/pq-new(), 1)
    let r = pq/pq-pop(q)
    let rest = get(r, 1)
    assert!(pq/pq-empty?(rest))
    assert-eq!(pq/pq-peek(rest), null)
}

test "negative numbers order correctly" {
    let q = pq/pq-from-vec([-3, 5, -10, 0, 7])
    assert-eq!(pq/pq-peek(q), -10)
    assert-eq!(pq/pq-to-sorted-vec(q), [-10, -3, 0, 5, 7])
}

test "larger heapify stays sorted" {
    let q = pq/pq-from-vec([15, 4, 22, 8, 1, 19, 3, 11, 7, 2])
    assert-eq!(pq/pq-to-sorted-vec(q), [1, 2, 3, 4, 7, 8, 11, 15, 19, 22])
}
