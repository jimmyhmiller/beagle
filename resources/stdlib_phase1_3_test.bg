namespace stdlib_phase1_3_test

// gc-always

// Regression coverage for the Phase 1+3 pure-Beagle modules: text, base64, hex,
// hash (sha1/sha256), url. Asserts canonical RFC/NIST vectors under gc-always.

use beagle.text as text
use beagle.base64 as b64
use beagle.hex as hex
use beagle.hash as hash
use beagle.url as url

fn main() {
    // text
    println(text/repeat-string("ab", 3) == "ababab")
    // printf replaced by ${...} string interpolation
    let label = "age"
    let n = 42
    println("${label} is ${n}" == "age is 42")
    // base64 (RFC 4648)
    println(b64/encode("Man") == "TWFu")
    println(b64/encode("hello") == "aGVsbG8=")
    // hex
    println(hex/encode([255, 0, 16, 171]) == "ff0010ab")
    // hash (canonical vectors)
    println(hash/sha1("abc") == "a9993e364706816aba3e25717850c26c9cd0d89d")
    println(hash/sha256("abc") == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad")
    // url
    println(url/encode-component("a b&c") == "a%20b%26c")
}

