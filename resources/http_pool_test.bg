namespace http_pool_test

use beagle.core as core
use beagle.socket as socket
use beagle.http as http

// An http/client() pools keep-alive connections and reuses them across requests.
// The server accepts ONE connection and hands it to handle-connection, whose
// keep-alive loop serves every request that arrives on it. Three pooled client-get
// calls to the same origin reuse that single connection, so the handler runs three
// times on the one accepted connection — proving reuse (a non-pooling client would
// need three separate connections, but the server only accepts one). The server
// thread ends when client-close closes the connection (so the process exits).

fn main() {
    let port = 20000 + core/random-int(20000)
    let ready = atom(false)
    let requests = atom(0)

    thread(fn() {
        let listener = socket/listen("127.0.0.1", port)
        reset!(ready, true)
        let handler = fn(req) {
            swap!(requests, fn(c) { c + 1 })
            http/ok("got:" ++ req.path)
        }
        // ONE accept; the keep-alive loop serves all three requests on it.
        http/handle-connection(socket/accept(listener), handler, http/config-from-opts({}))
        socket/close-listener(listener)
    })

    loop {
        if deref(ready) { break(null) }
        core/sleep(1)
    }

    let c = http/client()
    let r1 = http/client-get(c, "http://127.0.0.1:${port}/a")
    let r2 = http/client-get(c, "http://127.0.0.1:${port}/b")
    let r3 = http/client-get(c, "http://127.0.0.1:${port}/c")

    println("r1: " ++ to-string(unwrap!(r1).status) ++ " " ++ unwrap!(r1).body)
    println("r2: " ++ to-string(unwrap!(r2).status) ++ " " ++ unwrap!(r2).body)
    println("r3: " ++ to-string(unwrap!(r3).status) ++ " " ++ unwrap!(r3).body)
    println("requests-on-one-conn: " ++ to-string(deref(requests)))
    http/client-close(c)
    println("done")
}

// @beagle.core.snapshot
// r1: 200 got:/a
// r2: 200 got:/b
// r3: 200 got:/c
// requests-on-one-conn: 3
// done
