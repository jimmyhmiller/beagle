namespace struct_structural_redefine_race_test

// Regression for concurrent structural redefinition + GC layout-migration.
// The historical hang was a layout-version alias after 16+ redefinitions: the
// collector could migrate an object to version N, then classify the new copy as
// still needing a migration keyed by that same wrapped version.
// See docs/CONCURRENT_REDEFINE_OPEN_ISSUES.md (#7/#9).

use beagle.core as core

// Regression test for the structural-redefine GC stale-root crash (the deeper
// bug found alongside the binding-clobber race in concurrent_redefine_race_test.bg).
//
// A long-lived Point instance is read field-by-field on two threads while this
// thread STRUCTURALLY redefines Point (add a field, reorder, shrink) and forces
// a collection after each redefine. GC layout-migration rewrites the live
// instance to the new layout, which *moves* it; the collector must update every
// reader's reference so a later field access never dereferences a forwarded/
// freed corpse ("Struct not found … is_forwarding=true") or reads a heap
// pointer where an int lives.
//
// It redefines by GROWING, REORDERING, then SHRINKING (add a field, move
// existing fields, then remove the extra field). The number of rounds is high
// enough to cross the old 4-bit layout-version wrap boundary.

struct Point { x, y }

fn reader(p, running, crashed) {
    while deref(running) == true {
        try { p.x } catch (e, resume) { swap!(crashed, fn(c) { c + 1 }) resume(0) }
        try { p.y } catch (e, resume) { swap!(crashed, fn(c) { c + 1 }) resume(0) }
    }
}

fn redefiner(rounds, running) {
    let mut r = 0
    while r < rounds {
        eval("namespace struct_structural_redefine_race_test
struct Point { x, y, z }")
        core/gc()
        eval("namespace struct_structural_redefine_race_test
struct Point { z, y, x }")
        core/gc()
        eval("namespace struct_structural_redefine_race_test
struct Point { x, y }")
        core/gc()
        r = r + 1
    }
    reset!(running, false)
}

fn wait_done(a, attempts) {
    if deref(a) >= 1 {
        true
    } else if attempts > 2000000000 {
        false
    } else {
        wait_done(a, attempts + 1)
    }
}

test "concurrent structural redefine migrates live readers" {
    let running = atom(true)
    let crashed = atom(0)
    let done1 = atom(0)
    let done2 = atom(0)
    let anchor = Point { x: 111, y: 222 }
    thread(fn() { reader(anchor, running, crashed) swap!(done1, fn(x) { 1 }) })
    thread(fn() { reader(anchor, running, crashed) swap!(done2, fn(x) { 1 }) })
    redefiner(40, running)
    wait_done(done1, 0)
    wait_done(done2, 0)
    assert-eq!(deref(crashed), 0)
    assert-eq!(anchor.x, 111)
    assert-eq!(anchor.y, 222)
}
