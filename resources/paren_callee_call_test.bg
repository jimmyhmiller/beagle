namespace paren_callee_call_test

// Regression: a call postfix `(args)` on a NON-identifier callee — a
// parenthesized expression `(expr)(args)` or an index `arr[i](args)` — used to
// be silently dropped (returning the callee instead of calling it), because
// `OpenParen` had precedence 0 in the Pratt parser to protect space-separated
// collection literals. The fix gives it call precedence and suppresses it only
// in map-value / set-element context (`allow_call_postfix`).

fn add_one(n) { n + 1 }
fn get_fn() { add_one }
fn apply(f, x) { f(x) }

test "parenthesized callee is called" {
    assert-eq!((add_one)(10), 11)
}

test "call-result callee is called" {
    assert-eq!((get_fn())(10), 11)
}

test "index-then-call works" {
    let fns = [add_one, add_one, add_one]
    assert-eq!(fns[0](10), 11)
    assert-eq!(fns[2](41), 42)
}

test "chained parenthesized call composes with other postfixes" {
    // ((expr)(args)) then a further call argument
    assert-eq!(apply((get_fn()), 5), 6)
}

test "map literal values stay space-separated (not calls)" {
    // `5 (:y)` must be value-then-key, not a call `5(:y)`.
    let m = {:x 5 (:y) 6}
    assert-eq!(get(m, :x), 5)
    assert-eq!(get(m, :y), 6)
}

test "map literal still allows identifier-call values" {
    let m = {:a add_one(7)}
    assert-eq!(get(m, :a), 8)
}

test "set literal elements stay space-separated (not calls)" {
    let s = #{1 2 3}
    assert-eq!(count(s), 3)
    assert!(contains?(s, 2))
}

// A multi-shot resumable-exception continuation invoked via the inline
// parenthesized-callee form — the exact shape that first surfaced this bug.
fn throwing_body() { let x = throw("boom") x + 100 }

test "resume continuation invoked via parenthesized callee, multi-shot" {
    let saved = atom(null)
    let first = try { throwing_body() } catch (e, resume) { reset!(saved, resume) resume(1) }
    assert-eq!(first, 101)
    assert-eq!((deref(saved))(2), 102)
    assert-eq!((deref(saved))(3), 103)
}
