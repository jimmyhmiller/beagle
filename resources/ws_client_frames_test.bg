namespace ws_client_frames_test

use beagle.ws as ws
use beagle.socket as socket
use beagle.string-builder as sb

// Socket-free tests for client-side masked frame encoding and close-code
// extraction. Frames are pure byte transforms, so the round trips need no socket.

// A reader that yields a fixed byte string once, then EOF (conn unused).
fn canned-reader(bytes) {
    let remaining = atom(bytes)
    socket/reader-with(null, fn(n) {
        let b = deref(remaining)
        reset!(remaining, "")
        b
    })
}

test "masked client text frame round-trips through parse-frame" {
    let f = ws/parse-frame(ws/text-frame-masked("hello"))
    assert!(ws/text?(f))
    assert!(f.masked)
    assert-eq!(f.payload, "hello")
}

test "explicit masking key masks the payload bytes (and round-trips)" {
    // "AAAA" is four 0x41 bytes; XOR with key [1,2,3,4] -> [0x40,0x43,0x42,0x45].
    let frame = ws/encode-frame-masked-with-key(0x1, "AAAA", 1, 2, 3, 4)
    let buf = sb/new(16)
    sb/append!(buf, frame)
    // Layout: [0]=FIN|opcode, [1]=MASK|len, [2..5]=key, [6..9]=masked payload.
    assert-eq!(sb/byte-at(buf, 1) & 0xFF, 0x84)   // MASK bit set, len 4
    assert-eq!(sb/byte-at(buf, 6) & 0xFF, 0x40)
    assert-eq!(sb/byte-at(buf, 7) & 0xFF, 0x43)
    assert-eq!(sb/byte-at(buf, 8) & 0xFF, 0x42)
    assert-eq!(sb/byte-at(buf, 9) & 0xFF, 0x45)
    let f = ws/parse-frame(frame)
    assert!(f.masked)
    assert-eq!(f.payload, "AAAA")
}

test "the server read path unmasks a real masked client frame" {
    let r = canned-reader(ws/text-frame-masked("ping-me"))
    let f = ws/read-frame(r)
    assert!(f.masked)
    assert-eq!(f.payload, "ping-me")
}

test "close-code extraction (1009 / 1000 / 1005 no-status)" {
    assert-eq!(ws/close-code(ws/parse-frame(ws/close-frame-status(1009))), 1009)
    assert-eq!(ws/close-code(ws/parse-frame(ws/close-frame-status(1000))), 1000)
    // A close frame with no payload reports 1005 ("no status present").
    assert-eq!(ws/close-code(ws/parse-frame(ws/close-frame())), 1005)
}
