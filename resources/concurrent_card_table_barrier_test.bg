namespace concurrent_card_table_barrier_test

// gc-always

use beagle.channel as chan
use beagle.test-async as ta

// Regression: the generational write barrier must be safe under concurrent
// mutators. A long-lived (old-gen) atom gets a fresh young struct swapped in on
// every iteration (an old->young edge that must be card-marked), while two
// worker threads churn young allocations that drive minor GCs. The old barrier
// pushed to shared `Vec`s (dirty_card_indices / remembered_set) per write — a
// data race that dropped old->young edges, so the young struct was lost across a
// minor GC and a later field read hit a stale/forwarded pointer ("Struct not
// found by ID" / "stale young gen pointer"). The lock-free card-byte barrier
// fixes it: every read below must see the well-formed struct (bad stays 0).

struct W { n, tag }
let w_atom = atom(W { n: 0, tag: 99 })

fn churn(i) { if i <= 0 { 0 } else { let _ = W { n: i, tag: 7 } churn(i - 1) } }

test "concurrent write barrier keeps the old->young edge under churn" {
    let done_ch = chan/make-channel()
    thread(fn() { churn(350) chan/send!(done_ch, ["t1", "done"]) })
    thread(fn() { churn(350) chan/send!(done_ch, ["t2", "done"]) })

    let mut i = 0
    let mut bad = 0
    while i < 350 {
        let w = deref(w_atom)
        if w.tag != 99 { bad = bad + 1 }
        swap!(w_atom, fn(prev) { W { n: i, tag: 99 } })
        i = i + 1
    }

    // Deterministic completion barrier (replaces the magic-number-capped
    // wait_done busy-spin): EXACTLY both churn threads must finish — each send!s
    // on exit, a happens-before edge. Generous watchdog because gc-always is
    // slow; a churn thread stuck on a dropped edge hard-fails instead of spinning.
    ta/assert-receives-all!(done_ch, 2, [["t1", "done"], ["t2", "done"]], 20000)

    // Every deref above saw the well-formed struct (tag 99), so the barrier never
    // dropped the old->young edge.
    assert-eq!(bad, 0)
}
