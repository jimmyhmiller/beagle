namespace semver_ext2_test

use beagle.semver as semver

// ---------------------------------------------------------------------------
// satisfies? (pre-existing) — comparator + bare/exact forms
// ---------------------------------------------------------------------------

test "satisfies? bare and = are exact match" {
    assert!(semver/satisfies?("1.2.3", "1.2.3"))
    assert!(semver/satisfies?("1.2.3", "=1.2.3"))
    assert-eq!(semver/satisfies?("1.2.4", "1.2.3"), false)
    assert-eq!(semver/satisfies?("1.2.4", "=1.2.3"), false)
}

test "satisfies? comparators ge gt le lt" {
    assert!(semver/satisfies?("1.2.5", ">=1.2.0"))
    assert!(semver/satisfies?("1.2.0", ">=1.2.0"))
    assert-eq!(semver/satisfies?("1.2.0", ">1.2.0"), false)
    assert!(semver/satisfies?("1.2.1", ">1.2.0"))
    assert!(semver/satisfies?("1.2.0", "<=1.2.0"))
    assert!(semver/satisfies?("1.3.0", "<2.0.0"))
    assert-eq!(semver/satisfies?("2.0.0", "<2.0.0"), false)
}

test "satisfies? prerelease leak rule blocks foreign prerelease" {
    // 2.0.0-alpha would be >= 1.0.0 numerically, but the node-semver rule
    // rejects a prerelease whose tuple no comparator carries a prerelease for.
    assert-eq!(semver/satisfies?("2.0.0-alpha", ">=1.0.0"), false)
}

test "satisfies? throws on bad version or bad comparator operand" {
    assert-throws!(fn() { semver/satisfies?("not-a-version", ">=1.0.0") })
    assert-throws!(fn() { semver/satisfies?("1.2.3", ">=nope") })
}

// ---------------------------------------------------------------------------
// range-and (new) — conjunction of comparator strings
// ---------------------------------------------------------------------------

test "range-and all comparators hold" {
    assert!(semver/range-and("1.2.5", [">=1.2.0", "<2.0.0"]))
    assert!(semver/range-and("1.2.5", [">1.0.0", "<1.3.0", ">=1.2.5"]))
}

test "range-and fails when any comparator fails" {
    // 2.0.0 is not < 2.0.0
    assert-eq!(semver/range-and("2.0.0", [">=1.2.0", "<2.0.0"]), false)
    // 1.2.5 is not < 1.2.5
    assert-eq!(semver/range-and("1.2.5", [">1.0.0", "<1.2.5"]), false)
}

test "range-and empty vector is vacuously true" {
    assert!(semver/range-and("1.2.5", []))
}

test "range-and trims comparator whitespace" {
    assert!(semver/range-and("1.2.5", ["  >=1.2.0  ", " <2.0.0 "]))
}

test "range-and throws on bad version or bad comparator" {
    assert-throws!(fn() { semver/range-and("garbage", [">=1.0.0"]) })
    assert-throws!(fn() { semver/range-and("1.2.5", ["garbage"]) })
    assert-throws!(fn() { semver/range-and("1.2.5", [">=1.2.0", ">=bad"]) })
}
