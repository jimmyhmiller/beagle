namespace redefine_large_struct_dynamic_fallback_test

// Regression: stale allocation fallback must not have a fixed 32-field ABI cap.

struct P {
    f0, f1, f2, f3, f4, f5, f6, f7,
    f8, f9, f10, f11, f12, f13, f14, f15,
    f16, f17, f18, f19, f20, f21, f22, f23,
    f24, f25, f26, f27, f28, f29, f30, f31,
    f32
}

fn make() {
    P {
        f0: 0, f1: 1, f2: 2, f3: 3, f4: 4, f5: 5, f6: 6, f7: 7,
        f8: 8, f9: 9, f10: 10, f11: 11, f12: 12, f13: 13, f14: 14, f15: 15,
        f16: 16, f17: 17, f18: 18, f19: 19, f20: 20, f21: 21, f22: 22, f23: 23,
        f24: 24, f25: 25, f26: 26, f27: 27, f28: 28, f29: 29, f30: 30, f31: 31,
        f32: 32
    }
}

fn main() {
    eval("namespace redefine_large_struct_dynamic_fallback_test
struct P {
    f32, f0, f1, f2, f3, f4, f5, f6,
    f7, f8, f9, f10, f11, f12, f13, f14,
    f15, f16, f17, f18, f19, f20, f21, f22,
    f23, f24, f25, f26, f27, f28, f29, f30,
    f31, f33
}")
    let after = make()
    println(after.f0)
    println(after.f32)
    println(after.f33)
    println("done")
}

// @beagle.core.snapshot
// 0
// 32
// null
// done
