namespace mathx_ext2_test

// Extra coverage for beagle.mathx gcd / lcm / clamp / sign. All four already
// exist in the module; these tests pin their values independently (expected
// values derived by hand-evaluating the Euclidean / clamp / sign code), with
// emphasis on edges: gcd/lcm with zero, negative operands, coprime and equal
// inputs, clamp boundaries and out-of-range, and sign on negatives/zero/floats.

use beagle.mathx as m

test "gcd basic and zero edges" {
    assert-eq!(m/gcd(12, 18), 6)
    assert-eq!(m/gcd(0, 5), 5)
    assert-eq!(m/gcd(5, 0), 5)
    assert-eq!(m/gcd(0, 0), 0)
    assert-eq!(m/gcd(7, 7), 7)
    assert-eq!(m/gcd(17, 5), 1)
}

test "gcd negative operands (non-negative result)" {
    assert-eq!(m/gcd(0 - 12, 18), 6)
    assert-eq!(m/gcd(12, 0 - 18), 6)
    assert-eq!(m/gcd(0 - 12, 0 - 18), 6)
    assert!(m/gcd(0 - 8, 0 - 12) >= 0)
    assert-eq!(m/gcd(0 - 8, 0 - 12), 4)
}

test "lcm basic and zero contract" {
    assert-eq!(m/lcm(4, 6), 12)
    assert-eq!(m/lcm(21, 6), 42)
    assert-eq!(m/lcm(7, 7), 7)
    assert-eq!(m/lcm(0, 5), 0)
    assert-eq!(m/lcm(5, 0), 0)
    assert-eq!(m/lcm(0, 0), 0)
}

test "lcm negative operands (non-negative result)" {
    assert-eq!(m/lcm(0 - 4, 6), 12)
    assert-eq!(m/lcm(4, 0 - 6), 12)
    assert-eq!(m/lcm(0 - 4, 0 - 6), 12)
    assert!(m/lcm(0 - 4, 6) >= 0)
}

test "clamp out of range and inside" {
    assert-eq!(m/clamp(5, 0, 3), 3)
    assert-eq!(m/clamp(0 - 1, 0, 3), 0)
    assert-eq!(m/clamp(2, 0, 3), 2)
}

test "clamp boundaries" {
    assert-eq!(m/clamp(0, 0, 3), 0)
    assert-eq!(m/clamp(3, 0, 3), 3)
}

test "clamp floats" {
    assert-eq!(m/clamp(2.5, 0.0, 3.0), 2.5)
    assert-eq!(m/clamp(5.5, 0.0, 3.0), 3.0)
    assert-eq!(m/clamp(0.0 - 1.0, 0.0, 3.0), 0.0)
}

test "sign negative zero positive" {
    assert-eq!(m/sign(0 - 3), -1)
    assert-eq!(m/sign(0), 0)
    assert-eq!(m/sign(42), 1)
}

test "sign on floats" {
    assert-eq!(m/sign(0.0 - 2.5), -1)
    assert-eq!(m/sign(2.5), 1)
}
