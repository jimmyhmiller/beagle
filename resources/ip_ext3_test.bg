namespace ip_ext3_test

use beagle.ip as ip

// Coverage for the extended beagle.ip helpers (standard-library/beagle.ip.bg):
// is-loopback?, is-private?, is-multicast?, broadcast-address, host-count.
// IPv4 addresses are 32-bit ints in host order: (a<<24)|(b<<16)|(c<<8)|d.

test "is-loopback? true cases" {
    assert!(ip/is-loopback?("127.0.0.1"))
    assert!(ip/is-loopback?("127.0.0.0"))
    assert!(ip/is-loopback?("127.255.255.254"))
    assert!(ip/is-loopback?("127.255.255.255"))
}

test "is-loopback? false cases" {
    assert-eq!(ip/is-loopback?("128.0.0.1"), false)
    assert-eq!(ip/is-loopback?("126.255.255.255"), false)
    assert-eq!(ip/is-loopback?("10.0.0.1"), false)
    // invalid input is not loopback
    assert-eq!(ip/is-loopback?("not-an-ip"), false)
    assert-eq!(ip/is-loopback?("999.1.1.1"), false)
}

test "is-private? RFC 1918 ranges" {
    // 10.0.0.0/8
    assert!(ip/is-private?("10.0.0.1"))
    assert!(ip/is-private?("10.255.255.255"))
    // 172.16.0.0/12 spans 172.16.0.0 - 172.31.255.255
    assert!(ip/is-private?("172.16.0.1"))
    assert!(ip/is-private?("172.31.255.255"))
    // 192.168.0.0/16
    assert!(ip/is-private?("192.168.1.1"))
    assert!(ip/is-private?("192.168.255.255"))
}

test "is-private? boundary and public addresses" {
    // just outside 172.16/12
    assert-eq!(ip/is-private?("172.15.255.255"), false)
    assert-eq!(ip/is-private?("172.32.0.1"), false)
    // public addresses
    assert-eq!(ip/is-private?("8.8.8.8"), false)
    assert-eq!(ip/is-private?("1.1.1.1"), false)
    // loopback is NOT private under this narrow check
    assert-eq!(ip/is-private?("127.0.0.1"), false)
    // link-local is NOT private under this narrow check
    assert-eq!(ip/is-private?("169.254.1.1"), false)
    // invalid input
    assert-eq!(ip/is-private?("bad"), false)
}

test "is-multicast? 224.0.0.0/4" {
    assert!(ip/is-multicast?("224.0.0.0"))
    assert!(ip/is-multicast?("224.0.0.1"))
    assert!(ip/is-multicast?("239.255.255.255"))
    assert!(ip/is-multicast?("230.1.2.3"))
}

test "is-multicast? non-multicast addresses" {
    // one below the range
    assert-eq!(ip/is-multicast?("223.255.255.255"), false)
    // one above the range
    assert-eq!(ip/is-multicast?("240.0.0.0"), false)
    assert-eq!(ip/is-multicast?("192.168.1.1"), false)
    assert-eq!(ip/is-multicast?("8.8.8.8"), false)
    // invalid input
    assert-eq!(ip/is-multicast?("nope"), false)
}

test "broadcast-address common prefixes" {
    assert-eq!(ip/broadcast-address("192.168.1.0/24"), "192.168.1.255")
    assert-eq!(ip/broadcast-address("10.0.0.0/8"), "10.255.255.255")
    // host bits inside the input are masked to the network first
    assert-eq!(ip/broadcast-address("192.168.1.130/26"), "192.168.1.191")
    assert-eq!(ip/broadcast-address("192.168.1.0/30"), "192.168.1.3")
}

test "broadcast-address small and full subnets" {
    // /32: broadcast equals the host itself
    assert-eq!(ip/broadcast-address("192.168.1.1/32"), "192.168.1.1")
    // /31: upper of the two addresses
    assert-eq!(ip/broadcast-address("192.168.1.0/31"), "192.168.1.1")
    // /0: everything
    assert-eq!(ip/broadcast-address("0.0.0.0/0"), "255.255.255.255")
}

test "broadcast-address throws on bad input" {
    assert-throws!(fn() { ip/broadcast-address("garbage") })
    assert-throws!(fn() { ip/broadcast-address("192.168.1.0/33") })
    assert-throws!(fn() { ip/broadcast-address("999.1.1.1/24") })
}

test "host-count standard prefixes" {
    assert-eq!(ip/host-count("192.168.1.0/24"), 254)
    assert-eq!(ip/host-count("10.0.0.0/8"), 16777214)
    assert-eq!(ip/host-count("192.168.1.0/30"), 2)
    assert-eq!(ip/host-count("192.168.1.0/28"), 14)
}

test "host-count small and full subnets" {
    // /31 returns 2 (RFC 3021 point-to-point)
    assert-eq!(ip/host-count("192.168.1.0/31"), 2)
    // /32 returns 1 (single host)
    assert-eq!(ip/host-count("192.168.1.1/32"), 1)
    // /0 covers the whole space minus network+broadcast
    assert-eq!(ip/host-count("0.0.0.0/0"), 4294967294)
}

test "host-count throws on bad input" {
    assert-throws!(fn() { ip/host-count("garbage") })
    assert-throws!(fn() { ip/host-count("192.168.1.0/33") })
    assert-throws!(fn() { ip/host-count("10.0.0.0") })
}
