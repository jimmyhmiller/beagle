namespace soak_redefine_test

use beagle.core as core
use beagle.channel as chan
use beagle.test-async as ta

// ============================================================================
// Long-session live-coding SOAK (FUTURE_WORK §4 priority-2 / §3.1).
// ============================================================================
// A live-programming language must survive a long live-coding session — many
// redefinitions against running readers — without crashing, corrupting state, or
// LEAKING. This asserts that DETERMINISTICALLY (bounded growth, not eyeball):
//
//  PHASE 1 (concurrent safety): sustained struct + fn redefinition under reader
//    threads => ZERO reader errors, via the §2.1 channel completion barrier.
//    (Race-clean kinds only; protocol-impl re-extend under concurrent readers is
//    the separately-tracked §1.2 ~2% torn-read and is exercised single-threaded
//    in Phase 2.)
//
//  PHASE 2 (no GC-heap leak): sustained struct + fn + protocol redefinition,
//    single-threaded so the live set is noise-free, with multi-checkpoint
//    heap-bytes sampling. A per-round leak (e.g. unbounded definition retention)
//    shows as monotonic growth across checkpoints; a bounded heap keeps the
//    checkpoint spread tiny. Measured empirically: the heap PLATEAUS after a
//    short warmup on all 3 GCs (gen 24080->24400, compacting/ms 24080->24248);
//    a correct run's post-warmup spread is ~hundreds of bytes. The window + slack
//    are tuned (see PHASE 2 below) so a MINIMAL ~1-small-object/round leak
//    (~22 B/round) trips it (~22 KB over the window ≫ 4 KB slack) while a correct
//    run never false-fails — verified both ways (correct run + injected leak).
//
//  NOTE (deliberately NOT asserted): total RSS is expected-unbounded because the
//  JIT CodeAllocator never reclaims code (src/code_memory.rs) — every redefine
//  emits new code. That is a real, separate long-session item (logged in
//  FUTURE_WORK), not a GC leak; the soak asserts on the GC heap, which IS bounded.

protocol SoakDescribable { fn soak-describe(self) }
struct SoakThing { a }
fn soak-fn(x) { x + 1 }

// Race-clean churn (struct grow/reorder/shrink + fn) — safe under concurrent
// readers. Each eval recompiles, exercising the redefinition path.
fn churn-struct-and-fn() {
    eval("namespace soak_redefine_test
struct SoakThing { a, b }")
    eval("namespace soak_redefine_test
struct SoakThing { b, a }")
    eval("namespace soak_redefine_test
struct SoakThing { a }")
    eval("namespace soak_redefine_test
fn soak-fn(x) { x * 2 }")
    eval("namespace soak_redefine_test
fn soak-fn(x) { x + 1 }")
}

// Full churn including protocol re-extend — used single-threaded in Phase 2.
fn churn-all() {
    churn-struct-and-fn()
    eval("namespace soak_redefine_test
extend SoakThing with SoakDescribable { fn soak-describe(self) { 1 } }")
    eval("namespace soak_redefine_test
extend SoakThing with SoakDescribable { fn soak-describe(self) { 2 } }")
}

// Reader: reads a long-lived anchor's stable field + calls the live fn in a tight
// loop (like a game loop), counting any crash, until stopped. Reports its error
// count on exit (a happens-before edge the test body's barrier waits on).
fn reader(anchor, stop, label, done_ch) {
    let mut errors = 0
    while !deref(stop) {
        try {
            let _ = anchor.a
            let _ = soak-fn(1)
        } catch (e, resume) {
            errors = errors + 1
            resume(null)
        }
    }
    chan/send!(done_ch, [label, errors])
}

fn heap-after-gc() {
    core/gc()
    core/heap-bytes()
}

test "soak: sustained redefinition under concurrent readers stays correct" {
    let stop = atom(false)
    let done_ch = chan/make-channel()
    let anchor = SoakThing { a: 7 }
    thread(fn() { reader(anchor, stop, "r1", done_ch) })
    thread(fn() { reader(anchor, stop, "r2", done_ch) })
    thread(fn() { reader(anchor, stop, "r3", done_ch) })

    let mut i = 0
    while i < 300 {
        churn-struct-and-fn()
        i = i + 1
    }
    reset!(stop, true)

    // All three readers finished with ZERO errors, in any order (§2.1 barrier).
    ta/assert-receives-all!(done_ch, 3, [["r1", 0], ["r2", 0], ["r3", 0]], 20000)
}

test "soak: sustained redefinition does not leak the GC heap" {
    // Warm up well past the observed plateau (~90 rounds) so caches / sticky-bit
    // fallbacks have settled and the front-loaded growth is excluded.
    let mut w = 0
    while w < 200 {
        churn-all()
        w = w + 1
    }

    // Multi-checkpoint slope: a per-round leak grows the heap monotonically
    // across checkpoints; a bounded heap keeps the spread tiny. The window
    // (1000 rounds) and slack (4096 B) are sized for SENSITIVITY to a SLOW leak,
    // which is the whole point of a long-session soak: a minimal ~1-small-
    // object/round leak (~22 B/round, empirically) grows ~22 KB over the window,
    // far above the 4 KB slack, so it trips; the smallest leak this catches is
    // ~4 B/round. A correct run's spread is ~hundreds of bytes (≪ 4 KB), so it
    // never false-fails. (NOTE: these are RELATIVE byte deltas within ONE GC's
    // accounting — do not compare absolute heap-bytes across GCs; mark-and-sweep
    // reports committed−free = live + fragmentation, not pure live.)
    let checkpoints_n = 20
    let rounds_per_checkpoint = 50
    let slack_bytes = 4096

    let mut checkpoints = []
    let mut c = 0
    while c < checkpoints_n {
        let mut r = 0
        while r < rounds_per_checkpoint {
            churn-all()
            r = r + 1
        }
        checkpoints = push(checkpoints, heap-after-gc())
        c = c + 1
    }

    let lo = min-of(checkpoints)
    let hi = max-of(checkpoints)
    let first = first-of(checkpoints)
    let last = last(checkpoints)

    // Slope guard (end vs start) AND spread guard (max vs min) — either catches a
    // monotonic per-round leak; both are ~tens of bytes for a bounded heap.
    assert!((last - first) <= slack_bytes)
    assert!((hi - lo) <= slack_bytes)
}
