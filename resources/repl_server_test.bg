namespace repl_server_test

use beagle.core as core
use beagle.socket as socket
use beagle.repl as repl

// ============================================================================
// Deterministic REPL-server end-to-end live-coding test.
// ============================================================================
// Starts a real REPL server on a background thread and drives it as a client
// over the socket, proving the LIVE-CODING SURFACE: a function / struct /
// protocol redefinition issued through the REPL is correct and observable on
// the very next eval.
//
// WHY main()+snapshot (not a `test {}` block): a `test {}` block currently runs
// WITHOUT the ambient cooperative async handler (only main() and spawned
// threads get it — see beagle.async/__main__), so socket ops, which `perform`
// an async effect, can't run in a test body. main() has the handler. (Giving
// `test {}` blocks an async runtime is a separate, larger change — tracked in
// docs/FUTURE_WORK.md.)
//
// DETERMINISM (argued from happens-before, not timing):
//  - Startup: the server sets `ready` to true right AFTER socket/listen returns
//    (happens-before); main waits for it, then connects (no sleep-to-guess, no
//    refusal-retry).
//  - Op ordering: the REPL protocol is synchronous request->response.
//    `send-and-receive` blocks until the `:status ["done"]` terminator, so op
//    N+1 is not sent until op N is fully drained. The server is single-threaded
//    per client and `handle-eval` spin-waits on a single atomic publish of the
//    COMPLETE response before sending — so a response happens-after the eval
//    fully completed (incl. a structural redefine's in-eval STW migration).
//  - A torn / half-applied redefine deterministically FAILS the snapshot: the
//    next call prints the OLD value (distinct from NEW, so they never coincide)
//    or an error.
//  - Output determinism: the server is started in `quiet` mode (no server-side
//    prints), so main's stdout is exactly the lines below, in order.
//
// SCOPE (no overclaim): proves the SEQUENTIAL live-coding surface. Does NOT
// exercise concurrent dispatch during a redefine — that is the torn-read repro
// (resources/dispatch_torn_read_test.bg). The struct case uses ADD-A-FIELD +
// FRESH construction; it does NOT migrate an old instance (the known-open
// concurrent issue, docs/CONCURRENT_REDEFINE_OPEN_ISSUES.md — out of scope).

fn parse-json(line) {
    try { json-decode(line) } catch (e) { null }
}

// Read one newline-framed line, one byte at a time (handles TCP coalescence).
fn read-line(conn) {
    let mut line = ""
    let mut done = false
    while done == false {
        let data = socket/read(conn, 1)
        if data == null || data == "" {
            done = true
        } else {
            if data == "\n" { done = true } else { line = line ++ data }
        }
    }
    line
}

// Send one request, read responses until the `:status ["done"]` terminator
// (the per-request synchronization barrier).
fn send-and-receive(conn, request) {
    let json = json-encode(request)
    socket/write(conn, json ++ "\n")
    let mut responses = []
    let mut done = false
    while done == false {
        let line = read-line(conn)
        if length(line) > 0 {
            let msg = parse-json(line)
            if msg != null {
                responses = push(responses, msg)
                // Terminate on the success terminator OR an error status: an
                // error eval sends :status ["error", "resumable"] (never "done").
                let status = get(msg, "status")
                if status != null && any?(fn(s) { s == "done" || s == "error" }, status) {
                    done = true
                }
            }
        } else {
            done = true
        }
    }
    responses
}

fn response-value(responses) {
    let mut v = null
    let mut i = 0
    while i < length(responses) {
        let rv = get(nth(responses, i), "value")
        if rv != null { v = rv }
        i = i + 1
    }
    v
}

fn response-error(responses) {
    let mut e = null
    let mut i = 0
    while i < length(responses) {
        let rx = get(nth(responses, i), "ex")
        if rx != null { e = rx }
        i = i + 1
    }
    e
}

fn eval-req(id, code) {
    {:op "eval", :id id, :session "live", :code code}
}

fn main() {
    let host = "127.0.0.1"
    let port = 20000 + core/random-int(15000)
    let stop = atom(false)
    let ready = atom(false)

    // Quiet server on a background thread (threads have the async handler).
    thread(fn() {
        repl/start-repl-server-stoppable(host, port, stop, ready, true)
    })

    // Deterministic startup: the server sets `ready` right after socket/listen.
    while !deref(ready) {
        core/sleep(2)
    }
    let conn = socket/connect(host, port)

    // ---- FUNCTION (value) redefinition: live recompile ----
    send-and-receive(conn, eval-req("1", "fn compute(n) { n + 1 }"))
    println("fn-old: " ++ response-value(send-and-receive(conn, eval-req("2", "compute(99)"))))
    send-and-receive(conn, eval-req("3", "fn compute(n) { n * 2 }"))
    // OLD body would print 100; a torn/half-applied redefine breaks the snapshot.
    println("fn-new: " ++ response-value(send-and-receive(conn, eval-req("4", "compute(99)"))))

    // ---- STRUCT redefinition: ADD a field (fresh construction) ----
    send-and-receive(conn, eval-req("5", "struct Box { a }"))
    send-and-receive(conn, eval-req("6", "struct Box { a, b }"))
    send-and-receive(conn, eval-req("7", "fn box-b(x) { x.b }"))
    let s = send-and-receive(conn, eval-req("8", "box-b(Box { a: 1, b: 7 })"))
    println("struct-newfield: " ++ response-value(s))
    println("struct-err: " ++ to-string(response-error(s)))

    // ---- PROTOCOL redefinition: re-extend an impl ----
    send-and-receive(conn, eval-req("9", "protocol Greet { fn greet(self) }"))
    send-and-receive(conn, eval-req("10", "struct Person { n }"))
    send-and-receive(conn, eval-req("11", "extend Person with Greet { fn greet(self) { 1 } }"))
    println("proto-old: " ++ response-value(send-and-receive(conn, eval-req("12", "greet(Person { n: 0 })"))))
    send-and-receive(conn, eval-req("13", "extend Person with Greet { fn greet(self) { 2 } }"))
    println("proto-new: " ++ response-value(send-and-receive(conn, eval-req("14", "greet(Person { n: 0 })"))))

    // ---- DETERMINISTIC SHUTDOWN ----
    // Close the session first (stops its eval-loop thread via the cancel token —
    // otherwise that thread loops forever and the process can't exit), then stop
    // the server and disconnect.
    send-and-receive(conn, {:op "close", :id "98", :session "live"})
    reset!(stop, true)
    socket/close(conn)
    println("done")
}

// @beagle.core.snapshot
// fn-old: 100
// fn-new: 198
// struct-newfield: 7
// struct-err: null
// proto-old: 1
// proto-new: 2
// done
