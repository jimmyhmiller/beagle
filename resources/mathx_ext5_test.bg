namespace mathx_ext5_test

use beagle.mathx as mx

test "log-base of exact powers" {
    // Same value over itself is exactly 1.0; ln(1) is exactly 0.0.
    assert-eq!(mx/log-base(2, 2), 1.0)
    assert-eq!(mx/log-base(1, 10), 0.0)
    // Floating ratios land a hair off the integer; round to compare.
    assert-eq!(mx/round-to(mx/log-base(8, 2), 6), 3.0)
    assert-eq!(mx/round-to(mx/log-base(100, 10), 6), 2.0)
    assert-eq!(mx/round-to(mx/log-base(27, 3), 6), 3.0)
}

test "log-base invalid input throws" {
    assert-throws!(fn() { mx/log-base(0, 10) })
    assert-throws!(fn() { mx/log-base(-5, 10) })
    assert-throws!(fn() { mx/log-base(8, 1) })
    assert-throws!(fn() { mx/log-base(8, 0) })
    assert-throws!(fn() { mx/log-base(8, -2) })
}

test "round-to basic cases" {
    assert-eq!(mx/round-to(3.14159, 2), 3.14)
    assert-eq!(mx/round-to(2.567, 2), 2.57)
    assert-eq!(mx/round-to(2.5, 0), 3.0)
    assert-eq!(mx/round-to(-2.5, 0), -3.0)
    assert-eq!(mx/round-to(123.456, 0), 123.0)
}

test "round-to integer input and zero places" {
    assert-eq!(mx/round-to(5, 2), 5.0)
    assert-eq!(mx/round-to(0.0, 4), 0.0)
}

test "round-to negative places throws" {
    assert-throws!(fn() { mx/round-to(3.14, -1) })
}

test "factorial pre-existing still works" {
    assert-eq!(mx/factorial(0), 1)
    assert-eq!(mx/factorial(5), 120)
    assert-throws!(fn() { mx/factorial(-1) })
}
