namespace async_parallel_test

use beagle.async as async
use beagle.core as core

// spawn is COOPERATIVE: the futures run concurrently with main but on the SAME
// thread (the cooperative scheduler), never an OS thread. Real parallelism is
// `thread()`. This test verifies both: same-thread execution + correct results.

fn main() {
    println("=== Async Cooperative Execution Test ===")

    let main_thread_id = core/thread-id()
    let thread_ids = atom([])

    let f1 = async/spawn(fn() {
        let id = core/thread-id()
        async/sleep(10)
        swap!(thread_ids, fn(ids) { push(ids, id) })
        id
    })

    let f2 = async/spawn(fn() {
        let id = core/thread-id()
        async/sleep(10)
        swap!(thread_ids, fn(ids) { push(ids, id) })
        id
    })

    let tid1 = async/await(f1)
    let tid2 = async/await(f2)

    if tid1 == main_thread_id && tid2 == main_thread_id {
        println("Futures ran on the SAME thread as main (cooperative): OK")
    } else {
        println("Futures ran on the SAME thread as main (cooperative): FAILED")
    }

    let count = length(deref(thread_ids))
    if count == 2 {
        println("Both futures resolved: OK")
    } else {
        println("Both futures resolved: FAILED (expected 2, got", count, ")")
    }

    println("Final result: done")
}

// @beagle.core.snapshot
// === Async Cooperative Execution Test ===
// Futures ran on the SAME thread as main (cooperative): OK
// Both futures resolved: OK
// Final result: done
