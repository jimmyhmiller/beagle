namespace text_format_test

// Tests for the no-printf formatting toolkit in beagle.text:
// fixed / round-to / commas / pad-left / pad-right, designed to be used with
// ${...} string interpolation instead of a printf mini-language.

use beagle.text as text

test "fixed renders exact decimal places, rounded half-up" {
    assert-eq!(text/fixed(3.14159, 2), "3.14")
    assert-eq!(text/fixed(3.14159, 6), "3.141590")
    assert-eq!(text/fixed(3.0, 0), "3")
    assert-eq!(text/fixed(9.999, 2), "10.00")
    assert-eq!(text/fixed(0.05, 2), "0.05")
    assert-eq!(text/fixed(0.005, 2), "0.01")
    // integer input works too
    assert-eq!(text/fixed(5, 2), "5.00")
}

test "fixed handles negatives" {
    assert-eq!(text/fixed(0.0 - 3.14159, 2), "-3.14")
    assert-eq!(text/fixed(0.0 - 9.999, 2), "-10.00")
    assert-eq!(text/fixed(0.0 - 0.05, 2), "-0.05")
}

test "round-to returns a number rounded to n places" {
    assert-eq!(text/round-to(3.14159, 2), 3.14)
    assert-eq!(text/round-to(2.5, 0), 3.0)
    assert-eq!(text/round-to(0.0 - 2.5, 0), 0.0 - 3.0)
    // the result is a number, usable in further math
    assert-eq!(text/round-to(1.236, 2) + 0.01, 1.25)
}

test "commas inserts thousands separators" {
    assert-eq!(text/commas(0), "0")
    assert-eq!(text/commas(42), "42")
    assert-eq!(text/commas(999), "999")
    assert-eq!(text/commas(1000), "1,000")
    assert-eq!(text/commas(1234567), "1,234,567")
    assert-eq!(text/commas(0 - 1000), "-1,000")
    assert-eq!(text/commas(0 - 1234567), "-1,234,567")
}

test "pad-left/pad-right 2-arg default to spaces" {
    assert-eq!(text/pad-left("42", 5), "   42")
    assert-eq!(text/pad-right("42", 5), "42   ")
    // 3-arg form still works
    assert-eq!(text/pad-left("42", 5, "0"), "00042")
    assert-eq!(text/pad-right("Name", 8, "-"), "Name----")
    // no padding when already wide enough
    assert-eq!(text/pad-left("hello", 3), "hello")
}

test "composes with string interpolation (the printf replacement)" {
    // currency
    assert-eq!("\$${text/fixed(19.5, 2)}", "\$19.50")
    // big counts
    let n = 1000000
    assert-eq!("Count: ${text/commas(n)}", "Count: 1,000,000")
    // a percentage to one decimal
    let pct = text/fixed(0.3333 * 100.0, 1)
    assert-eq!("${pct}%", "33.3%")
}
