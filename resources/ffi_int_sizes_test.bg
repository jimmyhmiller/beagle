namespace ffi_int_sizes_test

use beagle.ffi as ffi

fn get_libc_path() {
    let os = get-os()
    if os == "macos" {
        "libSystem.B.dylib"
    } else if os == "linux" {
        "/lib/x86_64-linux-gnu/libc.so.6"
    } else {
        "libc.so.6"
    }
}

let libc = ffi/load-library(get_libc_path())

// abs(int) -> int: test calling with I8/I16 arg declarations
let c_abs_i8 = ffi/get-function(libc, "abs", [ffi/Type.I8], ffi/Type.I32)
let c_abs_i16 = ffi/get-function(libc, "abs", [ffi/Type.I16], ffi/Type.I32)

// labs(long) -> long: test I64 roundtrip
let c_labs = ffi/get-function(libc, "labs", [ffi/Type.I64], ffi/Type.I64)
let c_llabs = ffi/get-function(libc, "llabs", [ffi/Type.I64], ffi/Type.I64)

fn assert_eq(name, expected, actual) {
    if expected == actual {
        println("PASS: " ++ name)
    } else {
        println("FAIL: " ++ name ++ " expected=" ++ to-string(expected) ++ " got=" ++ to-string(actual))
    }
}

fn test_i8_arg() {
    assert_eq("abs I8 -5", 5, c_abs_i8(-5))
    assert_eq("abs I8 -128", 128, c_abs_i8(-128))
    assert_eq("abs I8 42", 42, c_abs_i8(42))
}

fn test_i16_arg() {
    assert_eq("abs I16 -1000", 1000, c_abs_i16(-1000))
    assert_eq("abs I16 -32768", 32768, c_abs_i16(-32768))
    assert_eq("abs I16 12345", 12345, c_abs_i16(12345))
}

fn test_i64() {
    assert_eq("labs -9999999999", 9999999999, c_labs(-9999999999))
    assert_eq("llabs -1234567890123", 1234567890123, c_llabs(-1234567890123))
    assert_eq("labs 42", 42, c_labs(42))
}

// Callback taking I8/I16/I64 args — verifies arg unmarshalling
// We call the callback indirectly via a C function that invokes it.
// Use qsort's compare callback which receives const void* args; we'll
// treat the buffer as signed int8 entries and sort it.
let c_qsort = ffi/get-function(
    libc,
    "qsort",
    [ffi/Type.MutablePointer, ffi/Type.U64, ffi/Type.U64, ffi/Type.Pointer],
    ffi/Type.Void
)

fn i8_compare(a_ptr, b_ptr) {
    let a = ffi/get-i8(a_ptr, 0)
    let b = ffi/get-i8(b_ptr, 0)
    if a < b { -1 } else if a > b { 1 } else { 0 }
}

fn test_i8_callback_return() {
    // Sort an array of i8s including negatives
    let buf = ffi/allocate(5)
    ffi/set-i8(buf, 0, 50)
    ffi/set-i8(buf, 1, -100)
    ffi/set-i8(buf, 2, 0)
    ffi/set-i8(buf, 3, 127)
    ffi/set-i8(buf, 4, -128)

    // Callback returns I32 (comparator contract), takes Pointer args
    let cmp = ffi/create-callback(i8_compare, [ffi/Type.Pointer, ffi/Type.Pointer], ffi/Type.I32)
    c_qsort(buf, 5, 1, cmp)

    assert_eq("i8 sort[0] = -128", -128, ffi/get-i8(buf, 0))
    assert_eq("i8 sort[1] = -100", -100, ffi/get-i8(buf, 1))
    assert_eq("i8 sort[2] = 0", 0, ffi/get-i8(buf, 2))
    assert_eq("i8 sort[3] = 50", 50, ffi/get-i8(buf, 3))
    assert_eq("i8 sort[4] = 127", 127, ffi/get-i8(buf, 4))
    ffi/deallocate(buf)
}

fn main() {
    test_i8_arg()
    test_i16_arg()
    test_i64()
    test_i8_callback_return()
    "done"
}

// @beagle.core.snapshot
// PASS: abs I8 -5
// PASS: abs I8 -128
// PASS: abs I8 42
// PASS: abs I16 -1000
// PASS: abs I16 -32768
// PASS: abs I16 12345
// PASS: labs -9999999999
// PASS: llabs -1234567890123
// PASS: labs 42
// PASS: i8 sort[0] = -128
// PASS: i8 sort[1] = -100
// PASS: i8 sort[2] = 0
// PASS: i8 sort[3] = 50
// PASS: i8 sort[4] = 127
