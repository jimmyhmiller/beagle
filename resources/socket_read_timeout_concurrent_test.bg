namespace socket_read_timeout_concurrent_test

use beagle.core as core
use beagle.socket as socket
use beagle.async as async

// Proves a parked read-timeout does NOT serialize the cooperative scheduler:
// five connections each read-time-out against a silent server with the SAME
// 500ms deadline, launched as concurrent cooperative tasks. If their parked
// timer-races overlap, all five finish at ~500ms (well under the 1500ms bound);
// if the scheduler blocked per read, it would take ~5*500ms = ~2500ms.

let n-clients = 5

// One client: connect, read with a 500ms deadline against a server that never
// writes, and report whether the deadline fired. Host must be a string literal
// (the connect builtin interns it), so it is inlined here.
fn probe(port) {
    let conn = socket/connect("127.0.0.1", port)
    try {
        let got = socket/read-timeout(conn, 1024, 500)
        "no-timeout"
    } catch (e) {
        "timeout"
    }
}

fn count-timeouts(results) {
    let mut c = 0
    for r in results {
        if r == "timeout" { c = c + 1 }
    }
    c
}

fn main() {
    let server_ready = atom(false)
    let clients_done = atom(false)
    let server_done = atom(false)
    let port = 20000 + core/random-int(40000)

    thread(fn() {
        let listener = socket/listen("127.0.0.1", port)
        reset!(server_ready, true)
        // Accept all clients and hold the connections OPEN and SILENT (never
        // write, never close) until the clients have finished — so each client's
        // read sees no data and hits its deadline rather than EOF.
        let conns = atom([])
        let mut i = 0
        while i < n-clients {
            reset!(conns, push(deref(conns), socket/accept(listener)))
            i = i + 1
        }
        loop {
            if deref(clients_done) { break(null) }
            core/sleep(1)
        }
        for c in deref(conns) { socket/close(c) }
        socket/close-listener(listener)
        reset!(server_done, true)
    })

    loop {
        if deref(server_ready) { break(null) }
        core/sleep(1)
    }

    let start = core/time-now()

    // Launch all probes concurrently as cooperative tasks (no OS threads).
    let futures = atom([])
    let mut i = 0
    while i < n-clients {
        reset!(futures, push(deref(futures), future(probe(port))))
        i = i + 1
    }

    // Await them all; collect the per-client outcomes.
    let mut results = []
    for f in deref(futures) {
        results = push(results, async/await(f))
    }

    let elapsed-ms = (core/time-now() - start) / 1000000

    reset!(clients_done, true)
    loop {
        if deref(server_done) { break(null) }
        core/sleep(1)
    }

    println("timed-out: " ++ to-string(count-timeouts(results)) ++ "/" ++ to-string(n-clients))
    println("concurrent: " ++ to-string(elapsed-ms < 1500))
    println("done")
}

// @beagle.core.snapshot
// timed-out: 5/5
// concurrent: true
// done
