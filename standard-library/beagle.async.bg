// ============================================================================
// Async Combinators (Legacy - for running thunks)
// ============================================================================

/// Call each thunk in order and collect their return values into a vector.
fn run-all-thunks(thunks) {
    let mut results = []
    let mut s = seq(thunks)
    while s != null {
        let thunk = first(s)
        results = push(results, thunk())
        s = next(s)
    }
    results
}

/// Call each thunk in order, returning the first whose Result is Ok, or null if none succeed.
fn await-any(thunks) {
    let mut s = seq(thunks)
    let mut result = null
    let mut found = false
    while s != null && found == false {
        let thunk = first(s)
        let r = thunk()
        if async-ok?(r) {
            result = r
            found = true
        }
        s = next(s)
    }
    result
}

/// Map f over the Ok values of a sequence of Results, leaving Err results unchanged.
fn map-results(results, f) {
    map(fn(r) {
        match r {
            Result.Ok { value } => ok(f(value)),
            Result.Err { error } => r
        }
    }, results)
}

/// Return only the Ok Results from a sequence.
fn filter-ok(results) {
    filter(fn(r) { async-ok?(r) }, results)
}

/// Return the unwrapped values of all Ok Results in a sequence (Err results are dropped).
fn unwrap-all(results) {
    map(fn(r) {
        match r {
            Result.Ok { value } => value,
            Result.Err { error } => null
        }
    }, filter-ok(results))
}

// ============================================================================
// IO Runtime Support
// ============================================================================
// Global event loop for all IO operations

let __io_loop_atom = atom(null)

// ============================================================================
// TCP Result Type Constants
// ============================================================================
// These constants correspond to the result types returned by core/tcp-result-pop().
// Using named constants instead of magic numbers improves code readability.

let TCP_RESULT_NONE = 0
let TCP_CONNECT_OK = 1
let TCP_CONNECT_ERR = 2
let TCP_ACCEPT_OK = 3
let TCP_ACCEPT_ERR = 4
let TCP_READ_OK = 5
let TCP_READ_ERR = 6
let TCP_WRITE_OK = 7
let TCP_WRITE_ERR = 8

// Decode a completed TCP result into a Beagle value
/// Decode a completed TCP result (by its numeric type) into a value: a TcpSocket, read data, bytes written, or a TcpIoError sentinel for failures.
fn decode-tcp-result(result_type, loop_id, op_id) {
    if result_type == TCP_CONNECT_OK || result_type == TCP_ACCEPT_OK {
        let socket_id = core/tcp-result-value-for-op-id(loop_id, op_id)
        TcpSocket { loop_id: loop_id, socket_id: socket_id }
    } else if result_type == TCP_READ_OK {
        core/tcp-result-data-for-op-id(loop_id, op_id)
    } else if result_type == TCP_WRITE_OK {
        core/tcp-result-value-for-op-id(loop_id, op_id)
    } else if result_type == TCP_CONNECT_ERR {
        TcpIoError { message: "Connect failed: " ++ core/tcp-result-data-for-op-id(loop_id, op_id) }
    } else if result_type == TCP_ACCEPT_ERR {
        TcpIoError { message: "Accept failed: " ++ core/tcp-result-data-for-op-id(loop_id, op_id) }
    } else if result_type == TCP_READ_ERR {
        TcpIoError { message: "Read failed: " ++ core/tcp-result-data-for-op-id(loop_id, op_id) }
    } else if result_type == TCP_WRITE_ERR {
        TcpIoError { message: "Write failed: " ++ core/tcp-result-data-for-op-id(loop_id, op_id) }
    } else {
        TcpIoError { message: "Unknown TCP result type: " ++ to-string(result_type) }
    }
}

// Re-raise a TCP result if it is a deferred error sentinel, otherwise pass it
// through. Socket ops call this so the throw happens in the caller's stack
// (inside their try/catch), matching the blocking handler's semantics, rather
// than in the cooperative scheduler where decode-tcp-result actually ran.
/// Re-raise a TcpIoError sentinel as a thrown error, or pass any other value through unchanged.
fn tcp-result-or-throw(result) {
    // `result` is frequently a bare scalar (read-data string, bytes-written int),
    // so this must tolerate non-struct values — instance-of handles that.
    if instance-of(result, TcpIoError) {
        throw(result.message)
    } else {
        result
    }
}

/// Return the shared global event loop, lazily creating a 4-worker threaded loop on first use (CAS-guarded against races).
fn get-io-loop() {
    let loop_id = deref(__io_loop_atom)
    if loop_id == null {
        // Use threaded event loop by default for concurrent I/O safety.
        // This prevents deadlocks when multiple threads perform socket I/O
        // concurrently (e.g., server accepting + client connecting).
        let new_loop = core/event-loop-create-threaded(4)
        // Use CAS to avoid race where two threads both see null and both create loops
        let swapped = compare-and-swap!(__io_loop_atom, null, new_loop)
        if swapped {
            new_loop
        } else {
            // Another thread won the race — destroy our loop, use theirs
            core/event-loop-destroy(new_loop)
            deref(__io_loop_atom)
        }
    } else {
        loop_id
    }
}

/// Return the shared global event loop (thin alias for get-io-loop).
fn get-io-loop-threaded() {
    get-io-loop()
}

// ============================================================================
// CooperativeHandler - single-threaded cooperative scheduler
// ============================================================================
// This handler suspends continuations on async IO and stashes them.
// The scheduler loop polls for completions and resumes ready tasks.
// Sync ops (listen, close) are handled immediately.

/// Park a cooperative task: push a SchedulerTask (its pending op and continuation) onto the handler's task atom. Returns null.
fn stash-task(tasks_atom, op, resume) {
    stash-task-cancellable(tasks_atom, op, resume, null)
}

// Park a task with a `cleanup` thunk run if its flow is cancelled while parked
// here (e.g. close the socket of a pending read). The flow's cancellation token
// is read from __current-cancel-token (set by scheduler-loop for the flow being
// resumed), so every op a flow performs inherits its token automatically.
/// Park a task that, if its flow is cancelled while waiting, runs `cleanup`.
fn stash-task-cancellable(tasks_atom, op, resume, cleanup) {
    let token = deref(__current-cancel-token)
    swap!(tasks_atom, fn(t) {
        push(t, SchedulerTask { op: op, resume: resume, token: token, cleanup: cleanup })
    })
    null
}

// Spawn `thunk` as a COOPERATIVE task on the current scheduler thread (NO OS
// thread) and return a future for it. The scheduler runs the task interleaved
// with everything else; `await` on the returned future suspends the caller
// until it resolves. This is what `spawn`/`future` mean under the cooperative
// default — concurrency without threads. Real parallelism is `thread()`.
/// Spawn thunk as a cooperative task (no OS thread) on the current scheduler and return its future; the scheduler interleaves it with other work.
fn spawn-cooperative-task(tasks_atom, thunk) {
    let future = make-future(FutureState.Running {})
    let state_atom = future.state_atom
    stash-task(
        tasks_atom,
        PendingOp.NewTask {
            thunk: fn() {
                try {
                    reset!(state_atom, FutureState.Resolved { value: thunk() })
                } catch (e) {
                    reset!(state_atom, FutureState.Rejected { error: e })
                }
            }
        },
        null
    )
    future
}

// Spawn a cooperative task governed by an EXPLICIT cancellation token, so the
// whole sub-computation (the thunk and every async op it parks on) can be force-
// cancelled by cancelling `token`. The NewTask is stashed with the explicit token
// (NOT the spawner's), and scheduler-loop publishes it while the thunk runs so
// the thunk's parked ops inherit it. Used by with-timeout.
/// Spawn a cooperative task under cancellation `token` and return its future;
/// cancelling the token force-cancels the task and everything it parks on.
fn spawn-cooperative-task-with-token(tasks_atom, thunk, token) {
    let future = make-future(FutureState.Running {})
    let state_atom = future.state_atom
    swap!(tasks_atom, fn(t) {
        push(t, SchedulerTask {
            op: PendingOp.NewTask {
                thunk: fn() {
                    try {
                        reset!(state_atom, FutureState.Resolved { value: thunk() })
                    } catch (e) {
                        reset!(state_atom, FutureState.Rejected { error: e })
                    }
                }
            },
            resume: null,
            token: token,
            cleanup: null
        })
    })
    future
}

extend CooperativeHandler with effect/Handler(Async) {
    fn handle(self, op, resume) {
        // Resolve the shared I/O loop lazily: pure programs that never touch
        // async IO never pay for spawning an event-loop thread.
        let loop_id = get-io-loop()
        match op {
            Async.IO { action } => {
                match action {
                    // Synchronous — handle immediately
                    IOAction.TcpListen { host, port } => {
                        let listener_id = core/tcp-listen(loop_id, host, port, 128)
                        if listener_id < 0 {
                            throw("Failed to create TCP listener on " ++ host ++ ":" ++ to-string(port))
                        }
                        effect/resume-tail(resume, TcpListener { loop_id: loop_id, listener_id: listener_id })
                    },
                    IOAction.TcpClose { socket } => {
                        core/tcp-close(socket.loop_id, socket.socket_id)
                        effect/resume-tail(resume, null)
                    },
                    IOAction.TcpCloseListener { listener } => {
                        core/tcp-close-listener(listener.loop_id, listener.listener_id)
                        effect/resume-tail(resume, null)
                    },

                    // Asynchronous — submit and stash, do NOT resume
                    IOAction.TcpAccept { listener } => {
                        let op_id = core/tcp-accept-async(loop_id, listener.listener_id, 0)
                        stash-task(self.tasks, PendingOp.TcpIO { op_id: op_id, loop_id: loop_id }, resume)
                    },
                    IOAction.TcpRead { socket, n } => {
                        let op_id = core/tcp-read-async(loop_id, socket.socket_id, n, 0)
                        // If the flow is cancelled while parked here, close the
                        // socket so the abandoned read doesn't leak its fd.
                        stash-task-cancellable(self.tasks, PendingOp.TcpIO { op_id: op_id, loop_id: loop_id }, resume, fn() { core/tcp-close(loop_id, socket.socket_id) })
                    },
                    IOAction.TcpWrite { socket, data } => {
                        let op_id = core/tcp-write-async(loop_id, socket.socket_id, data, 0)
                        stash-task-cancellable(self.tasks, PendingOp.TcpIO { op_id: op_id, loop_id: loop_id }, resume, fn() { core/tcp-close(loop_id, socket.socket_id) })
                    },
                    IOAction.TcpConnect { host, port } => {
                        let op_id = core/tcp-connect-async(loop_id, host, port, 0)
                        // If cancelled mid-connect, tear down the connecting fd.
                        stash-task-cancellable(self.tasks, PendingOp.TcpIO { op_id: op_id, loop_id: loop_id }, resume, fn() { core/tcp-cancel-connect(loop_id, op_id) })
                    }
                }
            },

            // Submit the I/O op AND a timer, then park on a race of the two. If
            // the I/O finishes first, the timer branch loses and is cancelled
            // (timer-cancel); the continuation resumes with the I/O result. If
            // the timer fires first, the I/O branch loses and is cancelled
            // (the socket is closed, dropping the pending read), and the
            // continuation resumes with a TcpIoTimeout sentinel.
            Async.IOTimeout { action, ms } => {
                match action {
                    IOAction.TcpRead { socket, n } => {
                        let op_id = core/tcp-read-async(loop_id, socket.socket_id, n, 0)
                        // Use op_id (unique per loop) as the timer marker so it
                        // never collides with other outstanding timers.
                        let timer_id = core/timer-set(loop_id, ms, op_id)
                        if timer_id < 0 {
                            throw("Failed to set read-timeout timer")
                        }
                        // `cancel` runs when THIS branch loses: if the read loses
                        // (timer won) cancel the pending read but LEAVE THE SOCKET
                        // OPEN (tcp-cancel-read) so the socket-level caller can
                        // still write a response (e.g. an HTTP 408) before closing;
                        // if the timer loses (read won) cancel the now-unneeded timer.
                        let branches = [
                            RaceBranch {
                                op: PendingOp.TcpIO { op_id: op_id, loop_id: loop_id },
                                cancel: fn() { core/tcp-cancel-read(loop_id, socket.socket_id) },
                                win: null
                            },
                            RaceBranch {
                                op: PendingOp.Timer { marker: op_id, loop_id: loop_id },
                                cancel: fn() { core/timer-cancel(loop_id, timer_id) },
                                win: fn(ignored) { TcpIoTimeout {} }
                            }
                        ]
                        stash-task(self.tasks, PendingOp.Race { branches: branches }, resume)
                    },
                    IOAction.TcpConnect { host, port } => {
                        let op_id = core/tcp-connect-async(loop_id, host, port, 0)
                        let timer_id = core/timer-set(loop_id, ms, op_id)
                        if timer_id < 0 {
                            throw("Failed to set connect-timeout timer")
                        }
                        // If the connect loses (timer won) abandon the in-progress
                        // connect (tcp-cancel-connect tears down the connecting fd);
                        // if the timer loses (connect won) cancel the timer.
                        let branches = [
                            RaceBranch {
                                op: PendingOp.TcpIO { op_id: op_id, loop_id: loop_id },
                                cancel: fn() { core/tcp-cancel-connect(loop_id, op_id) },
                                win: null
                            },
                            RaceBranch {
                                op: PendingOp.Timer { marker: op_id, loop_id: loop_id },
                                cancel: fn() { core/timer-cancel(loop_id, timer_id) },
                                win: fn(ignored) { TcpIoTimeout {} }
                            }
                        ]
                        stash-task(self.tasks, PendingOp.Race { branches: branches }, resume)
                    },
                    _ => {
                        throw("Async.IOTimeout supports only IOAction.TcpRead and IOAction.TcpConnect")
                    }
                }
            },

            Async.Sleep { ms } => {
                let marker = core/time-now()
                let timer_id = core/timer-set(loop_id, ms, marker)
                if timer_id < 0 {
                    throw("Failed to set timer")
                }
                stash-task(self.tasks, PendingOp.Timer { marker: marker, loop_id: loop_id }, resume)
            },

            // File operations — submit and stash
            Async.ReadFile { path } => {
                let handle = core/file-read-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit read operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.WriteFile { path, content } => {
                let handle = core/file-write-submit(loop_id, path, content)
                if handle < 0 { throw("Failed to submit write operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.AppendFile { path, content } => {
                let handle = core/file-append-submit(loop_id, path, content)
                if handle < 0 { throw("Failed to submit append operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.DeleteFile { path } => {
                let handle = core/file-delete-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit delete operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.FileExists { path } => {
                let handle = core/file-exists-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit exists operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.RenameFile { old_path, new_path } => {
                let handle = core/file-rename-submit(loop_id, old_path, new_path)
                if handle < 0 { throw("Failed to submit rename operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.CopyFile { src_path, dest_path } => {
                let handle = core/file-copy-submit(loop_id, src_path, dest_path)
                if handle < 0 { throw("Failed to submit copy operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.ReadDir { path } => {
                let handle = core/file-readdir-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit readdir operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.CreateDir { path } => {
                let handle = core/file-mkdir-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit mkdir operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.CreateDirAll { path } => {
                let handle = core/file-mkdir-all-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit mkdir-all operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.RemoveDir { path } => {
                let handle = core/file-rmdir-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit rmdir operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.RemoveDirAll { path } => {
                let handle = core/file-rmdir-all-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit rmdir-all operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.FileSize { path } => {
                let handle = core/file-stat-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit stat operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.IsDirectory { path } => {
                let handle = core/file-is-dir-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit is-directory operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.IsFile { path } => {
                let handle = core/file-is-file-submit(loop_id, path)
                if handle < 0 { throw("Failed to submit is-file operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.Open { path, mode } => {
                let handle = core/file-open-submit(loop_id, path, mode)
                if handle < 0 { throw("Failed to submit open operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.Close { file } => {
                let handle = core/file-close-submit(loop_id, file)
                if handle < 0 { throw("Failed to submit close operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.Read { file, n } => {
                let handle = core/file-handle-read-submit(loop_id, file, n)
                if handle < 0 { throw("Failed to submit handle-read operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.Write { file, content } => {
                let handle = core/file-handle-write-submit(loop_id, file, content)
                if handle < 0 { throw("Failed to submit handle-write operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.ReadLine { file } => {
                let handle = core/file-handle-readline-submit(loop_id, file)
                if handle < 0 { throw("Failed to submit handle-readline operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },
            Async.Flush { file } => {
                let handle = core/file-handle-flush-submit(loop_id, file)
                if handle < 0 { throw("Failed to submit handle-flush operation") }
                stash-task(self.tasks, PendingOp.FileIO { handle: handle, loop_id: loop_id }, resume)
            },

            // Threaded spawn — spawn thread immediately, resume with future.
            // TAIL resume: a synchronous `resume(...)` re-pushes a nested prompt
            // (the resumed flow is then captured under it, not the scheduler
            // handle — which breaks the scheduler's tail resume). A tail resume
            // keeps the flow under the single scheduler prompt.
            Async.Spawn { thunk } => {
                // Cooperative, awaitable, single-threaded — NOT an OS thread.
                effect/resume-tail(resume, spawn-cooperative-task(self.tasks, thunk))
            },
            Async.SpawnWithToken { thunk, token } => {
                // Cooperative (NOT an OS thread): the token governs forced cancel.
                effect/resume-tail(resume, spawn-cooperative-task-with-token(self.tasks, thunk, token))
            },

            // Await a future OR an `ms` timer, whichever finishes first. If the
            // future wins, resume with its (wrapped) value. If the timer wins,
            // cancel the future's token (force-cancelling the whole sub-computation
            // and cleaning up whatever it was parked on) and resume with TimedOut.
            Async.AwaitWithTimeout { future, token, ms } => {
                let marker = core/time-now()
                let timer_id = core/timer-set(loop_id, ms, marker)
                if timer_id < 0 {
                    throw("Failed to set with-timeout timer")
                }
                let branches = [
                    RaceBranch {
                        op: PendingOp.SpawnedTask { future: future },
                        cancel: fn() { cancel!(token) },
                        win: null
                    },
                    RaceBranch {
                        op: PendingOp.Timer { marker: marker, loop_id: loop_id },
                        cancel: fn() { core/timer-cancel(loop_id, timer_id) },
                        win: fn(ignored) { TimeoutResult.TimedOut {} }
                    }
                ]
                stash-task(self.tasks, PendingOp.Race { branches: branches }, resume)
            },

            // Await — stash the future for cooperative polling
            Async.Await { future } => {
                if future == null {
                    effect/resume-tail(resume, null)
                } else {
                    stash-task(self.tasks, PendingOp.SpawnedTask { future: future }, resume)
                }
            },

            // Synchronous operations — handle immediately (tail resume so the
            // resumed flow stays under the scheduler prompt, not a nested one).
            Async.AwaitAll { futures } => {
                effect/resume-tail(resume, handle-await-all-threaded(futures))
            },
            Async.AwaitFirst { futures } => {
                effect/resume-tail(resume, handle-await-first-threaded(futures))
            },
            Async.Cancel { future } => {
                effect/resume-tail(resume, handle-cancel(future))
            }
        }
    }
}

// ============================================================================
// ImplicitAsyncHandler - the primary production handler
// ============================================================================
// This handler provides the implicit ambient async context.
// It combines threaded spawn/await (for correct concurrent futures) with
// event-loop-based sleep and async file I/O (for non-blocking operations).
// The runtime installs it for main() and spawned threads.

/// The primary production async handler: threaded spawn/await combined with event-loop sleep and async file I/O.
struct ImplicitAsyncHandler {}

// Handle an IO action synchronously (blocking current thread)
/// Execute a TCP IOAction synchronously, blocking the current thread on the event loop until the operation completes. Throws on failure.
fn handle-io-action(action) {
    match action {
        // Listen and Connect create new resources - use the current thread's event loop
        IOAction.TcpListen { host, port } => {
            let loop_id = get-io-loop()
            let listener_id = core/tcp-listen(loop_id, host, port, 128)
            if listener_id < 0 {
                throw("Failed to create TCP listener on " ++ host ++ ":" ++ to-string(port))
            }
            TcpListener { loop_id: loop_id, listener_id: listener_id }
        },

        IOAction.TcpConnect { host, port } => {
            let loop_id = get-io-loop()
            let op_id = core/tcp-connect-async(loop_id, host, port, 0)

            // Block until notified (timeout=0 means wait forever)
            // Workers notify immediately when connection result is ready
            loop {
                core/event-loop-run-once(loop_id, 0)
                let result_type = core/tcp-result-pop-for-op-id(loop_id, op_id)
                if result_type == TCP_CONNECT_OK {
                    let socket_id = core/tcp-result-value-for-op-id(loop_id, op_id)
                    break(TcpSocket { loop_id: loop_id, socket_id: socket_id })
                } else if result_type == TCP_CONNECT_ERR {
                    let error = core/tcp-result-data-for-op-id(loop_id, op_id)
                    throw("Connect failed: " ++ error)
                }
            }
        },

        // Accept, Read, Write, Close use the resource's owning event loop
        // so operations go to the correct event loop thread regardless of
        // which thread is calling
        IOAction.TcpAccept { listener } => {
            let loop_id = listener.loop_id
            let op_id = core/tcp-accept-async(loop_id, listener.listener_id, 0)

            // Block until notified (timeout=0 means wait forever)
            // Workers notify immediately when accept result is ready
            loop {
                core/event-loop-run-once(loop_id, 0)
                let result_type = core/tcp-result-pop-for-op-id(loop_id, op_id)
                if result_type == TCP_ACCEPT_OK {
                    let socket_id = core/tcp-result-value-for-op-id(loop_id, op_id)
                    break(TcpSocket { loop_id: loop_id, socket_id: socket_id })
                } else if result_type == TCP_ACCEPT_ERR {
                    let error = core/tcp-result-data-for-op-id(loop_id, op_id)
                    throw("Accept failed: " ++ error)
                }
            }
        },

        IOAction.TcpRead { socket, n } => {
            let loop_id = socket.loop_id
            let op_id = core/tcp-read-async(loop_id, socket.socket_id, n, 0)
            let read_result = op_id
            if read_result < 0 {
                throw("Failed to start read operation")
            }

            // Block until notified (timeout=0 means wait forever)
            // Workers notify immediately when read result is ready
            loop {
                core/event-loop-run-once(loop_id, 0)
                let result_type = core/tcp-result-pop-for-op-id(loop_id, op_id)
                if result_type == TCP_READ_OK {
                    let data = core/tcp-result-data-for-op-id(loop_id, op_id)
                    break(data)
                } else if result_type == TCP_READ_ERR {
                    let error = core/tcp-result-data-for-op-id(loop_id, op_id)
                    throw("Read failed: " ++ error)
                }
            }
        },

        IOAction.TcpWrite { socket, data } => {
            let loop_id = socket.loop_id
            let op_id = core/tcp-write-async(loop_id, socket.socket_id, data, 0)

            // Block until notified (timeout=0 means wait forever)
            // Workers notify immediately when write result is ready
            loop {
                core/event-loop-run-once(loop_id, 0)
                let result_type = core/tcp-result-pop-for-op-id(loop_id, op_id)
                if result_type == TCP_WRITE_OK {
                    let bytes_written = core/tcp-result-value-for-op-id(loop_id, op_id)
                    break(bytes_written)
                } else if result_type == TCP_WRITE_ERR {
                    let error = core/tcp-result-data-for-op-id(loop_id, op_id)
                    throw("Write failed: " ++ error)
                }
            }
        },

        IOAction.TcpClose { socket } => {
            core/tcp-close(socket.loop_id, socket.socket_id)
            null
        },

        IOAction.TcpCloseListener { listener } => {
            core/tcp-close-listener(listener.loop_id, listener.listener_id)
            null
        }
    }
}

extend ImplicitAsyncHandler with effect/Handler(Async) {
    fn handle(self, op, resume) {
        // Acquire the shared I/O loop before destructuring file-operation payloads.
        // Under forced GC, lazy loop creation can allocate on the first async file op.
        let io_loop = get-io-loop()
        let result = match op {
            // Core async operations - use threaded await (polls with future-wait)
            Async.Await { future } => {
                handle-await-threaded(future)
            },
            Async.AwaitAll { futures } => {
                handle-await-all-threaded(futures)
            },
            Async.AwaitFirst { futures } => {
                handle-await-first-threaded(futures)
            },
            Async.Cancel { future } => {
                handle-cancel(future)
            },

            // Generic IO operations
            Async.IO { action } => {
                handle-io-action(action)
            },

            // Timed I/O is a cooperative-scheduler feature (it parks on a race
            // of the op vs a timer). This blocking-style handler has no park, so
            // it is unsupported here — a clear error rather than a silently
            // dropped deadline. Read deadlines run under the cooperative scheduler.
            Async.IOTimeout { action, ms } => {
                throw("Async.IOTimeout (timed reads) requires the cooperative scheduler; not available under this handler")
            },
            Async.AwaitWithTimeout { future, token, ms } => {
                throw("with-timeout requires the cooperative scheduler; not available under this handler")
            },

            // File operations - use async thread pool I/O where available
            Async.ReadFile { path } => {
                handle-read-file-async(io_loop, path)
            },
            Async.WriteFile { path, content } => {
                handle-write-file-async(io_loop, path, content)
            },
            Async.AppendFile { path, content } => {
                handle-append-file-async(io_loop, path, content)
            },
            Async.DeleteFile { path } => {
                handle-delete-file-async(io_loop, path)
            },
            Async.FileExists { path } => {
                handle-file-exists-async(io_loop, path)
            },
            Async.RenameFile { old_path, new_path } => {
                handle-rename-file-async(io_loop, old_path, new_path)
            },
            Async.CopyFile { src_path, dest_path } => {
                handle-copy-file-async(io_loop, src_path, dest_path)
            },
            Async.ReadDir { path } => {
                handle-read-dir-async(io_loop, path)
            },
            Async.CreateDir { path } => {
                handle-create-dir-async(io_loop, path)
            },
            Async.CreateDirAll { path } => {
                handle-create-dir-all-async(io_loop, path)
            },
            Async.RemoveDir { path } => {
                handle-remove-dir-async(io_loop, path)
            },
            Async.RemoveDirAll { path } => {
                handle-remove-dir-all-async(io_loop, path)
            },
            Async.FileSize { path } => {
                handle-file-size-async(io_loop, path)
            },
            Async.IsDirectory { path } => {
                handle-is-directory-async(io_loop, path)
            },
            Async.IsFile { path } => {
                handle-is-file-async(io_loop, path)
            },
            Async.Open { path, mode } => {
                handle-open-async(io_loop, path, mode)
            },
            Async.Close { file } => {
                handle-close-async(io_loop, file)
            },
            Async.Read { file, n } => {
                handle-handle-read-async(io_loop, file, n)
            },
            Async.Write { file, content } => {
                handle-handle-write-async(io_loop, file, content)
            },
            Async.ReadLine { file } => {
                handle-handle-readline-async(io_loop, file)
            },
            Async.Flush { file } => {
                handle-handle-flush-async(io_loop, file)
            },
            Async.Sleep { ms } => {
                handle-sleep-event-loop(io_loop, ms)
            },
            Async.Spawn { thunk } => {
                handle-spawn-threaded(thunk)
            },
            Async.SpawnWithToken { thunk, token } => {
                handle-spawn-with-token-threaded(thunk, token)
            }
        }
        effect/resume-tail(resume, result)
    }
}

// Create the default implicit handler instance
/// Create an ImplicitAsyncHandler instance (the default production handler).
fn create-implicit-handler() {
    ImplicitAsyncHandler {}
}

// ============================================================================
// Cooperative Scheduler Loop
// ============================================================================

// Poll a single PendingOp once. Returns the value the parked continuation
// should resume with, or the shared `poll-pending` sentinel if the op has not
// completed yet (checked with io-pending? / instance-of, never `== null`, since
// a real completion value may legitimately be null).
/// Poll one PendingOp; returns its completion value, or the poll-pending sentinel if not ready.
fn poll-pending-op(op) {
    match op {
        PendingOp.TcpIO { op_id, loop_id } => {
            let result_type = core/tcp-result-pop-for-op-id(loop_id, op_id)
            if result_type != 0 {
                decode-tcp-result(result_type, loop_id, op_id)
            } else {
                poll-pending
            }
        },
        PendingOp.FileIO { handle, loop_id } => {
            let result = poll-file-result(loop_id, handle)
            if result != null {
                result
            } else {
                poll-pending
            }
        },
        PendingOp.Timer { marker, loop_id } => {
            if core/timer-take-completed(loop_id, marker) == 1 {
                async-ok(null)
            } else {
                poll-pending
            }
        },
        PendingOp.SpawnedTask { future } => {
            let state = deref(future.state_atom)
            match state {
                FutureState.Resolved { value } => value,
                // Resume with a sentinel so `await` throws the error at the await
                // site (rather than returning it as a value, breaking try/catch).
                FutureState.Rejected { error } => { AwaitRejected { error: error } },
                // Awaiting a cancelled future used to park forever; resume with a
                // sentinel so `await` throws.
                FutureState.Cancelled {} => { AwaitCancelled {} },
                _ => poll-pending
            }
        },
        // New tasks are always immediately ready to start; the thunk is the value.
        PendingOp.NewTask { thunk } => thunk,
        PendingOp.Race { branches } => poll-race(branches)
    }
}

// Poll a race once: return the first ready branch's (possibly mapped) value,
// cancelling every other branch, or poll-pending if none is ready yet. Branches
// are polled in order, so an earlier branch wins a simultaneous completion
// (the timeout helpers list the real I/O before the timer, preferring a result).
/// Poll a race of branches; on the first ready branch, cancel the losers and return its value, else poll-pending.
fn poll-race(branches) {
    let n = count(branches)
    let mut i = 0
    let mut win-idx = 0 - 1
    let mut win-val = poll-pending
    while i < n && win-idx < 0 {
        let branch = branches[i]
        let r = poll-pending-op(branch.op)
        if instance-of(r, PollPending) == false {
            win-idx = i
            win-val = if branch.win == null { r } else { branch.win(r) }
        }
        i = i + 1
    }
    if win-idx < 0 {
        poll-pending
    } else {
        let mut j = 0
        while j < n {
            if j != win-idx {
                let cancel = branches[j].cancel
                if cancel != null {
                    cancel()
                }
            }
            j = j + 1
        }
        win-val
    }
}

// True if a parked task's flow has been cancelled (e.g. its with-timeout fired).
// A null token is the uncancellable root flow, so this is a cheap no-op for every
// ordinary task — the forced-cancellation machinery only touches tokened flows.
/// True if `task` belongs to a flow whose cancellation token has been cancelled.
fn task-cancelled?(task) {
    task.token != null && cancelled?(task.token)
}

// Poll all pending tasks, returning [ready_list, remaining_list]
/// Poll every parked scheduler task once, returning [ready, remaining]: tasks whose op completed (paired with their result) and those still pending. A task whose flow was cancelled is dropped (its cleanup run) instead of polled.
fn poll-tasks(tasks, loop_id) {
    let mut ready = []
    let mut remaining = []
    for task in tasks {
        if task-cancelled?(task) {
            // The flow was cancelled while parked here: run cleanup (close a
            // socket, etc.) and DROP the task — its continuation is discarded.
            if task.cleanup != null {
                task.cleanup()
            }
        } else {
            let result = poll-pending-op(task.op)
            if instance-of(result, PollPending) {
                remaining = push(remaining, task)
            } else {
                ready = push(ready, ReadyTask { resume: task.resume, result: result, token: task.token })
            }
        }
    }
    [ready, remaining]
}

// Run the scheduler loop — polls for IO completions, resumes ready tasks
/// Run the cooperative scheduler: repeatedly poll parked tasks, resume ready ones (and start new tasks), driving the event loop until no tasks remain.
// Resumes AT MOST ONE ready task per iteration so each resume can be a tail
// resume (`effect/resume-tail`), which reclaims the handler-body frame instead
// of letting the resumed flow's next park capture it — the per-await
// continuation chain that otherwise grows the heap without bound. A tail resume
// teleports (does not return to a `for` loop), so the remaining ready tasks wait
// in a persisted queue (their event-loop results are already consumed and
// carried on each ReadyTask — they must NOT be re-polled). The single `handle`
// is the last action in the loop body at a stable stack depth, so every flow is
// captured under one prompt and the tail resume lands consistently.
fn scheduler-loop(handler) {
    loop {
        let ready = deref(handler.ready)
        let idx = deref(handler.ready_idx)

        if idx >= length(ready) {
            // Ready batch exhausted — poll for more work.
            let tasks = deref(handler.tasks)
            if length(tasks) == 0 {
                break(null)
            }
            let loop_id = deref(__io_loop_atom)
            // Cleanups run by poll-tasks belong to no resumed flow.
            reset!(__current-cancel-token, null)
            let result = poll-tasks(tasks, loop_id)
            let new_ready = result[0]
            let remaining = result[1]
            reset!(handler.tasks, remaining)
            if length(new_ready) == 0 {
                // Nothing runnable yet — drive the event loop instead of spinning.
                if loop_id != null {
                    core/event-loop-run-once(loop_id, 1)
                } else {
                    core/sleep(1)
                }
            } else {
                reset!(handler.ready, new_ready)
                reset!(handler.ready_idx, 0)
            }
        } else {
            // Dequeue and resume exactly one ready task.
            let item = ready[idx]
            reset!(handler.ready_idx, idx + 1)
            // Publish the flow's token BEFORE the resume (a tail resume never
            // returns to code after the `handle`, so each resume sets it itself).
            reset!(__current-cancel-token, item.token)
            handle effect/Handler(Async) with handler {
                if item.resume == null {
                    item.result()
                } else {
                    effect/resume-tail(item.resume, item.result)
                }
            }
        }
    }
}

// Run a thunk under the cooperative scheduler and return its value.
//
// The thunk is enqueued as the root task; when it suspends on an async op the
// continuation is parked and the scheduler runs other ready work, so a single
// thread multiplexes many logical flows while each flow stays sequential.
/// Run thunk under a fresh cooperative scheduler and return its value. The thunk is the root task; async ops park their continuation so other tasks progress on the same thread.
fn run-cooperative(thunk) {
    let handler = CooperativeHandler { tasks: atom([]), loop_id: null, ready: atom([]), ready_idx: atom(0) }
    let result_box = atom(null)
    stash-task(
        handler.tasks,
        PendingOp.NewTask { thunk: fn() { reset!(result_box, thunk()) } },
        null
    )
    scheduler-loop(handler)
    deref(result_box)
}

// ============================================================================
// Main Function Wrapper
// ============================================================================
// This function is called by the runtime to provide the ambient async handler
// for main(). It takes the main function pointer and optional args.
fn __main__(main_fn, args) {
    // Default ambient context is the single-threaded cooperative scheduler:
    // straight-line code stays sequential, but blocking-looking async ops
    // (sleep, socket read/write, file IO) park their continuation so other
    // logical flows progress on the same thread.
    if args == null {
        run-cooperative(main_fn)
    } else {
        run-cooperative(fn() { main_fn(args) })
    }
}

// Thread wrapper — gives each thread its own cooperative scheduler, matching main.
fn __run_thread_start() {
    let thread-obj = primitive/__get-my-thread-obj();
    let f = thread-obj.closure;
    try {
        run-cooperative(f)
    } catch (e) {
        println("Uncaught exception in thread:")
        println(e)
        null
    }
}
