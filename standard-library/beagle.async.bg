// ============================================================================
// Public Async API Functions
// ============================================================================

// Read the entire contents of a file as a string
/// Read the entire contents of a file as a string. Performs Async.ReadFile; returns a Result.
fn read-file(path) {
    perform Async.ReadFile { path: path }
}

// Write content to a file (creates or overwrites)
/// Write content to a file, creating or overwriting it. Performs Async.WriteFile; returns a Result.
fn write-file(path, content) {
    perform Async.WriteFile { path: path, content: content }
}

// Append content to a file (creates if doesn't exist)
/// Append content to a file, creating it if absent. Performs Async.AppendFile; returns a Result.
fn append-file(path, content) {
    perform Async.AppendFile { path: path, content: content }
}

// Delete a file
/// Delete a file. Performs Async.DeleteFile; returns a Result.
fn delete-file(path) {
    perform Async.DeleteFile { path: path }
}

// Check if a file exists
/// Check whether a file exists. Performs Async.FileExists; returns ok(true/false).
fn file-exists?(path) {
    perform Async.FileExists { path: path }
}

// List directory contents
/// List a directory's entries. Performs Async.ReadDir; returns a Result.
fn read-dir(path) {
    perform Async.ReadDir { path: path }
}

// Create a directory
/// Create a directory. Performs Async.CreateDir; returns a Result.
fn create-dir(path) {
    perform Async.CreateDir { path: path }
}

// Create a directory and all parent directories
/// Create a directory and all missing parents. Performs Async.CreateDirAll; returns a Result.
fn create-dir-all(path) {
    perform Async.CreateDirAll { path: path }
}

// Remove an empty directory
/// Remove an empty directory. Performs Async.RemoveDir; returns a Result.
fn remove-dir(path) {
    perform Async.RemoveDir { path: path }
}

// Remove a directory and all contents
/// Remove a directory and all its contents. Performs Async.RemoveDirAll; returns a Result.
fn remove-dir-all(path) {
    perform Async.RemoveDirAll { path: path }
}

// Get file size in bytes
/// Get a file's size in bytes. Performs Async.FileSize; returns a Result.
fn file-size(path) {
    perform Async.FileSize { path: path }
}

// Check if path is a directory
/// Check whether a path is a directory. Performs Async.IsDirectory; returns ok(true/false).
fn is-directory?(path) {
    perform Async.IsDirectory { path: path }
}

// Check if path is a regular file
/// Check whether a path is a regular file. Performs Async.IsFile; returns ok(true/false).
fn is-file?(path) {
    perform Async.IsFile { path: path }
}

// Rename/move a file or directory
/// Rename or move a file or directory. Performs Async.RenameFile; returns a Result.
fn rename-file(old-path, new-path) {
    perform Async.RenameFile { old_path: old-path, new_path: new-path }
}

// Copy a file
/// Copy a file. Performs Async.CopyFile; returns a Result.
fn copy-file(src-path, dest-path) {
    perform Async.CopyFile { src_path: src-path, dest_path: dest-path }
}

// Open a file with mode ("r", "w", "a", etc.)
/// Open a file with the given mode ("r", "w", "a", ...). Performs Async.Open; returns a Result with a file handle.
fn open(path, mode) {
    perform Async.Open { path: path, mode: mode }
}

// Close a file handle
/// Close a file handle. Performs Async.Close; returns a Result.
fn close(file) {
    perform Async.Close { file: file }
}

// Read n bytes from a file
/// Read n bytes from a file. Performs Async.Read; returns a Result with the data.
fn read(file, n) {
    perform Async.Read { file: file, n: n }
}

// Write content to a file
/// Write content to a file. Performs Async.Write; returns a Result.
fn write(file, content) {
    perform Async.Write { file: file, content: content }
}

// Read a line from a file
/// Read a single line from a file. Performs Async.ReadLine; returns a Result.
fn read-line(file) {
    perform Async.ReadLine { file: file }
}

// Flush a file's buffers
/// Flush a file's buffers. Performs Async.Flush; returns a Result.
fn flush(file) {
    perform Async.Flush { file: file }
}

/// Sleep for a number of milliseconds.
///
/// Must be called within an Async effect handler.
///
/// Examples:
///   sleep(1000)  // Sleep for 1 second
fn sleep(ms) {
    perform Async.Sleep { ms: ms }
}

// ============================================================================
// Future/Async API Functions
// ============================================================================


/// Wait for a future to complete and return its value.
///
/// Blocks until the future resolves, rejects, or is cancelled.
///
/// Examples:
///   let f = spawn(fn() { compute() })
///   await(f)  // => result of compute()
fn await(future) {
    let r = perform Async.Await { future: future }
    // Under the cooperative scheduler a rejected/cancelled future resumes here
    // with a sentinel; re-raise it so the caller's try/catch sees the error.
    // (Blocking/threaded handlers throw internally and never produce a sentinel,
    // so this match falls through to `_` and returns the value unchanged.)
    match r {
        AwaitRejected { error } => throw(error),
        AwaitCancelled {} => throw("Future was cancelled"),
        _ => r
    }
}

/// Wait for all futures to complete and return their values as a vector.
///
/// Cooperative: awaits each future in turn. The futures were all spawned up
/// front, so they make progress concurrently on the scheduler while we collect
/// their results in order.
///
/// Examples:
///   let fs = [spawn(fn() { 1 }), spawn(fn() { 2 })]
///   await-all(fs)  // => [1, 2]
fn await-all(futures) {
    let mut results = []
    let mut s = seq(futures)
    while s != null {
        results = push(results, await(first(s)))
        s = next(s)
    }
    results
}

/// Wait for the first future to complete and return its result as a RaceResult.
///
/// Cooperative: polls the futures, yielding to the scheduler (via a 0ms sleep)
/// between rounds so the spawned tasks can run, until one resolves or all fail.
fn await-first(futures) {
    loop {
        let mut s = seq(futures)
        let mut index = 0
        let mut pending = 0
        let mut result = null
        while s != null {
            match future-state(first(s)) {
                FutureState.Resolved { value } => {
                    if result == null {
                        result = RaceResult.Ok { value: value, index: index }
                    }
                },
                FutureState.Rejected { error } => {},
                FutureState.Cancelled {} => {},
                _ => { pending = pending + 1 }
            }
            index = index + 1
            s = next(s)
        }
        if result != null {
            break(result)
        } else if pending == 0 {
            // none pending and none resolved => everything failed
            let mut errors = []
            let mut s2 = seq(futures)
            while s2 != null {
                match future-state(first(s2)) {
                    FutureState.Rejected { error } => { errors = push(errors, error) },
                    FutureState.Cancelled {} => { errors = push(errors, "Cancelled") },
                    _ => {}
                }
                s2 = next(s2)
            }
            break(RaceResult.AllFailed { errors: errors })
        } else {
            // yield to the scheduler so spawned tasks can make progress
            sleep(0)
        }
    }
}

/// Wait for a future with a timeout in milliseconds.
///
/// Returns TimeoutResult.Ok if completed, TimeoutResult.TimedOut if timeout.
fn await-timeout(ms, future) {
    let start = time-now()
    let deadline_ns = start + (ms * 1000000)
    let wait_timeout = 50

    loop {
        let state = future-state(future)
        match state {
            FutureState.Resolved { value } => {
                break(TimeoutResult.Ok { value: value })
            },
            FutureState.Rejected { error } => {
                throw(error)
            },
            FutureState.Cancelled {} => {
                throw("Future was cancelled")
            },
            _ => {
                let now = time-now()
                if now >= deadline_ns {
                    break(TimeoutResult.TimedOut {})
                }
                let remaining_ms = (deadline_ns - now) / 1000000
                let actual_wait = if remaining_ms < wait_timeout {
                    remaining_ms
                } else {
                    wait_timeout
                }
                core/future-wait(actual_wait)
            }
        }
    }
}

// ============================================================================
// Cancellation API Functions
// ============================================================================

// Create a future with a cancellation token
/// Spawn thunk as a task governed by a cancellation token, returning its future. Performs Async.SpawnWithToken.
fn async-with-token(token, thunk) {
    perform Async.SpawnWithToken { thunk: thunk, token: token }
}

// Cancel a future (cooperative cancellation)
/// Request cooperative cancellation of a future. Performs Async.Cancel.
fn cancel(future) {
    perform Async.Cancel { future: future }
}

// Spawn a task in a scope
/// Spawn thunk as a child of a scope (using the scope's token) and register its future with the scope.
fn spawn-in-scope(scope, thunk) {
    let future = async-with-token(scope.token, thunk)
    scope-add-child!(scope, future)
    future
}

// ============================================================================
// Timeout Wrappers
// ============================================================================

// Run a thunk with a timeout (in milliseconds), truly interrupting it.
/// Run `thunk` as a cooperative sub-computation bounded by `ms` milliseconds.
/// Returns `TimeoutResult.Ok { value }` if it finishes in time, or
/// `TimeoutResult.TimedOut {}` if not — in which case the sub-computation is
/// FORCE-CANCELLED: whatever async op it was parked on (a socket read, a sleep,
/// a child task) is cleaned up and its continuation discarded. If `thunk` itself
/// throws, the error propagates out of with-timeout. Single-threaded cooperative:
/// a tight CPU loop that never parks can't be interrupted (it blocks the thread).
fn with-timeout(ms, thunk) {
    let token = make-cancellation-token()
    let future = perform Async.SpawnWithToken { thunk: thunk, token: token }
    let outcome = perform Async.AwaitWithTimeout { future: future, token: token, ms: ms }
    // `outcome` is TimedOut (timer won), AwaitRejected/AwaitCancelled (the thunk
    // threw / was cancelled), or the thunk's plain return value (it finished).
    match outcome {
        TimeoutResult.TimedOut {} => outcome,
        AwaitRejected { error } => throw(error),
        AwaitCancelled {} => { TimeoutResult.TimedOut {} },
        _ => { TimeoutResult.Ok { value: outcome } }
    }
}

/// True if a with-timeout result is the TimedOut case.
fn timed-out?(result) {
    match result {
        TimeoutResult.TimedOut {} => true,
        _ => false
    }
}

/// Run `thunk` bounded by `ms` milliseconds, returning its value or THROWING
/// `Error.Timeout` if it timed out (the sub-computation is force-cancelled).
/// Convenient when you want the timeout to propagate via try/catch rather than a
/// TimeoutResult — e.g. so it folds into a Result-returning client.
fn with-timeout!(ms, thunk) {
    let outcome = with-timeout(ms, thunk)
    match outcome {
        TimeoutResult.Ok { value } => value,
        TimeoutResult.TimedOut {} => {
            let timeout-error = Error.Timeout { operation: "with-timeout" }
            throw(timeout-error)
        }
    }
}

/// The value from a with-timeout result that finished in time, or null if it
/// timed out. (Use with-timeout's match for the full Ok/TimedOut distinction.)
fn timeout-value(result) {
    match result {
        TimeoutResult.Ok { value } => value,
        _ => null
    }
}

// Run an async operation with a timeout
/// Spawn thunk with a fresh cancellation token and await it up to ms milliseconds, cancelling and returning TimedOut on timeout, else Ok with the value.
fn async-with-timeout(ms, thunk) {
    let token = make-cancellation-token()
    let result_future = async-with-token(token, thunk)

    let outcome = await-timeout(ms, result_future)
    match outcome {
        TimeoutResult.TimedOut {} => {
            cancel!(token)
            TimeoutResult.TimedOut {}
        },
        TimeoutResult.Ok { value } => {
            TimeoutResult.Ok { value: value }
        }
    }
}

// Create an async sleep - returns a future that resolves after ms milliseconds
/// Return a future that resolves to null after ms milliseconds (spawns a task that sleeps).
fn async-sleep(ms) {
    spawn(fn() {
        sleep(ms)
        null
    })
}

// Shorthand for awaiting a sleep
/// Sleep for ms milliseconds by spawning and awaiting an async sleep.
fn await-sleep(ms) {
    await(async-sleep(ms))
}

// Get current time in nanoseconds
/// Return the current time in nanoseconds (thin wrapper over core/time-now).
fn time-now() {
    core/time-now()
}

/// Spawn a cooperative task and return a future.
///
/// The task runs concurrently with the caller — but on the SAME thread, via
/// the cooperative scheduler. It makes progress whenever the caller (or any
/// other task) parks on an async op. `spawn` never starts an OS thread; use
/// `thread()` for real parallelism. `await` the future to get the result.
///
/// Examples:
///   let f = spawn(fn() { compute() })
///   await(f)  // => result of compute()
fn spawn(thunk) {
    perform Async.Spawn { thunk: thunk }
}

// Lowering target for the `future(expr)` special form: the compiler rewrites
// `future(expr)` into `__make_future(fn() { expr })`, so this just spawns the
// deferred expression as a cooperative task and returns its future. Lets users
// write `future(http/get(url))` instead of `spawn(fn() { http/get(url) })`.
/// Spawn a deferred-expression thunk as a cooperative task and return its future. (Lowering target for `future(expr)`.)
fn __make_future(thunk) {
    spawn(thunk)
}

// ============================================================================
// Convenience Functions
// ============================================================================

// Read file and unwrap the result
/// Read a file and unwrap the Result, throwing on error. Returns the contents string.
fn read-file!(path) {
    async-unwrap(read-file(path))
}

// Write file and unwrap the result
/// Write a file and unwrap the Result, throwing on error.
fn write-file!(path, content) {
    async-unwrap(write-file(path, content))
}

// Check if operation was successful
/// Return true if a Result is Ok (alias for async-ok?).
fn ok?(result) {
    async-ok?(result)
}

// Unwrap result or return default
/// Return the Ok value of a Result, or default on error (alias for async-unwrap-or).
fn unwrap-or(result, default) {
    async-unwrap-or(result, default)
}

// Create the default async handler
/// Create the default async handler instance (a BlockingAsyncHandler).
fn default-handler() {
    BlockingAsyncHandler {}
}

// Run a block with the default blocking handler
/// Run thunk with the BlockingAsyncHandler installed for the Async effect.
fn run-blocking(thunk) {
    let handler = BlockingAsyncHandler {}
    handle effect/Handler(Async) with handler {
        thunk()
    }
}

