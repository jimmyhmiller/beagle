// TODO: This is hack because 0 is making the fast path cache activate
// fix by changing id or filling the cache
/// Internal sentinel struct (workaround for id 0 activating the fast-path cache).
struct NEVER {}

/// Runtime descriptor for a struct type: its name and numeric id.
struct Struct {
    name
    id
}

extend Struct with Format {
    /// Format a Struct descriptor as its name.
    fn format(self, depth) {
        self.name
    }
}

// Type descriptors for primitive types
// These are Struct instances that describe each built-in type
// Negative IDs distinguish primitives from custom structs (which have positive IDs)
let Array = Struct {
    name: "Array",
    id: -1
}

let String = Struct {
    name: "String",
    id: -2
}

let Int = Struct {
    name: "Int",
    id: -3
}

let Float = Struct {
    name: "Float",
    id: -4
}

let Bool = Struct {
    name: "Bool",
    id: -5
}

let Null = Struct {
    name: "Null",
    id: -6
}

let Function = Struct {
    name: "Function",
    id: -7
}

let Closure = Struct {
    name: "Closure",
    id: -8
}

let Keyword = Struct {
    name: "Keyword",
    id: -9
}

// Persistent collection types (Rust-backed HAMT implementations)
// These use negative IDs that map to the runtime type IDs
// (negative ID gets converted to primitive_dispatch index)
let PersistentVector = Struct {
    name: "PersistentVector",
    id: -20
}

let PersistentMap = Struct {
    name: "PersistentMap",
    id: -22
}

let PersistentSet = Struct {
    name: "PersistentSet",
    id: -28
}

let MultiArityFunction = Struct {
    name: "MultiArityFunction",
    id: -29
}

let Regex = Struct {
    name: "Regex",
    id: -30
}

// ============================================================================
// Math Constants
// ============================================================================

let PI = 3.141592653589793
let E = 2.718281828459045
let TAU = 6.283185307179586

// ============================================================================
// Protocol Definitions
// ============================================================================

/// Runtime descriptor for a protocol, identified by name.
struct Protocol {
    name
}

protocol Indexed {
    fn get {
        (coll, index)
        (coll, index, default) => {
            let result = get(coll, index)
            if result == null {
                default
            } else {
                result
            }
        }
    }
}

protocol Push {
    fn push(coll, value)
}

// Polymorphic "add one element", dispatching on the collection's type:
//   - PersistentVector => append to the tail
//   - PersistentSet    => add the element
//   - PersistentMap    => conjoin a [key, value] pair
//   - any container extending Conj (Deque, ...) => its natural add
// `into(to, from)` is defined as `reduce(conj, to, from)`.
protocol Conj {
    fn conj(coll, value)
}

// Total ordering for value types. A type implements `compare-to(self, other)`
// returning -1/0/1; the public `compare(a, b)` (below) dispatches here for heap
// value types (BigInt, SemVer, DateTime, user types) and uses </> directly for
// primitives. `sort`/`min-of`/`max-of` route through `compare`.
protocol Comparable {
    fn compare-to(self, other)
}

// Resources that hold an OS handle (files, sockets, streams, ...) implement
// `close(self)` to release it. `with-open` (below) uses this to guarantee the
// resource is closed on every exit path, including a thrown exception.
protocol Closeable {
    fn close(self)
}

protocol Length {
    fn length(coll)
}

protocol Format {
    fn format(self, depth) {
        // Default leaf: raw representation. Must NOT call to-string, which now
        // routes back through format (that would infinite-loop).
        __raw-repr(self)
    }
}

/// Convert any value to its display string. Routes through the `Format` protocol,
/// so a type's `extend T with Format` impl is honored — `to-string(x)`, `${x}`
/// interpolation, and `println(x)` all produce the SAME output. Equivalent to
/// `format(x, 0)`.
///
/// Examples:
///   to-string(42)     // => "42"
///   to-string([1, 2])  // => "[1, 2]"
fn to-string(x) {
    format(x, 0)
}

protocol Associable {
    fn assoc(coll, key, value)
}

protocol Keys {
    fn keys(coll)
}

protocol Seqable {
    fn seq(coll)
}

protocol Seq {
    fn first(seq)
    fn next(seq)
}

// Polymorphic membership test, dispatching on the first argument's type.
// Like Clojure's `contains?`, this asks whether a KEY/INDEX/element is present,
// not whether a value is contained:
//   - String          => substring test (Beagle's historical behavior)
//   - PersistentMap    => is the key present (true even if its value is null)
//   - PersistentSet    => is the element a member
//   - PersistentVector => is the index in range
protocol Contains {
    fn contains?(coll, x)
}

extend String with Format {
    /// Format a string; quote it when nested (depth > 0).
    fn format(self, depth) {
        if depth > 0 {
            "\"" ++ self ++ "\""
        } else {
            self
        }
    }
}

extend String with Contains {
    /// Test whether substr occurs within s.
    fn contains?(s, substr) {
        string-contains?(s, substr)
    }
}

// ============================================================================
// Rust PersistentVector Protocol Implementations
// ============================================================================

extend PersistentVector with Indexed {
    // Explicit 3-arg form: the protocol's default 3-arg does not route through
    // primitive-type dispatch, so each primitive Indexed type defines its own.
    /// Get the element at index, or default (2-arg form returns null when out of range).
    fn get {
        (vec, index) => rust-coll/vec-get(vec, index)
        (vec, index, default) => if index >= 0 && index < rust-coll/vec-count(vec) {
            rust-coll/vec-get(vec, index)
        } else {
            default
        }
    }
}

// Like Clojure, contains? on a vector tests whether an INDEX is in range,
// not whether a value is present.
extend PersistentVector with Contains {
    /// Test whether index is a valid in-range index of vec.
    fn contains?(vec, index) {
        index >= 0 && index < rust-coll/vec-count(vec)
    }
}

extend PersistentSet with Contains {
    /// Test whether element is a member of set.
    fn contains?(set, element) {
        rust-coll/set-contains?(set, element)
    }
}

extend PersistentVector with Length {
    /// Return the number of elements in vec.
    fn length(vec) {
        rust-coll/vec-count(vec)
    }
}

extend PersistentVector with Push {
    /// Return a new vector with value appended.
    fn push(vec, value) {
        rust-coll/vec-push(vec, value)
    }
}

extend PersistentVector with Format {
    /// Format vec as a bracketed, comma-separated list.
    fn format(vec, depth) {
        let len = rust-coll/vec-count(vec)
        format-rust-vec-helper(vec, 0, len, "[")
    }
}

/// Helper: recursively format a Rust-backed vector's elements into acc.
fn format-rust-vec-helper(vec, idx, len, acc) {
    if idx >= len {
        acc ++ "]"
    } else {
        let elem = rust-coll/vec-get(vec, idx)
        let elem-str = format(elem, 1)
        let new-acc = if idx == 0 {
            acc ++ elem-str
        } else {
            acc ++ ", " ++ elem-str
        }
        format-rust-vec-helper(vec, idx + 1, len, new-acc)
    }
}

extend PersistentVector with Associable {
    /// Return a new vector with value at index.
    fn assoc(vec, index, value) {
        rust-coll/vec-assoc(vec, index, value)
    }
}

// ============================================================================
// Rust PersistentMap Protocol Implementations
// ============================================================================

extend PersistentMap with Indexed {
    /// Look up key in the map; the 3-arg form returns default for a missing key.
    fn get {
        (map, key) => rust-coll/map-get(map, key)
        // 3-arg form must distinguish a stored null from a missing key, so it
        // routes to map-get-default instead of the protocol's null-comparing
        // default (which cannot tell the two apart).
        (map, key, default) => rust-coll/map-get-default(map, key, default)
    }
}

extend PersistentMap with Contains {
    /// Test whether key is present in the map (even if its value is null).
    fn contains?(map, key) {
        rust-coll/map-contains?(map, key)
    }
}

extend PersistentMap with Length {
    /// Return the number of entries in the map.
    fn length(map) {
        rust-coll/map-count(map)
    }
}

extend PersistentMap with Associable {
    /// Return a new map with key mapped to value.
    fn assoc(map, key, value) {
        rust-coll/map-assoc(map, key, value)
    }
}

extend PersistentMap with Keys {
    /// Return a vector of the map's keys.
    fn keys(map) {
        rust-coll/map-keys(map)
    }
}

extend PersistentMap with Format {
    /// Format the map as brace-enclosed key/value pairs.
    fn format(map, depth) {
        let ks = rust-coll/map-keys(map)
        let len = rust-coll/vec-count(ks)
        if len == 0 {
            "{}"
        } else {
            format-rust-map-entries(map, ks, 0, len, "{")
        }
    }
}

extend PersistentVector with Conj {
    /// Conjoin onto a vector: append to the tail.
    fn conj(vec, value) { rust-coll/vec-push(vec, value) }
}

extend PersistentSet with Conj {
    /// Conjoin onto a set: add the element (no-op if already present).
    fn conj(set, value) { rust-coll/set-add(set, value) }
}

extend PersistentMap with Conj {
    /// Conjoin a [key, value] pair onto a map.
    fn conj(map, kv) { rust-coll/map-assoc(map, rust-coll/vec-get(kv, 0), rust-coll/vec-get(kv, 1)) }
}

/// Helper: recursively format a Rust-backed map's key/value entries into acc.
fn format-rust-map-entries(map, keys-vec, idx, len, acc) {
    if idx >= len {
        acc ++ "}"
    } else {
        let key = rust-coll/vec-get(keys-vec, idx)
        let val = rust-coll/map-get(map, key)
        let key-str = format(key, 1)
        let val-str = format(val, 1)
        let entry = key-str ++ " " ++ val-str
        let new-acc = if idx == 0 {
            acc ++ entry
        } else {
            acc ++ ", " ++ entry
        }
        format-rust-map-entries(map, keys-vec, idx + 1, len, new-acc)
    }
}

// This may seem weird
// but we need our runtime to know
// how to call a function if it is a closure
// or a regular function
// this makes that idea simple
fn __call_fn(f) { f() }

// The reset/shift delimited-continuation boundary. `reset { body }`
// compiles to `__reset__(body_thunk)`. Its sole purpose is to leave a
// recognizable frame on the stack: capture_continuation and
// return_from_shift walk the FP chain looking for a frame whose PC
// lies inside this function's code range, and that frame IS the
// prompt. All prompt metadata (return SP/FP/return-address) is read
// from this frame at walk time — nothing is snapshotted in a side
// table. Keep the body identical in shape to __call_fn but distinct
// so the two compile to separate addresses.
fn __reset__(thunk) { thunk() }

// Thread struct - holds the closure to be executed and serves as a GC root
// for running threads. The Thread object keeps the closure alive while the
// thread is running.
/// Holds a thread's closure and acts as a GC root while the thread runs.
struct Thread {
    closure
}

// Called by the runtime to start a thread. This function takes no arguments
// and reads the Thread object via a builtin. This ensures GC can properly
// update the stack slot containing the Thread object.
fn __run_thread_start() {
    let thread-obj = primitive/__get-my-thread-obj();
    let f = thread-obj.closure;
    try {
        f()
    } catch (e) {
        println("Uncaught exception in thread:")
        println(e)
        null
    }
}

// Legacy function - kept for compatibility but no longer used.
fn __run_thread_closure(thread-obj) {
    let f = thread-obj.closure;
    f()
}

/// Thread-safe mutable reference cell holding a single value.
struct Atom {
    value
}

/// Dereference an atom to get its current value.
///
/// Atoms provide thread-safe mutable state. Use `deref` to read the value.
///
/// Examples:
///   let a = atom(0)
///   deref(a)  // => 0
fn deref(atom) {
    // Guard: the primitive untags + reads the value slot, so a non-object
    // (Int/null/...) would dereference a raw value and segfault.
    if primitive/is-object(atom) {
        primitive/deref(atom)
    } else {
        throw("deref expects an atom but got: ${atom}")
    }
}

/// Atomically update an atom's value by applying a function.
///
/// Takes the current value, applies f to it, and attempts to set the new value.
/// Retries if another thread changed the value concurrently.
///
/// Examples:
///   let counter = atom(0)
///   swap!(counter, fn(x) { x + 1 })  // => 1
fn swap!(atom, f) {
    let initial = deref(atom);
    let new = f(initial);
    let result = compare-and-swap!(atom, initial, new);
    if result {
        new
    } else {
        swap!(atom, f)
    }
}

/// Reset an atom to a new value unconditionally.
///
/// Unlike `swap!`, this does not read the current value first.
///
/// Examples:
///   let a = atom(0)
///   reset!(a, 42)
///   deref(a)  // => 42
fn reset!(atom, value) {
    if primitive/is-object(atom) {
        primitive/reset!(atom, value)
    } else {
        throw("reset! expects an atom but got: ${atom}")
    }
}

/// Atomically compare and swap an atom's value.
///
/// If the atom's current value equals `old`, set it to `new` and return true.
/// Otherwise return false without changing the value.
///
/// Examples:
///   let a = atom(0)
///   compare-and-swap!(a, 0, 1)  // => true, a is now 1
///   compare-and-swap!(a, 0, 2)  // => false, a is still 1
fn compare-and-swap!(atom, old, new) {
    if primitive/is-object(atom) {
        primitive/compare-and-swap!(atom, old, new)
    } else {
        throw("compare-and-swap! expects an atom but got: ${atom}")
    }
}

/// Create a new atom with the given initial value.
///
/// Atoms provide thread-safe mutable state.
///
/// Examples:
///   let counter = atom(0)
///   swap!(counter, fn(x) { x + 1 })
///   deref(counter)  // => 1
fn atom(value) {
    // TODO: Allow punning
    Atom { value: value }
}

// TODO: If I move the || on the next line,
// my parser is unhappy
// TODO: Need to make sure type is instance-of Struct
// but how do I do that in a reasonable way?
/// Test whether a value is an instance of the given type descriptor.
/// Handles both primitive types (negative id) and custom structs (by struct-id).
fn instance-of(value, type) {
    if type.id < 0 {
        // Primitive type - use type-of equality
        equal(type-of(value), type)
    } else {
        // Custom struct - check struct-id
        primitive/is-object(value) && primitive/read-struct-id(value) == type.id
    }
}

/// True if `value` is an instance of a user-defined struct (e.g. a record, or a
/// value type like BigInt/SemVer/DateTime). False for every built-in type —
/// numbers, strings, keywords, booleans, vectors, maps, sets, functions, null.
///
/// Built-in types are assigned negative type ids; user structs get non-negative
/// ones, which is exactly this test. Used by `compare`/`sort` to decide between
/// the native `<` ordering and the `Comparable` protocol.
fn struct?(value) {
    type-of(value).id >= 0
}


extend String with Indexed {
    /// Get the character at index i, or default when out of range.
    fn get {
        (str, i) => builtin/get-string-index(str, i)
        (str, i, default) => if i >= 0 && i < builtin/get-string-length(str) {
            builtin/get-string-index(str, i)
        } else {
            default
        }
    }
}

extend String with Length {
    /// Return the number of characters in str.
    fn length(str) {
        builtin/get-string-length(str)
    }
}

// Array protocol extensions for variadic function arguments
// Arrays are raw mutable arrays with type-id = 1
extend Array with Indexed {
    /// Get the element at index i, returning null/default when out of range.
    fn get {
        (arr, i) => if i < 0 || i >= primitive/size(arr) {
            null
        } else {
            primitive/read-field(arr, i)
        }
        (arr, i, default) => if i < 0 || i >= primitive/size(arr) {
            default
        } else {
            primitive/read-field(arr, i)
        }
    }
}

extend Array with Length {
    /// Return the number of elements in arr.
    fn length(arr) {
        primitive/size(arr)
    }
}

extend Array with Seqable {
    /// Return an ArraySeq over arr, or null if empty.
    fn seq(arr) {
        if primitive/size(arr) == 0 {
            null
        } else {
            ArraySeq { arr: arr, index: 0 }
        }
    }
}

/// Seq view over a raw Array, tracking the current index.
struct ArraySeq {
    arr
    index
}

extend ArraySeq with Seq {
    /// Return the element at the seq's current index.
    fn first(seq) {
        primitive/read-field(seq.arr, seq.index)
    }

    /// Advance to the next element, or null at the end.
    fn next(seq) {
        let next-index = seq.index + 1
        if next-index >= primitive/size(seq.arr) {
            null
        } else {
            ArraySeq { arr: seq.arr, index: next-index }
        }
    }
}

// seq is idempotent: a live seq object is itself Seqable (it always points at a
// valid element — empty is represented as null). Without this, passing the
// result of seq(...) (or any function that already returned a seq) back into a
// seq-driven function like reduce/map/stats crashes with "Function not
// implemented for Struct value: ...Seq".
extend ArraySeq with Seqable {
    /// A live seq is its own seq (idempotent).
    fn seq(s) { s }
}

extend ArraySeq with Length {
    /// Return the number of elements remaining in the seq.
    fn length(s) { primitive/size(s.arr) - s.index }
}

// PersistentVector protocol extensions (Rust-backed vector from literals)
extend PersistentVector with Length {
    /// Return the number of elements in vec.
    fn length(vec) {
        rust-coll/vec-count(vec)
    }
}

extend PersistentVector with Indexed {
    /// Get the element at index i, or default when out of range.
    fn get {
        (vec, i) => rust-coll/vec-get(vec, i)
        (vec, i, default) => if i >= 0 && i < rust-coll/vec-count(vec) {
            rust-coll/vec-get(vec, i)
        } else {
            default
        }
    }
}

extend PersistentVector with Push {
    /// Return a new vector with value appended.
    fn push(vec, value) {
        rust-coll/vec-push(vec, value)
    }
}

extend PersistentVector with Seqable {
    /// Return a PersistentVectorSeq over vec, or null if empty.
    fn seq(vec) {
        if rust-coll/vec-count(vec) == 0 {
            null
        } else {
            PersistentVectorSeq { vec: vec, index: 0 }
        }
    }
}

// PersistentMap protocol extensions (Rust-backed map from literals)
extend PersistentMap with Length {
    /// Return the number of entries in the map.
    fn length(m) {
        rust-coll/map-count(m)
    }
}

extend PersistentMap with Indexed {
    /// Look up key; the 3-arg form returns default for a missing key.
    fn get {
        (m, key) => rust-coll/map-get(m, key)
        (m, key, default) => rust-coll/map-get-default(m, key, default)
    }
}

extend PersistentMap with Associable {
    /// Return a new map with key mapped to value.
    fn assoc(m, key, value) {
        rust-coll/map-assoc(m, key, value)
    }
}

// Sequence type for iterating over PersistentVector
/// Seq view over a PersistentVector, tracking the current index.
struct PersistentVectorSeq {
    vec
    index
}

extend PersistentVectorSeq with Seq {
    /// Return the element at the seq's current index.
    fn first(seq) {
        rust-coll/vec-get(seq.vec, seq.index)
    }

    /// Advance to the next element, or null at the end.
    fn next(seq) {
        let next-index = seq.index + 1
        if next-index >= rust-coll/vec-count(seq.vec) {
            null
        } else {
            PersistentVectorSeq { vec: seq.vec, index: next-index }
        }
    }
}

extend PersistentVectorSeq with Seqable {
    /// A live seq is its own seq (idempotent).
    fn seq(s) { s }
}

extend PersistentVectorSeq with Length {
    /// Return the number of elements remaining in the seq.
    fn length(s) { rust-coll/vec-count(s.vec) - s.index }
}

// Helper for formatting PersistentVector
/// Helper: recursively format a PersistentVector's elements into acc.
fn format-persistent-vector-helper(vec, idx, acc, depth) {
    if idx >= rust-coll/vec-count(vec) {
        acc
    } else {
        let elem = rust-coll/vec-get(vec, idx)
        let elem-str = format(elem, depth + 1)
        let new-acc = if idx == 0 {
            acc ++ elem-str
        } else {
            acc ++ ", " ++ elem-str
        }
        format-persistent-vector-helper(vec, idx + 1, new-acc, depth)
    }
}

extend PersistentVector with Format {
    /// Format vec as a bracketed, comma-separated list.
    fn format(self, depth) {
        "[" ++ format-persistent-vector-helper(self, 0, "", depth) ++ "]"
    }
}

// ============================================================================
// String Operations (Protocol-based)
// ============================================================================

/// Join elements of a collection into a string with a separator.
///
/// Works with any collection that implements Indexed and Length protocols.
///
/// Examples:
///   join([1, 2, 3], ", ")  // => "1, 2, 3"
///   join(["a", "b"], "-") // => "a-b"
fn join(coll, sep) {
    join-helper(coll, sep, 0, "")
}

/// Helper: recursively join a collection's elements into acc, separated by sep.
fn join-helper(coll, sep, idx, acc) {
    let len = length(coll)
    if idx >= len {
        acc
    } else {
        let elem = get(coll, idx)
        let elem-str = to-string(elem)
        let new-acc = if idx == 0 {
            acc ++ elem-str
        } else {
            acc ++ sep ++ elem-str
        }
        join-helper(coll, sep, idx + 1, new-acc)
    }
}

/// Parse a string into an integer.
///
/// Returns null if the string is not a valid integer.
/// Supports negative numbers with leading '-'.
///
/// Examples:
///   parse-int("42")   // => 42
///   parse-int("-5")   // => -5
///   parse-int("abc")  // => null
fn parse-int(s) {
    let len = length(s)
    if len == 0 {
        null
    } else {
        // Check for negative sign
        let first-char = get(s, 0)
        let first-code = builtin/char-code(first-char)
        if first-code == 45 {
            // '-' sign
            if len == 1 {
                null
            } else {
                let result = parse-int-helper(s, 1, 0)
                if result == null {
                    null
                } else {
                    0 - result
                }
            }
        } else {
            parse-int-helper(s, 0, 0)
        }
    }
}

/// Helper: accumulate digits of s from idx into acc; null on a non-digit or overflow.
fn parse-int-helper(s, idx, acc) {
    if idx >= length(s) {
        acc
    } else {
        let c = get(s, idx)
        let code = builtin/char-code(c)
        // '0' is 48, '9' is 57
        if code >= 48 && code <= 57 {
            let digit = code - 48
            // Overflow guard: tagged Ints are 61-bit (max 1152921504606846975).
            // Past that, `acc * 10 + digit` silently wraps to a wrong (often
            // negative) value. Return null (parse-int's documented failure
            // signal) instead — use beagle.bigint for arbitrary precision.
            if acc > (1152921504606846975 - digit) / 10 {
                null
            } else {
                parse-int-helper(s, idx + 1, acc * 10 + digit)
            }
        } else {
            null
        }
    }
}

