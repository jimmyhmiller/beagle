// ============================================================================
// Writer Protocol for Stdout Rebinding
// ============================================================================

// Writer protocol - anything that can receive output
protocol Writer {
    fn write(self, s)
}

// Default stdout writer struct
/// Default Writer that sends output to standard out.
struct Stdout {}

// Stdout implementation - calls builtin printer directly
extend Stdout with Writer {
    /// Write s directly to standard out.
    fn write(self, s) {
        _print(s)
        null
    }
}

// StringBuffer - mutable accumulator for captured output
// With cons strings, each write() is O(1) concatenation.
/// Mutable Writer that accumulates written output into a string.
struct StringBuffer {
    mut content
}

// Factory function to create a new StringBuffer
/// Create a new empty StringBuffer.
fn new-string-buffer() {
    StringBuffer {
        content: ""
    }
}

// StringBuffer implementation - concatenates to content string
extend StringBuffer with Writer {
    /// Append s to the buffer's accumulated content.
    fn write(self, s) {
        self.content = self.content ++ s
        null
    }
}

// Define *out* dynamic var, default to stdout
let dynamic out = Stdout {}

// ============================================================================

/// Print arguments separated by spaces without a trailing newline.
///
/// Accepts any number of arguments. Each is formatted and printed.
/// Returns the last argument.
///
/// Examples:
///   print("Hello", "World")  // prints: Hello World
fn print(...args) {
    let len = length(args)
    if len == 0 {
        null
    } else {
        let mut last = null
        let mut i = 0
        while i < len {
            if i > 0 {
                write(out, " ")
            }
            last = get(args, i)
            write(out, format(last, 0))
            i = i + 1
        }
        last
    }
}

/// Print arguments separated by spaces with a trailing newline.
///
/// Accepts any number of arguments. Each is formatted and printed.
/// Returns the last argument.
///
/// Examples:
///   println("Hello", "World")  // prints: Hello World\n
///   println(1, 2, 3)            // prints: 1 2 3\n
fn println(...args) {
    let len = length(args)
    if len == 0 {
        write(out, "\n")
        null
    } else {
        let mut last = null
        let mut i = 0
        while i < len {
            if i > 0 {
                write(out, " ")
            }
            last = get(args, i)
            write(out, format(last, 0))
            i = i + 1
        }
        write(out, "\n")
        last
    }
}

/// Check if a value is a keyword.
///
/// Examples:
///   keyword?(:foo)  // => true
///   keyword?("foo") // => false
fn keyword?(value) {
    builtin/is-keyword(value)
}

/// Convert a keyword to a string.
///
/// Examples:
///   keyword->string(:foo)  // => "foo"
fn keyword->string(kw) {
    builtin/keyword-to-string(kw)
}

/// Convert a string to a keyword.
///
/// Examples:
///   string->keyword("foo")  // => :foo
fn string->keyword(str) {
    builtin/string-to-keyword(str)
}


struct __Box__ {
    value
}

// System error enum for exception handling
/// Built-in error variants raised by the runtime; each carries a message and location.
enum SystemError {
    StructError { message, location }
    ParseError { message, location }
    CompileError { message, location }
    TypeError { message, location }
    ArityError { message, location }
    RuntimeError { message, location }
    ThreadError { message, location }
    FFIError { message, location }
    FunctionError { message, location }
    FieldError { message, location }
    IndexError { message, location }
    MutabilityError { message, location }
    JsonError { message, location }
    AssertError { message, location }
    IOError { message, location }
    // Variants below are thrown by various Rust builtins (char-from-code,
    // string/regex/ffi/json paths, allocation failure). They MUST exist here or
    // create_error() unwraps None and panic-aborts the process uncatchably
    // instead of raising a catchable Beagle exception.
    AllocationError { message, location }
    ArgumentError { message, location }
    InvalidArgument { message, location }
    StringError { message, location }
    RegexError { message, location }
    EncodingError { message, location }
    CopyError { message, location }
}

// Diagnostic severity levels
/// Severity levels for compiler diagnostics: error, warning, info, hint.
enum DiagnosticSeverity {
    error,
    warning,
    info,
    hint,
}

// Diagnostic information for programmatic inspection
// Returned by (diagnostics), (diagnostics-for-file path), etc.
/// A compiler diagnostic (severity, kind, location, message) for programmatic inspection.
struct Diagnostic {
    severity         // DiagnosticSeverity enum variant
    kind             // String: diagnostic type identifier (e.g., "NonExhaustiveMatch")
    file-name        // String: source file path
    line             // Int: 1-based line number
    column           // Int: 1-based column number
    message          // String: human-readable description
    enum-name        // String or null: for NonExhaustiveMatch diagnostics
    missing-variants // [String] or null: for NonExhaustiveMatch diagnostics
}

// Range type for iteration
/// Lazy numeric range with current value, exclusive end, and step.
struct Range {
    current
    end
    step
}

/// Create a range from start (inclusive) to end (exclusive).
///
/// Ranges are iterable and can be used with for loops and seq functions.
///
/// Examples:
///   for i in range(0, 5) { println(i) }  // prints 0, 1, 2, 3, 4
///   reduce(fn(a, x) { a + x }, 0, range(1, 5))  // => 10
fn range(start, end) {
    Range { current: start, end: end, step: 1 }
}

/// Create a range with a custom step value.
///
/// Examples:
///   range-step(0, 10, 2)  // => 0, 2, 4, 6, 8
fn range-step(start, end, step) {
    Range { current: start, end: end, step: step }
}

extend Range with Seqable {
    /// Return the range as a seq, or null if exhausted.
    fn seq(r) {
        if r.current >= r.end {
            null
        } else {
            r
        }
    }
}

extend Range with Seq {
    /// Return the range's current value.
    fn first(r) {
        r.current
    }

    /// Advance by step, or null once at or past the end.
    fn next(r) {
        let next-val = r.current + r.step
        if next-val >= r.end {
            null
        } else {
            Range { current: next-val, end: r.end, step: r.step }
        }
    }
}

extend Range with Length {
    /// The number of elements the range will yield (so count/empty? work on it).
    fn length(r) {
        if r.step <= 0 {
            0
        } else {
            let span = r.end - r.current
            if span <= 0 {
                0
            } else {
                // ceil(span / step)
                (span + r.step - 1) / r.step
            }
        }
    }
}

// String sequence for iteration
/// Seq view over a String's characters, tracking the current index.
struct StringSeq {
    str
    index
}

extend String with Seqable {
    /// Return a StringSeq over str's characters, or null if empty.
    fn seq(str) {
        if length(str) == 0 {
            null
        } else {
            StringSeq { str: str, index: 0 }
        }
    }
}

extend StringSeq with Seq {
    /// Return the character at the seq's current index.
    fn first(seq) {
        get(seq.str, seq.index)
    }

    /// Advance to the next character, or null at the end.
    fn next(seq) {
        let next-index = seq.index + 1
        if next-index >= length(seq.str) {
            null
        } else {
            StringSeq { str: seq.str, index: next-index }
        }
    }
}

extend StringSeq with Seqable {
    /// A live seq is its own seq (idempotent).
    fn seq(s) { s }
}

extend StringSeq with Length {
    /// Return the number of characters remaining in the seq.
    fn length(s) { length(s.str) - s.index }
}

// ============================================================================
// Higher-Order Collection Functions
// ============================================================================

/// Fold a collection with an accumulator function.
///
/// Calls (f acc elem) for each element, threading the accumulator through.
/// Works with any Seqable type.
///
/// Examples:
///   reduce(fn(acc, x) { acc + x }, 0, [1, 2, 3])  // => 6
///   reduce(fn(acc, x) { push(acc, x * 2) }, [], [1, 2, 3])  // => [2, 4, 6]
fn reduce(f, init, coll) {
    let mut s = seq(coll)
    let mut acc = init
    while s != null {
        let elem = first(s)
        acc = f(acc, elem)
        s = next(s)
    }
    acc
}

/// Apply a function to each element of a collection.
///
/// Returns a new vector with the transformed elements.
///
/// Examples:
///   map(fn(x) { x * 2 }, [1, 2, 3])  // => [2, 4, 6]
///   map(uppercase, ["a", "b"])      // => ["A", "B"]
fn map(f, coll) {
    let mut s = seq(coll)
    let mut acc = []
    while s != null {
        let elem = first(s)
        acc = push(acc, f(elem))
        s = next(s)
    }
    acc
}

/// Map `f`, which receives (index, element), over `coll`.
///
/// Examples:
///   map-indexed(fn(i, x) { [i, x] }, ["a", "b"])  // => [[0, "a"], [1, "b"]]
fn map-indexed(f, coll) {
    let mut s = seq(coll)
    let mut idx = 0
    let mut acc = []
    while s != null {
        acc = push(acc, f(idx, first(s)))
        s = next(s)
        idx = idx + 1
    }
    acc
}

/// Remove the elements for which `pred` is true — the complement of `filter`.
///
/// Examples:
///   remove(fn(x) { x > 2 }, [1, 2, 3, 4])  // => [1, 2]
fn remove(pred, coll) {
    filter(fn(x) { not(pred(x)) }, coll)
}

/// Map `f` over `coll`, keeping only the non-null results (map + drop-nulls).
///
/// Examples:
///   keep(fn(x) { if x > 2 { x * 10 } else { null } }, [1, 2, 3, 4])  // => [30, 40]
fn keep(f, coll) {
    let mut s = seq(coll)
    let mut acc = []
    while s != null {
        let r = f(first(s))
        if r != null {
            acc = push(acc, r)
        }
        s = next(s)
    }
    acc
}

/// Like `keep`, but `f` receives (index, element); keeps non-null results.
fn keep-indexed(f, coll) {
    let mut s = seq(coll)
    let mut idx = 0
    let mut acc = []
    while s != null {
        let r = f(idx, first(s))
        if r != null {
            acc = push(acc, r)
        }
        s = next(s)
        idx = idx + 1
    }
    acc
}

/// Split `coll` at index `n`: returns [take(n, coll), drop(n, coll)].
///
/// Examples:
///   split-at(2, [1, 2, 3, 4])  // => [[1, 2], [3, 4]]
fn split-at(n, coll) {
    [take(n, coll), drop(n, coll)]
}

/// Split `coll` at the first element failing `pred`:
/// returns [take-while(pred, coll), drop-while(pred, coll)].
///
/// Examples:
///   split-with(fn(x) { x < 3 }, [1, 2, 3, 4, 1])  // => [[1, 2], [3, 4, 1]]
fn split-with(pred, coll) {
    [take-while(pred, coll), drop-while(pred, coll)]
}

/// Keep elements where the predicate returns true.
///
/// Returns a new vector containing only matching elements.
///
/// Examples:
///   filter(even?, [1, 2, 3, 4])  // => [2, 4]
///   filter(fn(s) { length(s) > 0 }, ["", "a", ""])  // => ["a"]
fn filter(pred, coll) {
    let mut s = seq(coll)
    let mut acc = []
    while s != null {
        let elem = first(s)
        if pred(elem) {
            acc = push(acc, elem)
        }
        s = next(s)
    }
    acc
}

/// Check if any element matches the predicate.
///
/// Returns true if pred returns true for at least one element.
///
/// Examples:
///   any?(even?, [1, 2, 3])  // => true
///   any?(even?, [1, 3, 5])  // => false
fn any?(pred, coll) {
    let mut s = seq(coll)
    let mut found = false
    while s != null && found == false {
        if pred(first(s)) {
            found = true
        }
        s = next(s)
    }
    found
}

/// Check if all elements match the predicate.
///
/// Returns true if pred returns true for every element.
///
/// Examples:
///   all?(even?, [2, 4, 6])  // => true
///   all?(even?, [1, 2, 3])  // => false
fn all?(pred, coll) {
    let mut s = seq(coll)
    let mut all-match = true
    while s != null && all-match {
        if pred(first(s)) == false {
            all-match = false
        }
        s = next(s)
    }
    all-match
}

/// Check if no elements match the predicate.
///
/// Returns true if pred returns false for every element.
///
/// Examples:
///   none?(even?, [1, 3, 5])  // => true
///   none?(even?, [1, 2, 3])  // => false
fn none?(pred, coll) {
    let mut s = seq(coll)
    let mut none-match = true
    while s != null && none-match {
        if pred(first(s)) {
            none-match = false
        }
        s = next(s)
    }
    none-match
}

/// Check if at least one element does NOT match the predicate.
///
/// Equivalent to (not (all? coll pred)).
///
/// Examples:
///   not-every?(even?, [1, 2, 3])  // => true
///   not-every?(even?, [2, 4, 6])  // => false
fn not-every?(pred, coll) {
    not(all?(pred, coll))
}

/// Find the first element matching the predicate.
///
/// Returns the element or null if no match.
///
/// Examples:
///   find(even?, [1, 2, 3, 4])  // => 2
///   find(even?, [1, 3, 5])    // => null
fn find(pred, coll) {
    let mut s = seq(coll)
    let mut result = null
    let mut found = false
    while s != null && found == false {
        let elem = first(s)
        if pred(elem) {
            result = elem
            found = true
        }
        s = next(s)
    }
    result
}

/// Find the index of the first element matching the predicate.
///
/// Returns the index or -1 if no match.
///
/// Examples:
///   find-index(even?, [1, 2, 3, 4])  // => 1
///   find-index(even?, [1, 3, 5])    // => -1
fn find-index(pred, coll) {
    let mut s = seq(coll)
    let mut idx = 0
    let mut result = -1
    let mut found = false
    while s != null && found == false {
        if pred(first(s)) {
            result = idx
            found = true
        }
        s = next(s)
        idx = idx + 1
    }
    result
}

/// Take the first n elements from a collection.
///
/// Returns a new vector with at most n elements.
///
/// Examples:
///   take(3, [1, 2, 3, 4, 5])  // => [1, 2, 3]
///   take(5, [1, 2])        // => [1, 2]
fn take(n, coll) {
    let mut s = seq(coll)
    let mut remaining = n
    let mut acc = []
    while s != null && remaining > 0 {
        acc = push(acc, first(s))
        s = next(s)
        remaining = remaining - 1
    }
    acc
}

/// Drop the first n elements from a collection.
///
/// Returns a new vector with the remaining elements.
///
/// Examples:
///   drop(2, [1, 2, 3, 4, 5])  // => [3, 4, 5]
///   drop(5, [1, 2])        // => []
fn drop(n, coll) {
    let mut s = seq(coll)
    let mut remaining = n
    while s != null && remaining > 0 {
        s = next(s)
        remaining = remaining - 1
    }
    let mut acc = []
    while s != null {
        acc = push(acc, first(s))
        s = next(s)
    }
    acc
}

/// Take elements while the predicate returns true.
///
/// Stops at the first element where pred returns false.
///
/// Examples:
///   take-while(fn(x) { x < 4 }, [1, 2, 3, 4, 1])  // => [1, 2, 3]
fn take-while(pred, coll) {
    let mut s = seq(coll)
    let mut acc = []
    let mut taking = true
    while s != null && taking {
        let elem = first(s)
        if pred(elem) {
            acc = push(acc, elem)
            s = next(s)
        } else {
            taking = false
        }
    }
    acc
}

/// Drop elements while the predicate returns true.
///
/// Returns elements starting from the first where pred returns false.
///
/// Examples:
///   drop-while(fn(x) { x < 3 }, [1, 2, 3, 4, 1])  // => [3, 4, 1]
fn drop-while(pred, coll) {
    let mut s = seq(coll)
    while s != null && pred(first(s)) {
        s = next(s)
    }
    let mut acc = []
    while s != null {
        acc = push(acc, first(s))
        s = next(s)
    }
    acc
}

/// Get a sub-collection from start (inclusive) to end (exclusive).
///
/// Examples:
///   slice([0, 1, 2, 3, 4], 1, 4)  // => [1, 2, 3]
fn slice(coll, start, end) {
    take(end - start, drop(start, coll))
}

/// Return pairs of [index, element] for each element.
///
/// Examples:
///   enumerate(["a", "b", "c"])  // => [[0, "a"], [1, "b"], [2, "c"]]
fn enumerate(coll) {
    let mut s = seq(coll)
    let mut idx = 0
    let mut acc = []
    while s != null {
        acc = push(acc, [idx, first(s)])
        s = next(s)
        idx = idx + 1
    }
    acc
}

/// Remove element at the specified index.
///
/// Returns the collection unchanged if index is out of bounds.
///
/// Examples:
///   remove-at([1, 2, 3, 4], 1)  // => [1, 3, 4]
fn remove-at(coll, idx) {
    let len = length(coll)
    if idx < 0 || idx >= len {
        coll
    } else {
        concat(take(idx, coll), drop(idx + 1, coll))
    }
}

// ============================================================================
// Element Access Functions
// ============================================================================

/// Return the number of elements in a collection.
///
/// Alias for length, more idiomatic for collections.
///
/// Examples:
///   count([1, 2, 3])  // => 3
///   count("hello")  // => 5
fn count(coll) {
    length(coll)
}

/// Check if a collection has no elements.
///
/// Examples:
///   empty?([])    // => true
///   empty?([1])   // => false
///   empty?("")    // => true
fn empty?(coll) {
    length(coll) == 0
}

/// Get the first element of a collection.
///
/// Returns null if the collection is empty.
/// Named differently to avoid conflict with Seq protocol's first.
///
/// Examples:
///   first-of([1, 2, 3])  // => 1
///   first-of([])       // => null
fn first-of(coll) {
    let s = seq(coll)
    if s == null {
        null
    } else {
        first(s)
    }
}

/// Get the last element of a collection.
///
/// Returns null if the collection is empty.
///
/// Examples:
///   last([1, 2, 3])  // => 3
///   last([])       // => null
fn last(coll) {
    // O(1) for vectors (index the tail) instead of an O(n) seq walk that also
    // allocates a seq node per element.
    if instance-of(coll, PersistentVector) {
        let n = length(coll)
        if n == 0 { null } else { get(coll, n - 1) }
    } else {
        let mut s = seq(coll)
        let mut prev = null
        while s != null {
            prev = first(s)
            s = next(s)
        }
        prev
    }
}

/// Get all elements except the first.
///
/// Examples:
///   rest([1, 2, 3])  // => [2, 3]
///   rest([1])      // => []
fn rest(coll) {
    drop(1, coll)
}

/// Get all elements except the last one.
///
/// Examples:
///   butlast([1, 2, 3])  // => [1, 2]
///   butlast([1])      // => []
fn butlast(coll) {
    if instance-of(coll, PersistentVector) {
        // O(log32 n) native pop (empty for 0/1 elements), not an O(n) rebuild.
        rust-coll/vec-pop(coll)
    } else {
        let len = length(coll)
        if len <= 1 {
            []
        } else {
            take(len - 1, coll)
        }
    }
}

/// Get the element at index n with bounds checking.
///
/// Returns null if index is out of bounds.
///
/// Examples:
///   nth([1, 2, 3], 1)   // => 2
///   nth([1, 2, 3], 10)  // => null
fn nth(coll, n) {
    get(coll, n)
}

/// Get the second element of a collection.
///
/// Examples:
///   second([1, 2, 3])  // => 2
fn second(coll) {
    nth(coll, 1)
}

/// Get the third element of a collection.
///
/// Examples:
///   third([1, 2, 3])  // => 3
fn third(coll) {
    nth(coll, 2)
}

// ============================================================================
// Min/Max Functions
// ============================================================================

/// Three-way comparison: returns -1 if a < b, 0 if equal, 1 if a > b.
///
/// Works directly on primitives (numbers, strings, booleans) and on any heap
/// value type implementing the `Comparable` protocol (BigInt, SemVer, DateTime,
/// user types via `extend T with Comparable`). Mixed-type comparisons are
/// undefined. Backs `sort`/`sort-by`/`min-of`/`max-of`.
///
/// Examples:
///   compare(3, 5)      // => -1
///   compare("b", "a")  // => 1
fn compare(a, b) {
    // Value-type structs (BigInt/SemVer/DateTime/...) can't be ordered with `<`,
    // so they dispatch to their `Comparable` impl. Everything built-in — numbers,
    // strings (any representation), keywords, booleans — orders with `<` directly.
    if struct?(a) {
        compare-to(a, b)
    } else {
        if a < b {
            -1
        } else {
            if a > b {
                1
            } else {
                0
            }
        }
    }
}

/// Return the minimum element in a collection (by `compare`, so value types work).
///
/// Examples:
///   min-of([3, 1, 4, 1, 5])  // => 1
///   min-of([])           // => null
fn min-of(coll) {
    let mut s = seq(coll)
    if s == null {
        null
    } else {
        let mut min-val = first(s)
        s = next(s)
        while s != null {
            let elem = first(s)
            if compare(elem, min-val) < 0 {
                min-val = elem
            }
            s = next(s)
        }
        min-val
    }
}

/// Return the maximum element in a collection.
///
/// Elements must be comparable with >.
///
/// Examples:
///   max-of([3, 1, 4, 1, 5])  // => 5
///   max-of([])           // => null
fn max-of(coll) {
    let mut s = seq(coll)
    if s == null {
        null
    } else {
        let mut max-val = first(s)
        s = next(s)
        while s != null {
            let elem = first(s)
            if compare(elem, max-val) > 0 {
                max-val = elem
            }
            s = next(s)
        }
        max-val
    }
}

/// Return the element with the minimum key value.
///
/// Compares elements by applying f to each and using < on the results.
///
/// Examples:
///   min-by(length, ["abc", "a", "ab"])  // => "a"
fn min-by(f, coll) {
    let mut s = seq(coll)
    if s == null {
        null
    } else {
        let mut min-elem = first(s)
        let mut min-val = f(min-elem)
        s = next(s)
        while s != null {
            let elem = first(s)
            let val = f(elem)
            if compare(val, min-val) < 0 {
                min-elem = elem
                min-val = val
            }
            s = next(s)
        }
        min-elem
    }
}

/// Return the element with the maximum key value.
///
/// Compares elements by applying f to each and using > on the results.
///
/// Examples:
///   max-by(length, ["a", "abc", "ab"])  // => "abc"
fn max-by(f, coll) {
    let mut s = seq(coll)
    if s == null {
        null
    } else {
        let mut max-elem = first(s)
        let mut max-val = f(max-elem)
        s = next(s)
        while s != null {
            let elem = first(s)
            let val = f(elem)
            if compare(val, max-val) > 0 {
                max-elem = elem
                max-val = val
            }
            s = next(s)
        }
        max-elem
    }
}

/// Reduce a collection from right to left.
///
/// Like reduce, but processes elements in reverse order.
///
/// Examples:
///   reduce-right(fn(acc, x) { push(acc, x) }, [], [1, 2, 3])  // => [3, 2, 1]
fn reduce-right(f, init, coll) {
    // Convert to vector and iterate backwards
    let v = if instance-of(coll, PersistentVector) {
        coll
    } else {
        reduce(fn(acc, x) { push(acc, x) }, [], coll)
    }
    let len = length(v)
    let mut acc = init
    let mut i = len - 1
    while i >= 0 {
        acc = f(acc, get(v, i))
        i = i - 1
    }
    acc
}

// ============================================================================
// Combining Functions
// ============================================================================

/// Concatenate two collections into one.
///
/// Returns a new vector with elements from both collections.
///
/// Examples:
///   concat([1, 2], [3, 4])  // => [1, 2, 3, 4]
fn concat(coll1, coll2) {
    let mut acc = []
    let mut s = seq(coll1)
    while s != null {
        acc = push(acc, first(s))
        s = next(s)
    }
    s = seq(coll2)
    while s != null {
        acc = push(acc, first(s))
        s = next(s)
    }
    acc
}

/// Flatten one level of nesting in a collection.
///
/// Examples:
///   flatten([[1, 2], [3, 4]])  // => [1, 2, 3, 4]
fn flatten(coll) {
    let mut s = seq(coll)
    let mut acc = []
    while s != null {
        let elem = first(s)
        acc = reduce(fn(a, x) { push(a, x) }, acc, elem)
        s = next(s)
    }
    acc
}

/// Map a function over a collection then flatten the result.
///
/// Examples:
///   flat-map(fn(x) { [x, x] }, [1, 2, 3])  // => [1, 1, 2, 2, 3, 3]
fn flat-map(f, coll) {
    flatten(map(f, coll))
}

/// Pair up elements from two collections into a vector of pairs.
///
/// Examples:
///   zip([1, 2, 3], ["a", "b", "c"])  // => [[1, "a"], [2, "b"], [3, "c"]]
fn zip(coll1, coll2) {
    let mut s1 = seq(coll1)
    let mut s2 = seq(coll2)
    let mut acc = []
    while s1 != null && s2 != null {
        acc = push(acc, [first(s1), first(s2)])
        s1 = next(s1)
        s2 = next(s2)
    }
    acc
}

/// Combine elements from two collections using a function.
///
/// Like zip, but applies f to each pair instead of creating tuples.
///
/// Examples:
///   zip-with(fn(a, b) { a + b }, [1, 2, 3], [10, 20, 30])  // => [11, 22, 33]
fn zip-with(f, coll1, coll2) {
    let mut s1 = seq(coll1)
    let mut s2 = seq(coll2)
    let mut acc = []
    while s1 != null && s2 != null {
        acc = push(acc, f(first(s1), first(s2)))
        s1 = next(s1)
        s2 = next(s2)
    }
    acc
}

/// Create a map from parallel key and value collections.
///
/// Pairs up keys[i] with vals[i] to form map entries.
///
/// Examples:
///   zipmap([:a, :b, :c], [1, 2, 3])  // => {:a 1, :b 2, :c 3}
fn zipmap(keys-coll, vals-coll) {
    let mut ks = seq(keys-coll)
    let mut vs = seq(vals-coll)
    let mut acc = {}
    while ks != null && vs != null {
        acc = assoc(acc, first(ks), first(vs))
        ks = next(ks)
        vs = next(vs)
    }
    acc
}

/// Interleave elements from two collections.
///
/// Returns a vector alternating between elements of coll1 and coll2.
///
/// Examples:
///   interleave([1, 2, 3], [:a, :b, :c])  // => [1, :a, 2, :b, 3, :c]
fn interleave(coll1, coll2) {
    let mut s1 = seq(coll1)
    let mut s2 = seq(coll2)
    let mut acc = []
    while s1 != null && s2 != null {
        acc = push(acc, first(s1))
        acc = push(acc, first(s2))
        s1 = next(s1)
        s2 = next(s2)
    }
    acc
}

/// Insert a separator between each element of a collection.
///
/// Examples:
///   interpose(0, [1, 2, 3])  // => [1, 0, 2, 0, 3]
fn interpose(sep, coll) {
    let mut s = seq(coll)
    let mut acc = []
    let mut is-first = true
    while s != null {
        if is-first {
            acc = push(acc, first(s))
            is-first = false
        } else {
            acc = push(acc, sep)
            acc = push(acc, first(s))
        }
        s = next(s)
    }
    acc
}

// ============================================================================
// Collection Creation & Transformation
// ============================================================================

/// Pour elements from source collection into target collection.
///
/// For vectors: appends elements. For maps: source should be [key, value] pairs.
/// For sets: adds elements.
///
/// Examples:
///   into([1, 2], [3, 4])          // => [1, 2, 3, 4]
///   into({}, [[:a, 1], [:b, 2]])   // => {:a 1, :b 2}
///   into(#{1, 2}, [2, 3, 4])       // => #{1, 2, 3, 4}
fn into(target, source) {
    // Polymorphic via the Conj protocol: vectors append, sets add, maps take
    // [k v] pairs, and any container extending Conj works as an accumulation
    // target. This is exactly Clojure's `(into to from)` == `(reduce conj to from)`.
    reduce(fn(acc, x) { conj(acc, x) }, target, source)
}

/// Reverse the order of elements in a collection.
///
/// Returns a new vector with elements in reverse order.
///
/// Examples:
///   reverse([1, 2, 3])  // => [3, 2, 1]
fn reverse(coll) {
    // O(n) backward index walk over a materialized vector (the old version was
    // O(n^2): it prepended via concat([x], acc) on every element).
    let v = vec(coll)
    let mut acc = []
    let mut i = length(v) - 1
    while i >= 0 {
        acc = push(acc, get(v, i))
        i = i - 1
    }
    acc
}

/// Create a vector with a value repeated n times.
///
/// Examples:
///   repeat("x", 3)  // => ["x", "x", "x"]
fn repeat(value, n) {
    let mut remaining = n
    let mut acc = []
    while remaining > 0 {
        acc = push(acc, value)
        remaining = remaining - 1
    }
    acc
}

/// Call a function n times and collect the results.
///
/// Examples:
///   repeatedly(fn() { random() }, 3)  // => [0.1, 0.7, 0.4] (random values)
fn repeatedly(f, n) {
    let mut remaining = n
    let mut acc = []
    while remaining > 0 {
        acc = push(acc, f())
        remaining = remaining - 1
    }
    acc
}

/// Generate a sequence by repeatedly applying a function.
///
/// Starts with init, then f(init), f(f(init)), etc. for n values.
///
/// Examples:
///   iterate(fn(x) { x * 2 }, 1, 5)  // => [1, 2, 4, 8, 16]
fn iterate(f, init, n) {
    let mut remaining = n
    let mut current = init
    let mut acc = []
    while remaining > 0 {
        acc = push(acc, current)
        current = f(current)
        remaining = remaining - 1
    }
    acc
}

/// Split a collection into groups of n elements.
///
/// Examples:
///   partition(2, [1, 2, 3, 4, 5, 6])  // => [[1, 2], [3, 4], [5, 6]]
fn partition(n, coll) {
    let mut remaining = coll
    let mut acc = []
    while empty?(remaining) == false {
        let chunk = take(n, remaining)
        remaining = drop(n, remaining)
        acc = push(acc, chunk)
    }
    acc
}

/// Split a collection when the key function's return value changes.
///
/// Groups consecutive elements with the same key value.
///
/// Examples:
///   partition-by(identity, [1, 1, 2, 2, 1])  // => [[1, 1], [2, 2], [1]]
fn partition-by(f, coll) {
    let mut s = seq(coll)
    if s == null {
        []
    } else {
        let mut acc = []
        let mut current-group = []
        let mut current-key = f(first(s))
        while s != null {
            let elem = first(s)
            let key = f(elem)
            if key == current-key {
                current-group = push(current-group, elem)
            } else {
                acc = push(acc, current-group)
                current-group = [elem]
                current-key = key
            }
            s = next(s)
        }
        // Don't forget the last group
        push(acc, current-group)
    }
}

/// Group elements by the result of a key function.
///
/// Returns a map from keys to vectors of elements with that key.
///
/// Examples:
///   group-by(even?, [1, 2, 3, 4, 5])  // => {true: [2, 4], false: [1, 3, 5]}
fn group-by(f, coll) {
    let mut s = seq(coll)
    let mut groups = {}
    while s != null {
        let elem = first(s)
        let key = f(elem)
        let existing = get(groups, key)
        let updated = if existing == null {
            [elem]
        } else {
            push(existing, elem)
        }
        groups = assoc(groups, key, updated)
        s = next(s)
    }
    groups
}

/// Count occurrences of each value in a collection.
///
/// Returns a map from values to their counts.
///
/// Examples:
///   frequencies([1, 2, 1, 3, 1, 2])  // => {1: 3, 2: 2, 3: 1}
fn frequencies(coll) {
    let mut s = seq(coll)
    let mut counts = {}
    while s != null {
        let elem = first(s)
        let current = get(counts, elem)
        let new-count = if current == null {
            1
        } else {
            current + 1
        }
        counts = assoc(counts, elem, new-count)
        s = next(s)
    }
    counts
}

/// Remove duplicate values from a collection.
///
/// Keeps the first occurrence of each value.
///
/// Examples:
///   distinct([1, 2, 1, 3, 2, 1])  // => [1, 2, 3]
fn distinct(coll) {
    let mut s = seq(coll)
    let mut seen = {}
    let mut acc = []
    while s != null {
        let elem = first(s)
        let already-seen = get(seen, elem)
        if already-seen == null {
            seen = assoc(seen, elem, true)
            acc = push(acc, elem)
        }
        s = next(s)
    }
    acc
}

/// Remove consecutive duplicate elements.
///
/// Keeps the first occurrence of each run of duplicates.
///
/// Examples:
///   dedupe([1, 1, 2, 2, 2, 1, 1])  // => [1, 2, 1]
fn dedupe(coll) {
    let mut s = seq(coll)
    if s == null {
        []
    } else {
        let mut acc = [first(s)]
        let mut prev = first(s)
        s = next(s)
        while s != null {
            let elem = first(s)
            if elem != prev {
                acc = push(acc, elem)
                prev = elem
            }
            s = next(s)
        }
        acc
    }
}

// ============================================================================
// Sorting Functions (Timsort)
// ============================================================================
//
// Stable, adaptive O(n log n) sort. Operates on a raw mutable array copy of
// the input vector, then rebuilds an immutable vector from the result.
// Galloping mode is omitted — everything else (natural run detection,
// minrun-extended binary insertion, stack-invariant merges) matches the
// classic Timsort algorithm.

// Allocate a raw mutable array (type_id = 1) filled with null. primitive/write-field
// emits a write barrier, so this array can safely hold heap pointers across GCs.
/// Allocate a raw mutable array of the given size, filled with null (write-barrier safe).
fn tim-allocate-array(size) {
    let a = builtin/allocate(size)
    builtin/fill-object-fields(a, null)
    primitive/write-type-id(a, 1)
    a
}

// Reverse arr[lo..=hi] in place.
/// Reverse arr[lo..=hi] in place.
fn tim-reverse(arr, lo, hi) {
    let mut l = lo
    let mut h = hi
    while l < h {
        let tmp = primitive/read-field(arr, l)
        primitive/write-field(arr, l, primitive/read-field(arr, h))
        primitive/write-field(arr, h, tmp)
        l = l + 1
        h = h - 1
    }
    null
}

// Scan a natural run starting at `start`. Strictly-descending runs are
// reversed in place — using strict less (not less-or-equal) when detecting
// descending keeps equal-keyed elements from being flipped, preserving stability.
/// Scan a natural run at start (reversing it if strictly descending); return its length.
fn tim-count-run-and-make-ascending(arr, start, n, less) {
    if start + 1 >= n {
        1
    } else {
        let first-val = primitive/read-field(arr, start)
        let second-val = primitive/read-field(arr, start + 1)
        let mut runhi = start + 2
        if less(second-val, first-val) {
            while runhi < n && less(primitive/read-field(arr, runhi), primitive/read-field(arr, runhi - 1)) {
                runhi = runhi + 1
            }
            tim-reverse(arr, start, runhi - 1)
        } else {
            while runhi < n && less(primitive/read-field(arr, runhi), primitive/read-field(arr, runhi - 1)) == false {
                runhi = runhi + 1
            }
        }
        runhi - start
    }
}

// Binary-insertion sort arr[lo..hi], with arr[lo..start] already sorted.
// Strict-less in the binary search puts the pivot after any equal elements,
// preserving stability.
/// Binary-insertion-sort arr[lo..hi], with arr[lo..start] already sorted (stable).
fn tim-binary-insertion-sort(arr, lo, hi, start, less) {
    let mut s = if start <= lo { lo + 1 } else { start }
    while s < hi {
        let pivot = primitive/read-field(arr, s)
        let mut left = lo
        let mut right = s
        while left < right {
            let mid = left + (right - left) / 2
            if less(pivot, primitive/read-field(arr, mid)) {
                right = mid
            } else {
                left = mid + 1
            }
        }
        let mut i = s
        while i > left {
            primitive/write-field(arr, i, primitive/read-field(arr, i - 1))
            i = i - 1
        }
        primitive/write-field(arr, left, pivot)
        s = s + 1
    }
    null
}

// Timsort minrun: pick a value in [32, 64) so that n / minrun is just below
// a power of two (keeps the merge tree balanced). Implemented without bitwise
// ops because Beagle has none — (m - (m/2)*2) is m mod 2.
/// Compute Timsort's minrun in [32,64) so n/minrun is just below a power of two.
fn tim-calc-min-run(n) {
    let mut r = 0
    let mut m = n
    while m >= 64 {
        if m - (m / 2) * 2 == 1 {
            r = 1
        }
        m = m / 2
    }
    m + r
}

// Merge adjacent runs arr[base1..base1+len1] and arr[base2..base2+len2],
// where base2 == base1 + len1. Copy the smaller side into temp to bound
// scratch usage.
/// Merge two adjacent runs, copying the smaller side into temp.
fn tim-merge(arr, temp, base1, len1, base2, len2, less) {
    if len1 <= len2 {
        tim-merge-lo(arr, temp, base1, len1, base2, len2, less)
    } else {
        tim-merge-hi(arr, temp, base1, len1, base2, len2, less)
    }
}

// Left run copied to temp, merge forward. On ties prefer temp (left) so
// equal-keyed elements keep their original relative order.
/// Merge two runs with the left run buffered in temp, scanning forward (stable on ties).
fn tim-merge-lo(arr, temp, base1, len1, base2, len2, less) {
    let mut i = 0
    while i < len1 {
        primitive/write-field(temp, i, primitive/read-field(arr, base1 + i))
        i = i + 1
    }
    let mut dest = base1
    let mut ti = 0
    let mut ai = base2
    let a-end = base2 + len2
    while ti < len1 && ai < a-end {
        let t-val = primitive/read-field(temp, ti)
        let a-val = primitive/read-field(arr, ai)
        if less(a-val, t-val) {
            primitive/write-field(arr, dest, a-val)
            ai = ai + 1
        } else {
            primitive/write-field(arr, dest, t-val)
            ti = ti + 1
        }
        dest = dest + 1
    }
    // If right drained first, its leftover tail is already in place at arr[ai..a-end].
    while ti < len1 {
        primitive/write-field(arr, dest, primitive/read-field(temp, ti))
        ti = ti + 1
        dest = dest + 1
    }
    null
}

// Right run copied to temp, merge backward. On ties prefer temp (right) —
// writing it at the higher dest keeps it after any equal left-run elements.
/// Merge two runs with the right run buffered in temp, scanning backward (stable on ties).
fn tim-merge-hi(arr, temp, base1, len1, base2, len2, less) {
    let mut i = 0
    while i < len2 {
        primitive/write-field(temp, i, primitive/read-field(arr, base2 + i))
        i = i + 1
    }
    let mut dest = base2 + len2 - 1
    let mut ti = len2 - 1
    let mut ai = base1 + len1 - 1
    while ti >= 0 && ai >= base1 {
        let t-val = primitive/read-field(temp, ti)
        let a-val = primitive/read-field(arr, ai)
        if less(t-val, a-val) {
            primitive/write-field(arr, dest, a-val)
            ai = ai - 1
        } else {
            primitive/write-field(arr, dest, t-val)
            ti = ti - 1
        }
        dest = dest - 1
    }
    while ti >= 0 {
        primitive/write-field(arr, dest, primitive/read-field(temp, ti))
        ti = ti - 1
        dest = dest - 1
    }
    null
}

// Merge runs at stack[i] and stack[i+1], compacting the stack down by one.
// Returns the new stack size.
/// Merge the pending runs at stack[i] and stack[i+1]; return the new stack size.
fn tim-merge-at(arr, temp, stack-base, stack-len, stack-size, i, less) {
    let base1 = primitive/read-field(stack-base, i)
    let len1 = primitive/read-field(stack-len, i)
    let base2 = primitive/read-field(stack-base, i + 1)
    let len2 = primitive/read-field(stack-len, i + 1)
    tim-merge(arr, temp, base1, len1, base2, len2, less)
    primitive/write-field(stack-len, i, len1 + len2)
    // If we merged the middle of the top three, shift the topmost down by one.
    if i == stack-size - 3 {
        primitive/write-field(stack-base, i + 1, primitive/read-field(stack-base, i + 2))
        primitive/write-field(stack-len, i + 1, primitive/read-field(stack-len, i + 2))
    }
    stack-size - 1
}

// Maintain Timsort's modern (CPython 3.6.2+) stack invariant for the top runs
// A, B, C (C on top):
//   A > B + C   AND   B > C
// If violated, merge B with whichever neighbor is smaller until balanced.
/// Merge pending runs until Timsort's stack invariants hold; return the new stack size.
fn tim-merge-collapse(arr, temp, stack-base, stack-len, stack-size, less) {
    let mut size = stack-size
    let mut done = false
    while size > 1 && done == false {
        let n = size - 2
        if n >= 1 && primitive/read-field(stack-len, n - 1) <= primitive/read-field(stack-len, n) + primitive/read-field(stack-len, n + 1) {
            if primitive/read-field(stack-len, n - 1) < primitive/read-field(stack-len, n + 1) {
                size = tim-merge-at(arr, temp, stack-base, stack-len, size, n - 1, less)
            } else {
                size = tim-merge-at(arr, temp, stack-base, stack-len, size, n, less)
            }
        } else {
            if primitive/read-field(stack-len, n) <= primitive/read-field(stack-len, n + 1) {
                size = tim-merge-at(arr, temp, stack-base, stack-len, size, n, less)
            } else {
                done = true
            }
        }
    }
    size
}

// Final sweep at end of sort: merge every remaining pending run.
/// Merge all remaining pending runs at the end of the sort.
fn tim-merge-force-collapse(arr, temp, stack-base, stack-len, stack-size, less) {
    let mut size = stack-size
    while size > 1 {
        let mut n = size - 2
        if n > 0 && primitive/read-field(stack-len, n - 1) < primitive/read-field(stack-len, n + 1) {
            n = n - 1
        }
        size = tim-merge-at(arr, temp, stack-base, stack-len, size, n, less)
    }
    null
}

// Sort a raw array in place using Timsort (no galloping).
/// Sort a raw array of n elements in place using Timsort and the given less comparator.
fn tim-sort-array(arr, n, less) {
    if n < 2 {
        null
    } else {
        if n < 64 {
            // Too small for run-detection overhead to pay off.
            tim-binary-insertion-sort(arr, 0, n, 0, less)
        } else {
            let min-run = tim-calc-min-run(n)
            let temp = tim-allocate-array(n)
            // 85 entries bound the pending-run stack for any n up to 2^63 under
            // the merge-collapse invariant with minrun >= 32.
            let stack-base = tim-allocate-array(85)
            let stack-len = tim-allocate-array(85)
            let mut stack-size = 0
            let mut i = 0
            while i < n {
                let run-base = i
                let mut run-len = tim-count-run-and-make-ascending(arr, i, n, less)
                if run-len < min-run {
                    let force = if n - i < min-run { n - i } else { min-run }
                    tim-binary-insertion-sort(arr, run-base, run-base + force, run-len, less)
                    run-len = force
                }
                primitive/write-field(stack-base, stack-size, run-base)
                primitive/write-field(stack-len, stack-size, run-len)
                stack-size = stack-size + 1
                stack-size = tim-merge-collapse(arr, temp, stack-base, stack-len, stack-size, less)
                i = run-base + run-len
            }
            tim-merge-force-collapse(arr, temp, stack-base, stack-len, stack-size, less)
        }
    }
}

/// Sort a collection with a user-provided `less` comparator.
///
/// `less(a, b)` must return true when `a` should come before `b`. Stable and
/// O(n log n) via Timsort; O(n) on already-sorted or reverse-sorted input.
fn sort-with(less, coll) {
    let vec = if instance-of(coll, PersistentVector) {
        coll
    } else {
        reduce(fn(acc, x) { push(acc, x) }, [], coll)
    }
    let n = rust-coll/vec-count(vec)
    if n < 2 {
        vec
    } else {
        let arr = rust-coll/vec-to-array(vec)
        tim-sort-array(arr, n, less)
        rust-coll/array-to-vec(arr, n)
    }
}

/// Sort a collection in ascending order.
///
/// Stable O(n log n) Timsort; runs in O(n) on already-sorted or reverse-sorted
/// input. Elements must be comparable with `<`.
///
/// Examples:
///   sort([3, 1, 4, 1, 5])  // => [1, 1, 3, 4, 5]
fn sort(coll) {
    // Primitives sort via the direct `<` (unchanged fast path); collections of
    // heap value types (BigInt/SemVer/DateTime/...) sort via `compare`, which
    // dispatches to their Comparable impl. The element kind is checked ONCE on
    // the first element rather than per comparison.
    let v = vec(coll)
    if length(v) < 2 {
        v
    } else {
        if struct?(get(v, 0)) {
            sort-with(fn(a, b) { compare(a, b) < 0 }, v)
        } else {
            sort-with(fn(a, b) { a < b }, v)
        }
    }
}

/// Sort a collection by a key function.
///
/// Elements are ordered by comparing `f(elem)` values. `f` is invoked on every
/// comparison — wrap in `memoize` if it's expensive and you have many ties.
///
/// Examples:
///   sort-by(fn(x) { x.age }, [{ name: "bob", age: 30 }, { name: "alice", age: 25 }])
///   // => [{ name: "alice", age: 25 }, { name: "bob", age: 30 }]
fn sort-by(f, coll) {
    // Same primitive-vs-value-type split as `sort`, checked once on f(first).
    let v = vec(coll)
    if length(v) < 2 {
        v
    } else {
        if struct?(f(get(v, 0))) {
            sort-with(fn(a, b) { compare(f(a), f(b)) < 0 }, v)
        } else {
            sort-with(fn(a, b) { f(a) < f(b) }, v)
        }
    }
}

// ============================================================================
// Function Utilities
// ============================================================================

/// Run `body(resource)` and guarantee `close(resource)` runs afterwards on EVERY
/// exit path — normal return OR a thrown exception — then return body's value (or
/// re-raise). `resource` must implement the `Closeable` protocol (e.g. an io/File).
/// This is Beagle's RAII / try-with-resources: no more leaked handles on a throw.
///
/// Examples:
///   with-open(unwrap(io/open("/tmp/x", "r")), fn(f) {
///       io/read-line(f)
///   })
fn with-open(resource, body) {
    let result = try {
        body(resource)
    } catch (e) {
        // Close on the error path, then re-raise the original error.
        close(resource)
        throw(e)
    }
    // Normal path: close after a successful body.
    close(resource)
    result
}

/// Return the input unchanged.
///
/// Useful as a default function argument.
///
/// Examples:
///   identity(42)  // => 42
///   map(identity, [1, 2, 3])  // => [1, 2, 3]
fn identity(x) {
    x
}

/// Return a function that always returns the given value.
///
/// Ignores any arguments passed to the returned function.
///
/// Examples:
///   let always-42 = constantly(42)
///   always-42("ignored")  // => 42
fn constantly(value) {
    fn(ignored) { value }
}

/// Return a function that negates a predicate.
///
/// Examples:
///   let not-even? = complement(even?)
///   not-even?(3)  // => true
fn complement(pred) {
    fn(x) { not(pred(x)) }
}

/// Compose two functions: (compose f g) returns fn(x) { f(g(x)) }.
///
/// The second function is applied first, then the first.
///
/// Examples:
///   let add1-then-double = compose(fn(x) { x * 2 }, fn(x) { x + 1 })
///   add1-then-double(3)  // => 8  (3+1=4, 4*2=8)
fn compose(f, g) {
    fn(x) { f(g(x)) }
}

/// Partially apply a function by fixing its first argument.
///
/// Examples:
///   let add10 = partial(fn(a, b) { a + b }, 10)
///   add10(5)  // => 15
fn partial(f, a) {
    fn(b) { f(a, b) }
}

// ============================================================================
// Boolean/Logic Utilities
// ============================================================================

/// Boolean negation.
///
/// Returns true if x is falsy, false if x is truthy.
///
/// Examples:
///   not(true)   // => false
///   not(false)  // => true
///   not(null)   // => true
fn not(x) {
    if x {
        false
    } else {
        true
    }
}

/// Check if a value is truthy (not null and not false).
///
/// Examples:
///   truthy?(1)      // => true
///   truthy?(null)   // => false
///   truthy?(false)  // => false
fn truthy?(x) {
    x != null && x != false
}

/// Check if a value is falsy (null or false).
///
/// Examples:
///   falsy?(null)   // => true
///   falsy?(false)  // => true
///   falsy?(0)      // => false
fn falsy?(x) {
    x == null || x == false
}

// ============================================================================
// Type Checking Predicates
// ============================================================================

/// Check if a value is null.
///
/// Examples:
///   nil?(null)  // => true
///   nil?(0)     // => false
fn nil?(x) {
    x == null
}

/// Check if a value is not null.
///
/// Examples:
///   some?(0)     // => true
///   some?(null)  // => false
fn some?(x) {
    x != null
}

// ============================================================================
// Map Utilities
// ============================================================================

/// Get all values from a map as a vector.
///
/// Examples:
///   vals({:a 1, :b 2})  // => [1, 2]
fn vals(m) {
    let ks = keys(m)
    map(fn(k) { get(m, k) }, ks)
}

/// Find the [key value] entry for a key in a map, or null if the key is absent.
///
/// This is Clojure's `find`, renamed because Beagle's `find` already means
/// "first element matching a predicate" (see `find`/`find-index`). Unlike
/// `get`, it distinguishes a missing key (null) from a key whose stored value
/// is null (returns `[key null]`).
///
/// Examples:
///   find-entry({:a 1}, :a)     // => [:a, 1]
///   find-entry({:a 1}, :b)     // => null
///   find-entry({:a null}, :a)  // => [:a, null]
fn find-entry(m, key) {
    rust-coll/map-find(m, key)
}

/// Remove a key from a map.
///
/// Returns a new map without the specified key.
///
/// Examples:
///   dissoc({:a 1, :b 2}, :a)  // => {:b 2}
fn dissoc(m, key) {
    // O(log n) native HAMT remove (was an O(n log n) filter-keys + re-assoc rebuild).
    rust-coll/map-dissoc(m, key)
}

/// Merge two maps together.
///
/// m2's values take precedence for duplicate keys.
///
/// Examples:
///   merge({:a 1, :b 2}, {:b 3, :c 4})  // => {:a 1, :b 3, :c 4}
fn merge(m1, m2) {
    let ks = keys(m2)
    reduce(fn(acc, k) { assoc(acc, k, get(m2, k)) }, m1, ks)
}

/// Merge two maps using a function to resolve key conflicts.
///
/// When a key exists in both maps, calls f(v1, v2) to get the merged value.
///
/// Examples:
///   merge-with(fn(a, b) { a + b }, {:a 1}, {:a 2, :b 3})  // => {:a 3, :b 3}
fn merge-with(f, m1, m2) {
    merge-with-helper(f, m1, m2, keys(m2), 0, m1)
}

/// Helper: fold m2's keys into acc, resolving conflicts with f.
fn merge-with-helper(f, m1, m2, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        let v2 = get(m2, k)
        // Use contains? not (v1 == null): a key present in m1 with a stored null
        // value must still go through the conflict resolver, not be treated as
        // absent.
        let new-acc = if contains?(m1, k) {
            assoc(acc, k, f(get(m1, k), v2))
        } else {
            assoc(acc, k, v2)
        }
        merge-with-helper(f, m1, m2, ks, idx + 1, new-acc)
    }
}

/// Keep only the specified keys from a map.
///
/// Returns a new map with only the keys in ks.
///
/// Examples:
///   select-keys({:a 1, :b 2, :c 3}, [:a, :c])  // => {:a 1, :c 3}
fn select-keys(m, ks) {
    select-keys-helper(m, ks, 0, {})
}

/// Helper: accumulate the entries of m whose keys are in ks.
fn select-keys-helper(m, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        // Include the key iff it is present in m — even when its stored value is
        // null. (v == null would wrongly drop present-with-null entries.)
        let new-acc = if contains?(m, k) {
            assoc(acc, k, get(m, k))
        } else {
            acc
        }
        select-keys-helper(m, ks, idx + 1, new-acc)
    }
}

/// Update a value at a key using a function.
///
/// Applies f to the current value at key and associates the result.
///
/// Examples:
///   update({:a 1}, :a, fn(x) { x + 1 })  // => {:a 2}
fn update(m, key, f) {
    let old-val = get(m, key)
    assoc(m, key, f(old-val))
}

/// Get a nested value using a path of keys.
///
/// Returns null if any key in the path is not found.
///
/// Examples:
///   get-in({:a {:b {:c 42}}}, [:a, :b, :c])  // => 42
///   get-in({:a {:b 1}}, [:a, :x])           // => null
fn get-in(m, path) {
    let mut current = m
    let mut s = seq(path)
    while s != null && current != null {
        let k = first(s)
        current = get(current, k)
        s = next(s)
    }
    current
}

/// Set a nested value using a path of keys.
///
/// Creates intermediate maps as needed.
///
/// Examples:
///   assoc-in({:a {:b 1}}, [:a, :b], 42)  // => {:a {:b 42}}
///   assoc-in({}, [:a, :b, :c], 1)         // => {:a {:b {:c 1}}}
fn assoc-in(m, path, val) {
    let len = length(path)
    if len == 0 {
        m
    } else {
        if len == 1 {
            assoc(m, get(path, 0), val)
        } else {
            let k = get(path, 0)
            let rest-path = rest(path)
            let nested = get(m, k)
            let new-nested = if nested == null {
                assoc-in({}, rest-path, val)
            } else {
                assoc-in(nested, rest-path, val)
            }
            assoc(m, k, new-nested)
        }
    }
}

/// Update a nested value using a path of keys and a function.
///
/// Applies f to the current value at the path.
///
/// Examples:
///   update-in({:a {:b 1}}, [:a, :b], fn(x) { x + 1 })  // => {:a {:b 2}}
fn update-in(m, path, f) {
    let len = length(path)
    if len == 0 {
        m
    } else {
        if len == 1 {
            update(m, get(path, 0), f)
        } else {
            let k = get(path, 0)
            let rest-path = rest(path)
            let nested = get(m, k)
            let new-nested = if nested == null {
                update-in({}, rest-path, f)
            } else {
                update-in(nested, rest-path, f)
            }
            assoc(m, k, new-nested)
        }
    }
}

/// Check if a map contains a key.
///
/// Examples:
///   contains-key?({:a 1, :b 2}, :a)  // => true
///   contains-key?({:a 1, :b 2}, :c)  // => false
fn contains-key?(m, key) {
    // Delegate to the native, O(log n) membership test (the old O(n) keys-scan
    // was redundant with `contains?`).
    contains?(m, key)
}

/// Swap keys and values in a map.
///
/// Values become keys and keys become values.
///
/// Examples:
///   invert({:a 1, :b 2})  // => {1: :a, 2: :b}
fn invert(m) {
    let ks = keys(m)
    reduce(fn(acc, k) {
        let v = get(m, k)
        assoc(acc, v, k)
    }, {}, ks)
}

/// Apply a function to all keys in a map.
///
/// Returns a new map with transformed keys, same values.
///
/// Examples:
///   map-keys({:a 1, :b 2}, keyword->string)  // => {"a": 1, "b": 2}
fn map-keys(m, f) {
    map-keys-helper(m, f, keys(m), 0, {})
}

/// Helper: rebuild a map applying f to each key.
fn map-keys-helper(m, f, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        let v = get(m, k)
        let new-acc = assoc(acc, f(k), v)
        map-keys-helper(m, f, ks, idx + 1, new-acc)
    }
}

/// Apply a function to all values in a map.
///
/// Returns a new map with same keys, transformed values.
///
/// Examples:
///   map-vals({:a 1, :b 2}, fn(x) { x * 2 })  // => {:a 2, :b 4}
fn map-vals(m, f) {
    map-vals-helper(m, f, keys(m), 0, {})
}

/// Helper: rebuild a map applying f to each value.
fn map-vals-helper(m, f, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        let v = get(m, k)
        let new-acc = assoc(acc, k, f(v))
        map-vals-helper(m, f, ks, idx + 1, new-acc)
    }
}

/// Keep only entries where the key satisfies the predicate.
///
/// Examples:
///   filter-keys({:a 1, :ab 2, :abc 3}, fn(k) { length(keyword->string(k)) > 1 })
///   ; => {:ab 2, :abc 3}
fn filter-keys(m, pred) {
    filter-keys-helper(m, pred, keys(m), 0, {})
}

/// Helper: accumulate entries of m whose keys satisfy pred.
fn filter-keys-helper(m, pred, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        let new-acc = if pred(k) {
            assoc(acc, k, get(m, k))
        } else {
            acc
        }
        filter-keys-helper(m, pred, ks, idx + 1, new-acc)
    }
}

/// Keep only entries where the value satisfies the predicate.
///
/// Examples:
///   filter-vals({:a 1, :b 2, :c 3}, fn(v) { v > 1 })  // => {:b 2, :c 3}
fn filter-vals(m, pred) {
    filter-vals-helper(m, pred, keys(m), 0, {})
}

/// Helper: accumulate entries of m whose values satisfy pred.
fn filter-vals-helper(m, pred, ks, idx, acc) {
    if idx >= length(ks) {
        acc
    } else {
        let k = get(ks, idx)
        let v = get(m, k)
        let new-acc = if pred(v) {
            assoc(acc, k, v)
        } else {
            acc
        }
        filter-vals-helper(m, pred, ks, idx + 1, new-acc)
    }
}

// ============================================================================
// Rust PersistentSet Protocol Implementations
// ============================================================================

extend PersistentSet with Length {
    /// Return the number of elements in set.
    fn length(set) {
        rust-coll/set-count(set)
    }
}

extend PersistentSet with Format {
    /// Format set as #{...} with comma-separated elements.
    fn format(set, depth) {
        let elems = rust-coll/set-elements(set)
        let len = rust-coll/vec-count(elems)
        if len == 0 {
            "#{}"
        } else {
            format-rust-set-elements(elems, 0, len, "#{")
        }
    }
}

/// Helper: recursively format a Rust-backed set's elements into acc.
fn format-rust-set-elements(elems-vec, idx, len, acc) {
    if idx >= len {
        acc ++ "}"
    } else {
        let elem = rust-coll/vec-get(elems-vec, idx)
        let elem-str = format(elem, 1)
        let new-acc = if idx == 0 {
            acc ++ elem-str
        } else {
            acc ++ ", " ++ elem-str
        }
        format-rust-set-elements(elems-vec, idx + 1, len, new-acc)
    }
}

// Sequence type for iterating over PersistentSet
/// Seq view over a PersistentSet's elements, tracking the current index.
struct PersistentSetSeq {
    elements
    index
}

extend PersistentSetSeq with Seq {
    /// Return the element at the seq's current index.
    fn first(seq) {
        rust-coll/vec-get(seq.elements, seq.index)
    }
    /// Advance to the next element, or null at the end.
    fn next(seq) {
        let next-idx = seq.index + 1
        if next-idx >= rust-coll/vec-count(seq.elements) {
            null
        } else {
            PersistentSetSeq { elements: seq.elements, index: next-idx }
        }
    }
}

extend PersistentSetSeq with Seqable {
    /// A live seq is its own seq (idempotent).
    fn seq(s) { s }
}

extend PersistentSetSeq with Length {
    /// Return the number of elements remaining in the seq.
    fn length(s) { rust-coll/vec-count(s.elements) - s.index }
}

extend PersistentSet with Seqable {
    /// Return a PersistentSetSeq over set, or null if empty.
    fn seq(set) {
        let elems = rust-coll/set-elements(set)
        if rust-coll/vec-count(elems) == 0 {
            null
        } else {
            PersistentSetSeq { elements: elems, index: 0 }
        }
    }
}

// Sequence type for iterating over a PersistentMap. Each element is a 2-element
// [key value] entry vector, mirroring Clojure's (seq {:a 1}) => ([:a 1]). This
// makes every seq-library function (map/filter/reduce/into/count/…) and the
// beagle.iter combinators work over maps.
/// Seq view over a PersistentMap, yielding [key value] entry pairs.
struct PersistentMapSeq {
    map
    keys
    index
}

extend PersistentMapSeq with Seq {
    /// Return the current [key value] entry pair.
    fn first(seq) {
        let k = rust-coll/vec-get(seq.keys, seq.index)
        [k, rust-coll/map-get(seq.map, k)]
    }
    /// Advance to the next entry, or null at the end.
    fn next(seq) {
        let next-idx = seq.index + 1
        if next-idx >= rust-coll/vec-count(seq.keys) {
            null
        } else {
            PersistentMapSeq { map: seq.map, keys: seq.keys, index: next-idx }
        }
    }
}

extend PersistentMapSeq with Seqable {
    /// A live seq is its own seq (idempotent).
    fn seq(s) { s }
}

extend PersistentMapSeq with Length {
    /// Return the number of entries remaining in the seq.
    fn length(s) { rust-coll/vec-count(s.keys) - s.index }
}

extend PersistentMap with Seqable {
    /// Return a PersistentMapSeq over map yielding [key value] pairs, or null if empty.
    fn seq(map) {
        let ks = rust-coll/map-keys(map)
        if rust-coll/vec-count(ks) == 0 {
            null
        } else {
            PersistentMapSeq { map: map, keys: ks, index: 0 }
        }
    }
}

// ============================================================================
// Set Utility Functions
// ============================================================================

/// Check if a value is a PersistentSet.
///
/// Examples:
///   set?(#{1, 2, 3})  // => true
///   set?([1, 2, 3])   // => false
fn set?(x) {
    instance-of(x, PersistentSet)
}

/// Check if an element is in a set.
///
/// Examples:
///   set-contains?(#{1, 2, 3}, 2)  // => true
///   set-contains?(#{1, 2, 3}, 5)  // => false
fn set-contains?(set, elem) {
    rust-coll/set-contains?(set, elem)
}

/// Add an element to a set.
///
/// Returns a new set with the element added (no-op if already present).
///
/// Examples:
///   set-add(#{1, 2}, 3)  // => #{1, 2, 3}
///   set-add(#{1, 2}, 2)  // => #{1, 2}
fn set-add(set, elem) {
    rust-coll/set-add(set, elem)
}

/// Remove an element from a set.
///
/// Returns a new set without the element.
///
/// Examples:
///   set-remove(#{1, 2, 3}, 2)  // => #{1, 3}
fn set-remove(set, elem) {
    // O(log n) native remove (was an O(n) rebuild via set-elements + re-add).
    rust-coll/set-disj(set, elem)
}

/// Return the union of two sets.
///
/// Contains all elements from both sets.
///
/// Examples:
///   set-union(#{1, 2}, #{2, 3})  // => #{1, 2, 3}
fn set-union(s1, s2) {
    let elems2 = rust-coll/set-elements(s2)
    set-union-helper(s1, elems2, 0, rust-coll/vec-count(elems2))
}

/// Helper: add each element of elems2 into s1.
fn set-union-helper(s1, elems2, idx, len) {
    if idx >= len {
        s1
    } else {
        let elem = rust-coll/vec-get(elems2, idx)
        let new-s1 = rust-coll/set-add(s1, elem)
        set-union-helper(new-s1, elems2, idx + 1, len)
    }
}

/// Return the intersection of two sets.
///
/// Contains only elements present in both sets.
///
/// Examples:
///   set-intersection(#{1, 2, 3}, #{2, 3, 4})  // => #{2, 3}
fn set-intersection(s1, s2) {
    let elems1 = rust-coll/set-elements(s1)
    set-intersection-helper(elems1, s2, 0, rust-coll/vec-count(elems1), #{})
}

/// Helper: accumulate elements of elems1 that are also in s2.
fn set-intersection-helper(elems1, s2, idx, len, acc) {
    if idx >= len {
        acc
    } else {
        let elem = rust-coll/vec-get(elems1, idx)
        let new-acc = if rust-coll/set-contains?(s2, elem) {
            rust-coll/set-add(acc, elem)
        } else {
            acc
        }
        set-intersection-helper(elems1, s2, idx + 1, len, new-acc)
    }
}

/// Return the difference of two sets.
///
/// Contains elements in s1 but not in s2.
///
/// Examples:
///   set-difference(#{1, 2, 3}, #{2, 3, 4})  // => #{1}
fn set-difference(s1, s2) {
    let elems1 = rust-coll/set-elements(s1)
    set-difference-helper(elems1, s2, 0, rust-coll/vec-count(elems1), #{})
}

/// Helper: accumulate elements of elems1 that are not in s2.
fn set-difference-helper(elems1, s2, idx, len, acc) {
    if idx >= len {
        acc
    } else {
        let elem = rust-coll/vec-get(elems1, idx)
        let new-acc = if rust-coll/set-contains?(s2, elem) {
            acc
        } else {
            rust-coll/set-add(acc, elem)
        }
        set-difference-helper(elems1, s2, idx + 1, len, new-acc)
    }
}

/// Check if s1 is a subset of s2.
///
/// Returns true if all elements of s1 are also in s2.
///
/// Examples:
///   set-subset?(#{1, 2}, #{1, 2, 3})  // => true
///   set-subset?(#{1, 4}, #{1, 2, 3})  // => false
fn set-subset?(s1, s2) {
    let elems1 = rust-coll/set-elements(s1)
    set-subset-helper(elems1, s2, 0, rust-coll/vec-count(elems1))
}

/// Helper: return true if every element of elems1 is in s2.
fn set-subset-helper(elems1, s2, idx, len) {
    if idx >= len {
        true
    } else {
        let elem = rust-coll/vec-get(elems1, idx)
        if rust-coll/set-contains?(s2, elem) {
            set-subset-helper(elems1, s2, idx + 1, len)
        } else {
            false
        }
    }
}

/// Convert a collection to a set.
///
/// Removes duplicates since sets only contain unique elements.
///
/// Examples:
///   into-set([1, 2, 2, 3, 3, 3])  // => #{1, 2, 3}
fn into-set(coll) {
    reduce(fn(acc, elem) { rust-coll/set-add(acc, elem) }, #{}, coll)
}

/// Materialize any collection into a persistent vector (identity on vectors).
///
/// Examples:
///   vec(#{1, 2, 3})  // => [1, 2, 3]
fn vec(coll) {
    if instance-of(coll, PersistentVector) {
        coll
    } else {
        reduce(fn(acc, x) { push(acc, x) }, [], coll)
    }
}

/// Return the sub-vector coll[start:end] (end exclusive) as a new vector.
///
/// Examples:
///   subvec([10, 20, 30, 40], 1, 3)  // => [20, 30]
fn subvec(coll, start, end) {
    let v = vec(coll)
    let mut acc = []
    let mut i = start
    while i < end {
        acc = push(acc, get(v, i))
        i = i + 1
    }
    acc
}

/// Value membership: true if `x` is structurally equal to some element of `coll`.
///
/// Distinct from `contains?`, which tests keys/indices: `contains?([10,20], 1)`
/// asks "is index 1 valid", whereas `includes?([10,20], 20)` asks "is 20 an element".
///
/// Examples:
///   includes?([10, 20, 30], 20)  // => true
///   includes?([10, 20, 30], 1)   // => false
fn includes?(coll, x) {
    any?(fn(e) { equal(e, x) }, coll)
}

/// Set union: a set containing every element of `a` and `b` (inputs may be any
/// collections; the result is always a set).
///
/// Examples:
///   union(#{1, 2}, [2, 3])  // => #{1, 2, 3}
fn union(a, b) {
    let mut acc = into-set(a)
    for x in b {
        acc = rust-coll/set-add(acc, x)
    }
    acc
}

/// Set intersection: a set of the elements present in both `a` and `b`.
///
/// Examples:
///   intersection([1, 2, 3], [2, 3, 4])  // => #{2, 3}
fn intersection(a, b) {
    let bs = into-set(b)
    let mut acc = #{}
    for x in a {
        if contains?(bs, x) {
            acc = rust-coll/set-add(acc, x)
        }
    }
    acc
}

/// Set difference: a set of the elements of `a` not present in `b`.
///
/// Examples:
///   difference([1, 2, 3], [2])  // => #{1, 3}
fn difference(a, b) {
    let bs = into-set(b)
    let mut acc = #{}
    for x in a {
        if contains?(bs, x) == false {
            acc = rust-coll/set-add(acc, x)
        }
    }
    acc
}

// ============================================================================
// Regex Protocol Implementations
// ============================================================================

extend Regex with Format {
    /// Format a regex as the literal "#regex".
    fn format(regex, depth) {
        "#regex"
    }
}

// ============================================================================
// Character Code Functions
// ============================================================================

/// Get the Unicode code point of the first character in a string.
///
/// Examples:
///   char-code("A")  // => 65
///   char-code("a")  // => 97
fn char-code(s) {
    builtin/char-code(s)
}

/// Create a single-character string from a Unicode code point.
///
/// Examples:
///   char-from-code(65)  // => "A"
///   char-from-code(97)  // => "a"
fn char-from-code(code) {
    builtin/char-from-code(code)
}

// ============================================================================
// Error Enum for Unified Error Handling
// ============================================================================
// This is the canonical Error type used across all async and I/O operations.
// Pattern match on specific error types to handle different failure cases.

/// Canonical error type for async and I/O operations; pattern-match to handle each case.
enum Error {
    NotFound { path },
    PermissionDenied { path },
    AlreadyExists { path },
    IsDirectory { path },
    NotDirectory { path },
    Timeout { operation },
    Cancelled {},
    IO { message },
    Other { code, message }
}

// ============================================================================
// Result Type for Error Handling
// ============================================================================
// This is the canonical Result type used across all async and I/O operations.
// All namespaces (fs, timer, io, async) should use this type.

/// Canonical Ok/Err result type used across async and I/O operations.
enum Result {
    Ok { value },
    Err { error }
}

/// Create a successful Result containing a value.
///
/// Examples:
///   ok(42)  // => Result.Ok { value: 42 }
fn ok(value) {
    Result.Ok { value: value }
}

/// Create an error Result containing an Error.
///
/// Examples:
///   err(Error.NotFound { path: "/missing" })
fn err(error) {
    Result.Err { error: error }
}

// Create an error result with code and message (convenience for legacy/IO errors)
/// Create an Err Result wrapping an Error.IO with the given message.
fn err-io(message) {
    Result.Err { error: Error.IO { message: message } }
}

// Create an error result with code (convenience for legacy code)
/// Create an Err Result wrapping an Error.Other with code and message.
fn err-code(code, message) {
    Result.Err { error: Error.Other { code: code, message: message } }
}

/// Check if a Result is successful (Ok variant).
///
/// Examples:
///   ok?(ok(42))                      // => true
///   ok?(err(Error.IO { message: "failed" }))  // => false
fn ok?(result) {
    match result {
        Result.Ok { value } => true,
        Result.Err { error } => false
    }
}

/// Unwrap a Result, returning the value or null on error.
///
/// Prints an error message if the result is an Err.
///
/// Examples:
///   unwrap(ok(42))  // => 42
///   unwrap(err(Error.NotFound { path: "/x" }))  // prints error, returns null
fn unwrap(result) {
    match result {
        Result.Ok { value } => value,
        Result.Err { error } => {
            match error {
                Error.NotFound { path } => println("Error: Not found:", path),
                Error.PermissionDenied { path } => println("Error: Permission denied:", path),
                Error.AlreadyExists { path } => println("Error: Already exists:", path),
                Error.IsDirectory { path } => println("Error: Is a directory:", path),
                Error.NotDirectory { path } => println("Error: Not a directory:", path),
                Error.Timeout { operation } => println("Error: Timeout on:", operation),
                Error.Cancelled {} => println("Error: Cancelled"),
                Error.IO { message } => println("Error:", message),
                Error.Other { code, message } => println("Error:", message)
            }
            null
        }
    }
}

/// Unwrap a Result, returning the value or a default on error.
///
/// Examples:
///   unwrap-or(ok(42), 0)                        // => 42
///   unwrap-or(err(Error.IO { message: "" }), 0)  // => 0
fn unwrap-or(result, default) {
    match result {
        Result.Ok { value } => value,
        Result.Err { error } => default
    }
}

/// Unwrap a Result, returning the value or THROWING the contained error. This is
/// the general "I just want the value, and let the error propagate" unwrap — it
/// composes with try/catch and resumable errors. Prefer this over per-function
/// `!` variants. Use unwrap-or for a default, or unwrap for a print-and-null.
///
/// Examples:
///   unwrap!(ok(42))                                  // => 42
///   unwrap!(err(Error.NotFound { path: "/x" }))      // throws the error
fn unwrap!(result) {
    match result {
        Result.Ok { value } => value,
        Result.Err { error } => throw(error)
    }
}

// Check if a result is a timeout error
/// Check whether a Result is an Err carrying a Timeout error.
fn timeout?(result) {
    match result {
        Result.Err { error } => match error {
            Error.Timeout { operation } => true,
            _ => false
        },
        _ => false
    }
}

// Check if a result is a not-found error
/// Check whether a Result is an Err carrying a NotFound error.
fn not-found?(result) {
    match result {
        Result.Err { error } => match error {
            Error.NotFound { path } => true,
            _ => false
        },
        _ => false
    }
}

// Get the error from a result (returns null if Ok)
/// Return the error from an Err Result, or null if it is Ok.
fn get-error(result) {
    match result {
        Result.Ok { value } => null,
        Result.Err { error } => error
    }
}

// ============================================================================
// String Utility Functions
// ============================================================================
// Note: split() and starts-with?() are provided as builtins - see builtins.rs

// ============================================================================
// Reflection Utilities (aliases for beagle.reflect)
// ============================================================================

use beagle.reflect as reflect

/// Get documentation for a function or type.
///
/// Returns the docstring associated with the value, or null if none exists.
/// Works with functions, structs, enums, and other documented values.
///
/// Examples:
///   doc(map)       ; => "Apply a function to each element..."
///   doc(Result)    ; => documentation for Result enum
fn doc(value) {
    reflect/doc(value)
}

/// Search for functions by name or docstring.
///
/// Returns a list of fully-qualified function names that match the query.
/// The query is matched against both function names and their docstrings.
///
/// Examples:
///   apropos("file")    ; => ["beagle.fs/read-file", "beagle.fs/write-file", ...]
///   apropos("reduce")  ; => ["beagle.core/reduce", "beagle.core/reduce-right"]
fn apropos(query) {
    reflect/apropos(query)
}

/// Assert that calling the given function throws an exception.
/// Throws AssertionError if no exception is thrown.
///
/// Examples:
///   assert-throws!(fn() { throw "boom" })   ; passes
///   assert-throws!(fn() { 42 })              ; fails - no exception thrown
fn assert-throws!(thunk) {
    let threw = try {
        thunk()
        false
    } catch (_e) {
        true
    }
    if !threw {
        throw("assert-throws! failed: expected function to throw, but it returned normally")
    }
}

