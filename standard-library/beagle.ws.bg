namespace beagle.ws

// beagle.ws — RFC 6455 WebSocket server, in pure Beagle.
//
// Built on beagle.http (request parsing / Response type), beagle.hash (SHA-1),
// beagle.base64 (Accept-key + frame helpers), beagle.socket (transport), and
// beagle.string-builder (byte-faithful frame construction).
//
// BYTE MODEL
// ----------
// Sockets carry bytes as a String (byte-faithful): s[i] is a one-byte slice
// whose char-code is the byte value 0..255. We build outbound frames by
// appending char-from-code(byte) into a string-builder, and we parse inbound
// frames by indexing the received string with char-code. All multi-byte
// integers on the wire are big-endian (network order). All 32-bit-ish
// arithmetic stays well within Beagle's 62-bit ints, so no masking is needed
// beyond the per-byte & 0xFF.

use beagle.http as http
use beagle.hash as hash
use beagle.base64 as base64
use beagle.socket as socket
use beagle.string-builder as sb
use beagle.core as core
use beagle.url as url
use beagle.tls as tls

// The RFC 6455 GUID concatenated to the client key before SHA-1.
let WS_GUID = "258EAFA5-E914-47DA-95CA-C5AB0DC85B11"

// ===========================================================================
// Opcodes (RFC 6455 §5.2)
// ===========================================================================

/// RFC 6455 opcode value for a continuation frame (0x0).
fn opcode-continuation() { 0x0 }
/// RFC 6455 opcode value for a text frame (0x1).
fn opcode-text() { 0x1 }
/// RFC 6455 opcode value for a binary frame (0x2).
fn opcode-binary() { 0x2 }
/// RFC 6455 opcode value for a close control frame (0x8).
fn opcode-close() { 0x8 }
/// RFC 6455 opcode value for a ping control frame (0x9).
fn opcode-ping() { 0x9 }
/// RFC 6455 opcode value for a pong control frame (0xA).
fn opcode-pong() { 0xA }

// ===========================================================================
// Byte helpers
// ===========================================================================
//
// CRITICAL: Beagle strings are byte-faithful at the socket layer, but the
// `s[i]` / `length(s)` operations decode UTF-8 — a frame header byte like 0x81
// is an invalid lone UTF-8 byte and corrupts that codepoint view. So we never
// index a wire string directly. Instead we push it into a string-builder once
// and read individual bytes back with sb/byte-at (which is byte-exact), and
// take its byte count with sb/length. This is the same pattern beagle.url uses.

// Wrap a byte-faithful string in a string-builder so its raw bytes can be read
// by index regardless of UTF-8 validity.
/// Wrap a byte-faithful string in a string-builder so its raw bytes can be
/// read by index regardless of UTF-8 validity.
fn to-buf(s) {
    let b = sb/new(length-or-zero(s) + 1)
    sb/append!(b, s)
    b
}

// length() can throw or mislead on invalid-UTF-8 strings; only used as a size
// hint for the builder, so guard it.
/// Return length(s), or 0 if length() throws; used only as a builder size hint
/// for possibly-invalid-UTF-8 wire strings.
fn length-or-zero(s) {
    try {
        length(s)
    } catch (e) {
        0
    }
}

// Read byte i (0..255) from a builder produced by to-buf.
/// Read byte i (0..255) from a builder produced by to-buf.
fn buf-byte(buf, i) {
    sb/byte-at(buf, i) & 0xFF
}

// Convert a lowercase hex string (such as hash/sha1 output) into a Vec<Int>
// of byte values. Each pair of hex digits becomes one byte.
/// Convert a lowercase hex string into a Vec<Int> of byte values, one byte per
/// pair of hex digits.
fn hex-to-bytes(hex) {
    let n = length(hex)
    let mut out = []
    let mut i = 0
    while i + 1 < n {
        let hi = hex-digit-value(char-code(hex[i]))
        let lo = hex-digit-value(char-code(hex[i + 1]))
        out = push(out, (hi << 4) | lo)
        i = i + 2
    }
    out
}

/// Map a single hex-digit char-code (0-9, a-f, A-F) to its 0..15 value; throws
/// on any non-hex code.
fn hex-digit-value(code) {
    if code >= 48 && code <= 57 {
        code - 48
    } else {
        if code >= 97 && code <= 102 {
            code - 97 + 10
        } else {
            if code >= 65 && code <= 70 {
                code - 65 + 10
            } else {
                throw("beagle.ws/hex-to-bytes: invalid hex digit code ${code}")
            }
        }
    }
}

// ===========================================================================
// Handshake (RFC 6455 §4)
// ===========================================================================

// Compute the Sec-WebSocket-Accept value for a client's Sec-WebSocket-Key.
//   accept = base64( sha1( key ++ GUID ) )
// SHA-1 here yields the 20 raw digest bytes (decoded from hash/sha1's hex),
// which are then standard-base64-encoded.
/// Compute the Sec-WebSocket-Accept value (base64(sha1(key ++ GUID))) for a
/// client's Sec-WebSocket-Key.
fn accept-key(client-key) {
    let digest-hex = hash/sha1(client-key ++ WS_GUID)
    let digest-bytes = hex-to-bytes(digest-hex)
    base64/encode(digest-bytes)
}

// Is this http/Request a WebSocket upgrade request? RFC 6455 requires
// Upgrade: websocket and a Connection header that includes "upgrade"
// (case-insensitive), plus a Sec-WebSocket-Key. http stores header keys
// lowercased, so we read them directly.
/// True if the http/Request is a valid RFC 6455 upgrade: Upgrade: websocket,
/// a Connection header containing "upgrade", and a Sec-WebSocket-Key present.
fn is-websocket-upgrade?(request) {
    let upgrade = http/header(request, "upgrade")
    let connection = http/header(request, "connection")
    let key = http/header(request, "sec-websocket-key")
    if upgrade == null || connection == null || key == null {
        false
    } else {
        let upgrade-ok = contains?(lowercase(upgrade), "websocket")
        let connection-ok = contains?(lowercase(connection), "upgrade")
        upgrade-ok && connection-ok
    }
}

// Build the 101 Switching Protocols Response that completes the handshake.
// The caller is responsible for serializing + writing it (or use serve-ws,
// which does the whole dance). Header keys are lowercased to match http's
// convention; http/serialize-response emits them verbatim.
/// Build the 101 Switching Protocols http/Response that completes the
/// handshake; throws if the request has no Sec-WebSocket-Key header.
fn handshake-response(request) {
    let key = http/header(request, "sec-websocket-key")
    if key == null {
        throw("beagle.ws/handshake-response: request has no Sec-WebSocket-Key header")
    } else {
        let accept = accept-key(key)
        http/Response {
            status: 101,
            reason: "Switching Protocols",
            headers: {
                "upgrade" "websocket",
                "connection" "Upgrade",
                "sec-websocket-accept" accept
            },
            body: ""
        }
    }
}

// ===========================================================================
// Frames (RFC 6455 §5)
// ===========================================================================

// A parsed WebSocket frame.
//   fin     — Bool: is this the final fragment?
//   opcode  — Int opcode
//   masked  — Bool: was the payload masked? (client->server frames must be)
//   payload — String: the (unmasked) payload bytes, byte-faithful
/// A parsed WebSocket frame: fin (final-fragment Bool), opcode (Int), masked
/// (Bool: was the payload masked), payload (unmasked byte-faithful String).
struct Frame {
    fin
    opcode
    masked
    payload
}

// Parse a single WebSocket frame from a byte-faithful string `bytes`.
// Decodes FIN/opcode/MASK/length (including the 126 = 16-bit and 127 = 64-bit
// extended length forms) and, if MASK is set, XOR-unmasks the payload with the
// 4-byte masking key. Returns a Frame. Assumes `bytes` contains at least one
// complete frame starting at index 0 (which is the case after read-frame).
/// Parse one complete WebSocket frame from a byte-faithful string starting at
/// index 0, handling 126/127 extended lengths and XOR-unmasking; returns a Frame.
fn parse-frame(bytes) {
    let buf = to-buf(bytes)
    let b0 = buf-byte(buf, 0)
    let b1 = buf-byte(buf, 1)
    let fin = (b0 & 0x80) != 0
    let opcode = b0 & 0x0F
    let masked = (b1 & 0x80) != 0
    let len7 = b1 & 0x7F

    // Determine payload length and where the payload starts.
    let mut payload-len = len7
    let mut offset = 2
    if len7 == 126 {
        // 16-bit extended length.
        payload-len = (buf-byte(buf, 2) << 8) | buf-byte(buf, 3)
        offset = 4
    } else {
        if len7 == 127 {
            // 64-bit extended length. Beagle ints are 62-bit; real-world
            // frames never approach that, so we accumulate all 8 bytes.
            let mut acc = 0
            let mut i = 0
            while i < 8 {
                acc = (acc << 8) | buf-byte(buf, 2 + i)
                i = i + 1
            }
            payload-len = acc
            offset = 10
        }
    }

    // Read the 4-byte masking key if present.
    let mut mask0 = 0
    let mut mask1 = 0
    let mut mask2 = 0
    let mut mask3 = 0
    if masked {
        mask0 = buf-byte(buf, offset)
        mask1 = buf-byte(buf, offset + 1)
        mask2 = buf-byte(buf, offset + 2)
        mask3 = buf-byte(buf, offset + 3)
        offset = offset + 4
    }

    // Extract and unmask the payload, byte by byte.
    let payload-builder = sb/new(payload-len + 1)
    let mut j = 0
    while j < payload-len {
        let raw = buf-byte(buf, offset + j)
        let unmasked = if masked {
            let mask-byte = if (j & 3) == 0 {
                mask0
            } else {
                if (j & 3) == 1 {
                    mask1
                } else {
                    if (j & 3) == 2 {
                        mask2
                    } else {
                        mask3
                    }
                }
            }
            raw ^ mask-byte
        } else {
            raw
        }
        sb/append-byte!(payload-builder, unmasked)
        j = j + 1
    }

    Frame {
        fin: fin,
        opcode: opcode,
        masked: masked,
        payload: sb/to-string(payload-builder)
    }
}

// Encode a server->client frame (unmasked, FIN=1) for the given opcode and
// payload String. Emits the header (FIN+opcode, length using the 126/127
// extended forms when needed) followed by the raw payload bytes. Returns a
// byte-faithful String suitable for socket/write.
/// Encode an unmasked, FIN=1 server->client frame for the given opcode and
/// payload String; returns a byte-faithful String suitable for socket/write.
fn encode-frame(opcode, payload) {
    let payload-buf = to-buf(payload)
    let payload-len = sb/length(payload-buf)
    let builder = sb/new(payload-len + 10)

    // First byte: FIN (0x80) | opcode.
    sb/append-byte!(builder, 0x80 | (opcode & 0x0F))

    // Length byte(s). MASK bit is 0 (servers never mask).
    if payload-len < 126 {
        sb/append-byte!(builder, payload-len)
    } else {
        if payload-len < 65536 {
            sb/append-byte!(builder, 126)
            sb/append-byte!(builder, (payload-len >>> 8) & 0xFF)
            sb/append-byte!(builder, payload-len & 0xFF)
        } else {
            sb/append-byte!(builder, 127)
            // 64-bit big-endian length. Top bytes are 0 for sane sizes; emit
            // all 8 by repeated right shifts.
            let mut shift = 56
            while shift >= 0 {
                sb/append-byte!(builder, (payload-len >>> shift) & 0xFF)
                shift = shift - 8
            }
        }
    }

    // Payload bytes, byte-faithful (copied straight from the payload builder).
    sb/append-builder-range!(builder, payload-buf, 0, payload-len)
    sb/to-string(builder)
}

// Opcode-specialized frame encoders.
/// Encode payload as a text frame (thin encode-frame wrapper).
fn text-frame(payload) {
    encode-frame(opcode-text(), payload)
}

/// Encode payload as a binary frame (thin encode-frame wrapper).
fn binary-frame(payload) {
    encode-frame(opcode-binary(), payload)
}

/// Encode payload as a ping control frame (thin encode-frame wrapper).
fn ping-frame(payload) {
    encode-frame(opcode-ping(), payload)
}

/// Encode payload as a pong control frame (thin encode-frame wrapper).
fn pong-frame(payload) {
    encode-frame(opcode-pong(), payload)
}

// A close frame. RFC 6455 close frames may carry a 2-byte status code; we send
// an empty close payload (a clean, codeless close).
/// Encode an empty (codeless, clean) close frame.
fn close-frame() {
    encode-frame(opcode-close(), "")
}

// Build a close control frame carrying a 2-byte big-endian status code (RFC 6455
// §5.5.1) — e.g. 1000 normal, 1001 going away, 1009 message too big.
/// Build a close frame whose payload is the 2-byte big-endian status `code`.
fn close-frame-status(code) {
    let payload = sb/new(2)
    sb/append-byte!(payload, (code >> 8) & 0xFF)
    sb/append-byte!(payload, code & 0xFF)
    encode-frame(opcode-close(), sb/to-string(payload))
}

// ---------------------------------------------------------------------------
// Client-side (masked) frame encoding
// ---------------------------------------------------------------------------
// RFC 6455 §5.3: every client->server frame MUST be masked with a fresh, random
// 4-byte key; the payload is XORed with the key (key[i mod 4]) and the MASK bit
// (0x80) is set on the length byte. A server that receives an unmasked frame
// must fail the connection, so these encoders are required for a real WS client.

// Encode a masked, FIN=1 client->server frame with an explicit 4-byte key. Kept
// separate so tests can pass a known key; encode-frame-masked generates a random one.
/// Encode a masked client->server frame for `opcode`/`payload` using the explicit
/// 4-byte masking key m0..m3; returns a byte-faithful String for socket/write.
fn encode-frame-masked-with-key(opcode, payload, m0, m1, m2, m3) {
    let payload-buf = to-buf(payload)
    let payload-len = sb/length(payload-buf)
    let builder = sb/new(payload-len + 14)

    // First byte: FIN (0x80) | opcode.
    sb/append-byte!(builder, 0x80 | (opcode & 0x0F))

    // Length byte(s), each with the MASK bit (0x80) set.
    if payload-len < 126 {
        sb/append-byte!(builder, 0x80 | payload-len)
    } else {
        if payload-len < 65536 {
            sb/append-byte!(builder, 0x80 | 126)
            sb/append-byte!(builder, (payload-len >>> 8) & 0xFF)
            sb/append-byte!(builder, payload-len & 0xFF)
        } else {
            sb/append-byte!(builder, 0x80 | 127)
            let mut shift = 56
            while shift >= 0 {
                sb/append-byte!(builder, (payload-len >>> shift) & 0xFF)
                shift = shift - 8
            }
        }
    }

    // 4-byte masking key.
    sb/append-byte!(builder, m0 & 0xFF)
    sb/append-byte!(builder, m1 & 0xFF)
    sb/append-byte!(builder, m2 & 0xFF)
    sb/append-byte!(builder, m3 & 0xFF)

    // XOR-masked payload, byte by byte (key[j mod 4]).
    let mut j = 0
    while j < payload-len {
        let raw = buf-byte(payload-buf, j)
        let mask-byte = if (j & 3) == 0 {
            m0
        } else {
            if (j & 3) == 1 {
                m1
            } else {
                if (j & 3) == 2 {
                    m2
                } else {
                    m3
                }
            }
        }
        sb/append-byte!(builder, (raw ^ mask-byte) & 0xFF)
        j = j + 1
    }
    sb/to-string(builder)
}

// Encode a masked client frame with a fresh random masking key.
/// Encode a masked, FIN=1 client->server frame for `opcode`/`payload`, generating
/// a fresh random 4-byte masking key (required of all client frames).
fn encode-frame-masked(opcode, payload) {
    encode-frame-masked-with-key(
        opcode,
        payload,
        core/random-int(256),
        core/random-int(256),
        core/random-int(256),
        core/random-int(256)
    )
}

/// Encode a masked client text frame.
fn text-frame-masked(payload) {
    encode-frame-masked(opcode-text(), payload)
}

/// Encode a masked client binary frame.
fn binary-frame-masked(payload) {
    encode-frame-masked(opcode-binary(), payload)
}

/// Encode a masked client ping frame.
fn ping-frame-masked(payload) {
    encode-frame-masked(opcode-ping(), payload)
}

/// Encode a masked client pong frame.
fn pong-frame-masked(payload) {
    encode-frame-masked(opcode-pong(), payload)
}

/// Encode a masked client close frame (empty payload).
fn close-frame-masked() {
    encode-frame-masked(opcode-close(), "")
}

// ---------------------------------------------------------------------------
// Close-frame status code / reason
// ---------------------------------------------------------------------------

// Extract the close status code from a parsed close Frame. RFC 6455 §5.5.1: an
// empty close payload means "no status" — reported as 1005; otherwise the first
// two payload bytes are the big-endian code (1000 normal, 1001 going away,
// 1009 message too big, ...).
/// Return the close status code from a close Frame (1005 if the payload carries
/// no code).
fn close-code(frame) {
    let buf = to-buf(frame.payload)
    if sb/length(buf) < 2 {
        1005
    } else {
        (buf-byte(buf, 0) << 8) | buf-byte(buf, 1)
    }
}

// The optional UTF-8 reason string following the 2-byte code in a close payload.
/// Return the close reason text (the payload after the 2-byte code), or "" if absent.
fn close-reason(frame) {
    let total = sb/byte-length(frame.payload)
    if total <= 2 {
        ""
    } else {
        sb/byte-slice(frame.payload, 2, total)
    }
}

// Opcode predicates for dispatching parsed frames.
/// True if the parsed frame is a text frame.
fn text?(frame) { frame.opcode == opcode-text() }
/// True if the parsed frame is a binary frame.
fn binary?(frame) { frame.opcode == opcode-binary() }
/// True if the parsed frame is a ping frame.
fn ping?(frame) { frame.opcode == opcode-ping() }
/// True if the parsed frame is a pong frame.
fn pong?(frame) { frame.opcode == opcode-pong() }
/// True if the parsed frame is a close frame.
fn close?(frame) { frame.opcode == opcode-close() }
/// True if the parsed frame is a continuation frame (opcode 0x0).
fn continuation?(frame) { frame.opcode == opcode-continuation() }

// ===========================================================================
// Fragmentation reassembly (RFC 6455 §5.4)
// ===========================================================================
//
// A WebSocket MESSAGE may be split across frames: a data frame (text/binary)
// with fin=false, then zero or more continuation frames, the last with fin=true.
// The payloads concatenate. Control frames (close/ping/pong) may be interleaved
// and are NOT part of the data stream — filter them out before reassembling.

// Advance fragmentation state by one DATA/CONTINUATION frame. `cur-opcode` is
// the in-progress message's opcode (null when not mid-message) and `cur-payload`
// its accumulated bytes. Returns [new-opcode, new-payload, message-or-null],
// where message (when non-null) is {:opcode, :payload} for a now-complete message.
/// Pure fragmentation step: fold one data/continuation frame into the current
/// (opcode, payload) state, emitting a completed {:opcode, :payload} on a fin frame.
fn frag-step(cur-opcode, cur-payload, frame) {
    if continuation?(frame) {
        let payload = cur-payload ++ frame.payload
        if frame.fin {
            [null, "", { :opcode cur-opcode, :payload payload }]
        } else {
            [cur-opcode, payload, null]
        }
    } else {
        if frame.fin {
            [null, "", { :opcode frame.opcode, :payload frame.payload }]
        } else {
            [frame.opcode, frame.payload, null]
        }
    }
}

// Reassemble a sequence of DATA/CONTINUATION frames into the list of complete
// messages ({:opcode, :payload}). Pure — the same logic the server loop uses.
/// Reassemble a list of data/continuation frames into complete messages
/// ({:opcode, :payload}); single (fin=true) frames pass through as one message each.
fn reassemble(frames) {
    reassemble-helper(frames, 0, null, "", [])
}

/// Internal fold for reassemble.
fn reassemble-helper(frames, i, cur-opcode, cur-payload, out) {
    if i >= length(frames) {
        out
    } else {
        let stepped = frag-step(cur-opcode, cur-payload, frames[i])
        let msg = stepped[2]
        let new-out = if msg == null { out } else { push(out, msg) }
        reassemble-helper(frames, i + 1, stepped[0], stepped[1], new-out)
    }
}

// ===========================================================================
// Streaming frame reads from a live socket
// ===========================================================================

// Byte-exact frame reads go through socket's buffered Reader (socket/read-n-buf),
// the same byte layer the http parser uses — ws no longer reimplements it. The
// reader buffers, so handshake over-reads are preserved into the frame loop.

// Returned by read-frame-max when a frame declares a payload larger than the
// configured cap — BEFORE the (huge) payload is read, so an oversized frame
// can't make the server allocate unbounded memory. The server replies with a
// 1009 (Message Too Big) close and ends the connection.
/// Marker for a frame whose declared payload exceeds the max-frame cap. `limit`
/// is the configured cap; `declared` is the frame's claimed payload length.
struct FrameTooBig { limit, declared }

/// True if a read-frame result is the oversized-frame marker.
fn frame-too-big?(f) {
    instance-of(f, FrameTooBig)
}

// Read one complete WebSocket frame off the socket and parse it. Returns a
// Frame, or null at EOF (connection closed before a full header arrived).
/// Read and parse one complete WebSocket frame off the connection reader;
/// returns a Frame, or null at EOF (connection closed before a full header
/// arrived). `r` is a socket/Reader (shared with the handshake so no bytes are lost).
fn read-frame(r) {
    read-frame-max(r, null)
}

/// Like read-frame, but if the frame declares a payload larger than `max-frame`
/// bytes (null = unlimited), returns a FrameTooBig marker WITHOUT reading the
/// payload — so an oversized frame can't trigger an unbounded allocation.
fn read-frame-max(r, max-frame) {
    // socket/read-n-buf returns the bytes wrapped in a byte-faithful builder so
    // we can read header bytes by index without tripping over UTF-8 decoding.
    let head = socket/read-n-buf(r, 2)
    if sb/length(head) < 2 {
        null
    } else {
        let b1 = buf-byte(head, 1)
        let masked = (b1 & 0x80) != 0
        let len7 = b1 & 0x7F

        // Read any extended-length bytes.
        let mut payload-len = len7
        let mut ext = sb/new(1)
        if len7 == 126 {
            ext = socket/read-n-buf(r, 2)
            payload-len = (buf-byte(ext, 0) << 8) | buf-byte(ext, 1)
        } else {
            if len7 == 127 {
                ext = socket/read-n-buf(r, 8)
                let mut acc = 0
                let mut i = 0
                while i < 8 {
                    acc = (acc << 8) | buf-byte(ext, i)
                    i = i + 1
                }
                payload-len = acc
            }
        }

        // Enforce the frame cap BEFORE reading the mask/payload (don't allocate
        // for an oversized frame; the caller closes 1009 and drops the connection).
        if max-frame != null && payload-len > max-frame {
            FrameTooBig { limit: max-frame, declared: payload-len }
        } else {
            let mask = if masked { socket/read-n-buf(r, 4) } else { sb/new(1) }
            let payload = socket/read-n-buf(r, payload-len)

            // Reassemble the whole frame into one builder and hand it to
            // parse-frame, which owns the unmasking logic (single source of truth).
            let whole = sb/new(2 + sb/length(ext) + sb/length(mask) + payload-len + 1)
            sb/append-builder-range!(whole, head, 0, sb/length(head))
            sb/append-builder-range!(whole, ext, 0, sb/length(ext))
            sb/append-builder-range!(whole, mask, 0, sb/length(mask))
            sb/append-builder-range!(whole, payload, 0, sb/length(payload))
            parse-frame(sb/to-string(whole))
        }
    }
}

// ===========================================================================
// Server
// ===========================================================================

// Perform the HTTP upgrade handshake on an accepted connection. Reads the HTTP
// request; if it is a valid WebSocket upgrade, writes the 101 response and
// returns true. Otherwise writes a 400 and returns false.
/// Perform the HTTP upgrade handshake using reader `r`: read the upgrade request
/// through the SAME buffered reader the frame loop uses (so any bytes read past
/// the request stay buffered for the first frame), and write via r.conn. On a
/// valid WebSocket upgrade, write the 101 response and return true; otherwise
/// write a 400 and return false.
fn do-handshake(r) {
    let req = http/read-request(r)
    if req == null {
        false
    } else {
        if is-websocket-upgrade?(req) {
            let resp = handshake-response(req)
            socket/write(r.conn, http/serialize-response(resp))
            true
        } else {
            socket/write(r.conn, http/serialize-response(http/status-response(400, "Expected WebSocket upgrade")))
            false
        }
    }
}

// Cooperative single-thread WebSocket server. Accepts one connection at a
// time, performs the upgrade, then runs a read loop on that connection:
//   - text/binary frames -> call (on-message conn payload); if it returns a
//     non-null String, that string is sent back as a text frame.
//   - ping  -> reply with a pong carrying the same payload.
//   - close -> reply with a close frame and end the connection.
// Everything runs on the calling thread (no thread-per-connection), so it is
// GC-safe. Blocks forever.
// Default max WebSocket frame payload accepted by the server: 1 MB. An inbound
// frame declaring more is rejected with a 1009 close (Message Too Big).
let default-max-frame-bytes = 1048576

/// Cooperative WebSocket server: each connection is upgraded and runs its frame
/// loop as its own cooperative task (via socket/on-connection), so a slow client
/// can't block others. A frame over the default size cap is rejected (close 1009).
/// GC-safe; blocks forever.
fn serve-ws(host, port, on-message) {
    serve-ws-with(host, port, {}, on-message)
}

// Run a cooperative WebSocket server with options. `opts` keys:
//   :max-frame-bytes  max inbound frame payload (default 1048576) -> close 1009
/// Cooperative WebSocket server with an options map (`:max-frame-bytes`) plus the
/// on-message handler. Like serve-ws, but lets you tune the max frame size.
fn serve-ws-with(host, port, opts, on-message) {
    let max-frame = core/get(opts, :max-frame-bytes, default-max-frame-bytes)
    let listener = socket/listen(host, port)
    println("beagle.ws serving on " ++ host ++ ":" ++ to-string(port))
    socket/on-connection(listener, fn(conn) {
        handle-ws-connection(conn, on-message, max-frame)
    })
}

// Handle a single upgraded connection's frame loop. Isolated in a try so one
// bad client never takes down the accept loop.
/// Run one upgraded connection's frame loop (text/binary -> on-message reply,
/// ping -> pong, close -> close, oversized frame -> close 1009), isolated in a
/// try so one bad client can't kill the accept loop; closes the connection on exit.
fn handle-ws-connection(conn, on-message, max-frame) {
    try {
        // One buffered reader for the whole connection: the handshake and every
        // frame read share it, so bytes read past the upgrade request are not lost.
        let r = socket/reader(conn)
        if do-handshake(r) {
            let mut open = true
            // Fragmentation state: cur-opcode is null unless mid-message.
            let mut cur-opcode = null
            let mut cur-payload = ""
            while open {
                let frame = read-frame-max(r, max-frame)
                if frame == null {
                    open = false
                } else {
                    if frame-too-big?(frame) {
                        // Oversized frame: tell the client (1009) and end. The
                        // unread payload is dropped when the connection closes.
                        socket/write(conn, close-frame-status(1009))
                        open = false
                    } else {
                    if close?(frame) {
                        // Control frames may arrive between data fragments; handle inline.
                        socket/write(conn, close-frame())
                        open = false
                    } else {
                        if ping?(frame) {
                            socket/write(conn, pong-frame(frame.payload))
                        } else {
                            if pong?(frame) {
                                null   // pongs are unsolicited acks; ignore
                            } else {
                                // text / binary / continuation: fold into the
                                // message, delivering only when fin completes it.
                                let stepped = frag-step(cur-opcode, cur-payload, frame)
                                cur-opcode = stepped[0]
                                cur-payload = stepped[1]
                                let msg = stepped[2]
                                if msg != null {
                                    let reply = on-message(conn, get(msg, :payload))
                                    if reply != null {
                                        socket/write(conn, text-frame(reply))
                                    }
                                }
                            }
                        }
                    }
                    }
                }
            }
        }
    } catch (e) {
        null
    }
    try {
        socket/close(conn)
    } catch (e) {
        null
    }
    null
}

// ===========================================================================
// Client
// ===========================================================================
//
// A WebSocket CLIENT: opens a TCP (ws://) or TLS (wss://) connection, performs
// the RFC 6455 HTTP Upgrade handshake (random Sec-WebSocket-Key, verifies the
// server's Sec-WebSocket-Accept), then exchanges frames. Client->server frames
// MUST be masked (handled by the *-frame-masked encoders); inbound server frames
// are unmasked. Built on the async socket/TLS layers, so it parks like any other
// I/O (concurrent, with-timeout-able).

/// A live client WebSocket connection: the transport (TcpSocket or TlsConn), the
/// buffered reader over it (shared with the frame loop), and whether it is TLS.
struct WsConn {
    transport
    reader
    secure
}

// A fresh Sec-WebSocket-Key: 16 random bytes, standard-base64-encoded (RFC 6455
// §4.1). The server echoes base64(sha1(key ++ GUID)) in Sec-WebSocket-Accept.
fn gen-ws-key() {
    let b = sb/new(16)
    let mut i = 0
    while i < 16 {
        sb/append-byte!(b, core/random-int(256))
        i = i + 1
    }
    base64/encode(sb/to-string(b))
}

// Write raw bytes over the transport (TLS or plain).
fn ws-write-raw(transport, secure, bytes) {
    if secure {
        tls/write(transport, bytes)
    } else {
        socket/write(transport, bytes)
    }
}

// Close the transport (TLS or plain), tolerating errors.
fn ws-close-transport(transport, secure) {
    try {
        if secure {
            tls/close(transport)
        } else {
            socket/close(transport)
        }
    } catch (e) {
        null
    }
}

// Build the RFC 6455 client Upgrade request for host:port/path with key `key`.
fn build-upgrade-request(host, port, path, key) {
    let b = sb/new(256)
    sb/append!(b, "GET ")
    sb/append!(b, path)
    sb/append!(b, " HTTP/1.1\r\n")
    sb/append!(b, "Host: ")
    sb/append!(b, host)
    sb/append!(b, ":")
    sb/append-int!(b, port)
    sb/append!(b, "\r\n")
    sb/append!(b, "Upgrade: websocket\r\n")
    sb/append!(b, "Connection: Upgrade\r\n")
    sb/append!(b, "Sec-WebSocket-Key: ")
    sb/append!(b, key)
    sb/append!(b, "\r\n")
    sb/append!(b, "Sec-WebSocket-Version: 13\r\n")
    sb/append!(b, "\r\n")
    sb/to-string(b)
}

// Read the server's handshake response off `reader` and verify it is a valid 101
// upgrade whose Sec-WebSocket-Accept matches our key. Returns true iff accepted.
fn verify-handshake-response(reader, key) {
    let status-line = socket/read-line(reader)
    if status-line == null {
        false
    } else {
        let headers = http/read-headers(reader)
        let accept = core/get(headers, "sec-websocket-accept")
        let is-101 = index-of(status-line, " 101") >= 0
        is-101 && accept != null && accept == accept-key(key)
    }
}

/// Open a client WebSocket connection to `url` (ws://host:port/path or
/// wss://... for TLS), performing the upgrade handshake. Returns a WsConn.
/// Throws if the connect, handshake, or Sec-WebSocket-Accept check fails.
///
/// Examples:
///   let c = connect("ws://127.0.0.1:9001/chat")
///   send(c, "hello")
///   let reply = receive(c)
///   close(c)
fn connect(url) {
    let u = url/parse-url(url)
    let secure = lowercase(u.scheme) == "wss"
    let port = if u.port == null {
        if secure { 443 } else { 80 }
    } else {
        u.port
    }
    let path = if length(u.path) == 0 { "/" } else { u.path }
    let full-path = if u.query == null { path } else { path ++ "?" ++ u.query }

    let transport = if secure {
        tls/connect(u.host, port)
    } else {
        socket/connect(u.host, port)
    }
    // A reader over the transport (TLS reads route through tls/read).
    let reader = if secure {
        socket/reader-with(transport, fn(n) { tls/read(transport, n) })
    } else {
        socket/reader(transport)
    }

    let key = gen-ws-key()
    ws-write-raw(transport, secure, build-upgrade-request(u.host, port, full-path, key))

    if verify-handshake-response(reader, key) {
        WsConn { transport: transport, reader: reader, secure: secure }
    } else {
        ws-close-transport(transport, secure)
        throw("beagle.ws/connect: handshake failed (server did not complete the WebSocket upgrade)")
    }
}

/// Send `text` as a masked text frame over the client connection.
fn send(c, text) {
    ws-write-raw(c.transport, c.secure, text-frame-masked(text))
}

/// Send `data` as a masked binary frame over the client connection.
fn send-binary(c, data) {
    ws-write-raw(c.transport, c.secure, binary-frame-masked(data))
}

/// Send a masked ping frame carrying `payload`.
fn ping(c, payload) {
    ws-write-raw(c.transport, c.secure, ping-frame-masked(payload))
}

// Continuation accumulation: gather continuation frames until the FIN frame,
// auto-answering any interleaved pings. Returns the full reassembled payload.
fn receive-continuation(c, acc) {
    let frame = read-frame(c.reader)
    if frame == null {
        acc
    } else {
        if ping?(frame) {
            ws-write-raw(c.transport, c.secure, pong-frame-masked(frame.payload))
            receive-continuation(c, acc)
        } else {
            if frame.fin {
                acc ++ frame.payload
            } else {
                receive-continuation(c, acc ++ frame.payload)
            }
        }
    }
}

/// Receive the next application message (text or binary payload, byte-faithful)
/// from the connection, reassembling fragments. Control frames are handled
/// transparently: a ping is auto-answered with a pong, a pong is ignored, and a
/// close is acknowledged. Returns null when the peer closes or at EOF.
fn receive(c) {
    let frame = read-frame(c.reader)
    if frame == null {
        null
    } else {
        if ping?(frame) {
            ws-write-raw(c.transport, c.secure, pong-frame-masked(frame.payload))
            receive(c)
        } else {
            if pong?(frame) {
                receive(c)
            } else {
                if close?(frame) {
                    try {
                        ws-write-raw(c.transport, c.secure, close-frame-masked())
                    } catch (e) {
                        null
                    }
                    null
                } else {
                    if frame.fin {
                        frame.payload
                    } else {
                        receive-continuation(c, frame.payload)
                    }
                }
            }
        }
    }
}

/// Close the client WebSocket connection: send a masked close frame, then close
/// the underlying transport.
fn close(c) {
    try {
        ws-write-raw(c.transport, c.secure, close-frame-masked())
    } catch (e) {
        null
    }
    ws-close-transport(c.transport, c.secure)
}

