namespace beagle.hash

use beagle.mutable-array as arr
use beagle.string-builder as sb

// Pure-Beagle MD5, SHA-1, SHA-256, SHA-512, and HMAC.
//
// Input: either a Beagle String (hashed as its UTF-8 bytes) or a
// Vec<Int> of byte values (0..255). Output: a lowercase hex String.
//
// All 32-bit arithmetic is masked with & 0xFFFFFFFF, because Beagle ints
// are 62-bit and do NOT auto-wrap. SHA-512 needs true 64-bit words; we
// emulate each as a pair of 32-bit halves (see the W64 section below).

let MASK32 = 0xFFFFFFFF

// ---- byte input normalization ----------------------------------------

// Turn the input (String or Vec<Int>) into a Vec<Int> of byte values.
/// Normalizes hash input into a Vec<Int> of byte values (0..255). A String is
/// converted to its UTF-8 bytes; a Vec<Int> has each element masked to a byte.
fn to-bytes(input) {
    if instance-of(input, String) {
        // A String is hashed as its UTF-8 bytes. We obtain those bytes by
        // appending the string to a string-builder (which stores the raw
        // UTF-8 encoding) and reading them back one byte at a time. This is
        // correct for multibyte characters; masking codepoints to a u8 is not.
        let builder = sb/new(length(input) + 1)
        sb/append!(builder, input)
        let n = sb/length(builder)
        let mut out = []
        let mut i = 0
        while i < n {
            out = push(out, sb/byte-at(builder, i))
            i = i + 1
        }
        out
    } else {
        // assume Vec<Int> already; mask each to a byte for safety
        let n = length(input)
        let mut out = []
        let mut i = 0
        while i < n {
            out = push(out, input[i] & 0xFF)
            i = i + 1
        }
        out
    }
}

// ---- 32-bit helpers --------------------------------------------------

/// Adds two 32-bit words modulo 2^32 (result masked to 32 bits).
fn add32(a, b) {
    (a + b) & MASK32
}

/// Rotates the 32-bit word `x` left by `n` bits.
fn rotl32(x, n) {
    ((x << n) | (x >>> (32 - n))) & MASK32
}

/// Rotates the 32-bit word `x` right by `n` bits.
fn rotr32(x, n) {
    ((x >>> n) | (x << (32 - n))) & MASK32
}

// lower-case hex of one 32-bit word, 8 digits, big-endian.
let HEXCHARS = "0123456789abcdef"

/// Appends `word` to `builder` as 8 lowercase big-endian hex digits. Returns the builder.
fn append-hex32!(builder, word) {
    let mut shift = 28
    while shift >= 0 {
        let nibble = (word >>> shift) & 0xF
        sb/append!(builder, HEXCHARS[nibble])
        shift = shift - 4
    }
    builder
}

/// Appends `byte` to `builder` as 2 lowercase hex digits. Returns the builder.
fn append-hex8!(builder, byte) {
    sb/append!(builder, HEXCHARS[(byte >>> 4) & 0xF])
    sb/append!(builder, HEXCHARS[byte & 0xF])
    builder
}

// ---- padding (big-endian length: SHA-1 / SHA-256) --------------------

// Append SHA padding (the 0x80 byte, zero bytes, then the 64-bit
// big-endian bit length) onto a copy of the byte vector. Returns a new
// Vec<Int> whose length is a multiple of 64.
/// Applies SHA-1/SHA-256 (big-endian) message padding to `bytes`, returning a
/// new Vec<Int> whose length is a multiple of 64.
fn pad-message(bytes) {
    let msg-len = length(bytes)
    let bit-len = msg-len * 8
    let mut out = bytes
    // append 0x80
    out = push(out, 0x80)
    // pad with zeros until length % 64 == 56
    while (length(out) % 64) != 56 {
        out = push(out, 0)
    }
    // append 64-bit big-endian bit length.
    // bit-len can exceed 32 bits; split into high/low 32-bit halves
    // using division/modulo to avoid relying on >32-bit shifts.
    let low = bit-len & MASK32
    let high = (bit-len / 4294967296) & MASK32
    out = push(out, (high >>> 24) & 0xFF)
    out = push(out, (high >>> 16) & 0xFF)
    out = push(out, (high >>> 8) & 0xFF)
    out = push(out, high & 0xFF)
    out = push(out, (low >>> 24) & 0xFF)
    out = push(out, (low >>> 16) & 0xFF)
    out = push(out, (low >>> 8) & 0xFF)
    out = push(out, low & 0xFF)
    out
}

// Read a big-endian 32-bit word from bytes starting at index `i`.
/// Reads a big-endian 32-bit word from `bytes` at index `i`.
fn word-be(bytes, i) {
    ((bytes[i] << 24) | (bytes[i + 1] << 16) | (bytes[i + 2] << 8) | bytes[i + 3]) & MASK32
}

// Read a little-endian 32-bit word (MD5).
/// Reads a little-endian 32-bit word from `bytes` at index `i` (used by MD5).
fn word-le(bytes, i) {
    (bytes[i] | (bytes[i + 1] << 8) | (bytes[i + 2] << 16) | (bytes[i + 3] << 24)) & MASK32
}

// =====================================================================
// MD5 (RFC 1321)
// =====================================================================
//
// MD5 is little-endian: words are read little-endian, the appended bit
// length is little-endian, and the final digest words are emitted
// byte-reversed. Everything else is plain 32-bit arithmetic, reusing
// add32 / rotl32. 64 rounds, 4 working words.

// Padding with LITTLE-endian 64-bit bit length. Block size is 64 bytes.
/// MD5 message padding: like pad-message but with a little-endian 64-bit bit-length field.
fn pad-message-le(bytes) {
    let msg-len = length(bytes)
    let bit-len = msg-len * 8
    let mut out = bytes
    out = push(out, 0x80)
    while (length(out) % 64) != 56 {
        out = push(out, 0)
    }
    let low = bit-len & MASK32
    let high = (bit-len / 4294967296) & MASK32
    // little-endian: low byte first, low word before high word
    out = push(out, low & 0xFF)
    out = push(out, (low >>> 8) & 0xFF)
    out = push(out, (low >>> 16) & 0xFF)
    out = push(out, (low >>> 24) & 0xFF)
    out = push(out, high & 0xFF)
    out = push(out, (high >>> 8) & 0xFF)
    out = push(out, (high >>> 16) & 0xFF)
    out = push(out, (high >>> 24) & 0xFF)
    out
}

// Per-round shift amounts s[0..63].
/// Returns the 64 per-round left-rotate amounts for MD5.
fn md5-s() {
    [
        7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22, 7, 12, 17, 22,
        5, 9, 14, 20, 5, 9, 14, 20, 5, 9, 14, 20, 5, 9, 14, 20,
        4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23, 4, 11, 16, 23,
        6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21, 6, 10, 15, 21
    ]
}

// Per-round constants K[i] = floor(abs(sin(i+1)) * 2^32).
/// Returns the 64 MD5 round constants K[i] = floor(abs(sin(i+1)) * 2^32).
fn md5-k() {
    [
        0xD76AA478, 0xE8C7B756, 0x242070DB, 0xC1BDCEEE,
        0xF57C0FAF, 0x4787C62A, 0xA8304613, 0xFD469501,
        0x698098D8, 0x8B44F7AF, 0xFFFF5BB1, 0x895CD7BE,
        0x6B901122, 0xFD987193, 0xA679438E, 0x49B40821,
        0xF61E2562, 0xC040B340, 0x265E5A51, 0xE9B6C7AA,
        0xD62F105D, 0x02441453, 0xD8A1E681, 0xE7D3FBC8,
        0x21E1CDE6, 0xC33707D6, 0xF4D50D87, 0x455A14ED,
        0xA9E3E905, 0xFCEFA3F8, 0x676F02D9, 0x8D2A4C8A,
        0xFFFA3942, 0x8771F681, 0x6D9D6122, 0xFDE5380C,
        0xA4BEEA44, 0x4BDECFA9, 0xF6BB4B60, 0xBEBFBC70,
        0x289B7EC6, 0xEAA127FA, 0xD4EF3085, 0x04881D05,
        0xD9D4D039, 0xE6DB99E5, 0x1FA27CF8, 0xC4AC5665,
        0xF4292244, 0x432AFF97, 0xAB9423A7, 0xFC93A039,
        0x655B59C3, 0x8F0CCC92, 0xFFEFF47D, 0x85845DD1,
        0x6FA87E4F, 0xFE2CE6E0, 0xA3014314, 0x4E0811A1,
        0xF7537E82, 0xBD3AF235, 0x2AD7D2BB, 0xEB86D391
    ]
}

// The MD5 round-shift and round-constant tables, built ONCE at load and reused
// by every digest (the md5-s()/md5-k() helpers rebuilt them on every call).
let MD5_S = md5-s()
let MD5_K = md5-k()

/// Runs the MD5 compression over `raw-bytes`, returning the digest as a Vec of 4 words.
fn md5-digest-words(raw-bytes) {
    let bytes = pad-message-le(raw-bytes)
    let total = length(bytes)
    let s = MD5_S
    let k = MD5_K

    let mut a0 = 0x67452301
    let mut b0 = 0xEFCDAB89
    let mut c0 = 0x98BADCFE
    let mut d0 = 0x10325476

    let m = arr/new-array(16)

    let mut block = 0
    while block < total {
        let mut t = 0
        while t < 16 {
            arr/write-field(m, t, word-le(bytes, block + t * 4))
            t = t + 1
        }

        let mut a = a0
        let mut b = b0
        let mut c = c0
        let mut d = d0

        let mut i = 0
        while i < 64 {
            let mut f = 0
            let mut g = 0
            if i < 16 {
                f = (b & c) | ((b ^ MASK32) & d)
                g = i
            } else {
                if i < 32 {
                    f = (d & b) | ((d ^ MASK32) & c)
                    g = (5 * i + 1) % 16
                } else {
                    if i < 48 {
                        f = b ^ c ^ d
                        g = (3 * i + 5) % 16
                    } else {
                        f = c ^ (b | (d ^ MASK32))
                        g = (7 * i) % 16
                    }
                }
            }
            f = add32(add32(f, a), add32(k[i], arr/read-field(m, g)))
            a = d
            d = c
            c = b
            b = add32(b, rotl32(f, s[i]))
            i = i + 1
        }

        a0 = add32(a0, a)
        b0 = add32(b0, b)
        c0 = add32(c0, c)
        d0 = add32(d0, d)

        block = block + 64
    }

    [a0, b0, c0, d0]
}

// Emit a 32-bit word byte-reversed (little-endian) as 8 hex digits.
/// Appends `word` to `builder` byte-reversed (little-endian) as 8 hex digits. Returns the builder.
fn append-hex32-le!(builder, word) {
    append-hex8!(builder, word & 0xFF)
    append-hex8!(builder, (word >>> 8) & 0xFF)
    append-hex8!(builder, (word >>> 16) & 0xFF)
    append-hex8!(builder, (word >>> 24) & 0xFF)
    builder
}

/// Computes the MD5 hash of `input` (String or Vec<Int>), returning a 32-char lowercase hex String.
fn md5(input) {
    let words = md5-digest-words(to-bytes(input))
    let out = sb/new(32)
    let mut i = 0
    while i < length(words) {
        append-hex32-le!(out, words[i])
        i = i + 1
    }
    sb/to-string(out)
}

// MD5 digest as a Vec of 16 bytes (little-endian per word), for HMAC.
/// MD5 digest of `raw-bytes` as a Vec of 16 bytes (little-endian per word), for HMAC.
fn md5-digest-bytes(raw-bytes) {
    let words = md5-digest-words(raw-bytes)
    let mut out = []
    let mut i = 0
    while i < length(words) {
        let w = words[i]
        out = push(out, w & 0xFF)
        out = push(out, (w >>> 8) & 0xFF)
        out = push(out, (w >>> 16) & 0xFF)
        out = push(out, (w >>> 24) & 0xFF)
        i = i + 1
    }
    out
}

// =====================================================================
// SHA-1
// =====================================================================

/// Computes the SHA-1 hash of `input` (String or Vec<Int>), returning a 40-char lowercase hex String.
fn sha1(input) {
    let bytes = pad-message(to-bytes(input))
    let total = length(bytes)

    let mut h0 = 0x67452301
    let mut h1 = 0xEFCDAB89
    let mut h2 = 0x98BADCFE
    let mut h3 = 0x10325476
    let mut h4 = 0xC3D2E1F0

    let w = arr/new-array(80)

    let mut block = 0
    while block < total {
        // load 16 words
        let mut t = 0
        while t < 16 {
            arr/write-field(w, t, word-be(bytes, block + t * 4))
            t = t + 1
        }
        // extend to 80 words
        t = 16
        while t < 80 {
            let v = arr/read-field(w, t - 3) ^ arr/read-field(w, t - 8) ^ arr/read-field(w, t - 14) ^ arr/read-field(w, t - 16)
            arr/write-field(w, t, rotl32(v, 1))
            t = t + 1
        }

        let mut a = h0
        let mut b = h1
        let mut c = h2
        let mut d = h3
        let mut e = h4

        t = 0
        while t < 80 {
            let mut f = 0
            let mut k = 0
            if t < 20 {
                f = (b & c) | ((b ^ MASK32) & d)
                k = 0x5A827999
            } else {
                if t < 40 {
                    f = b ^ c ^ d
                    k = 0x6ED9EBA1
                } else {
                    if t < 60 {
                        f = (b & c) | (b & d) | (c & d)
                        k = 0x8F1BBCDC
                    } else {
                        f = b ^ c ^ d
                        k = 0xCA62C1D6
                    }
                }
            }
            let temp = add32(add32(add32(rotl32(a, 5), f), add32(e, k)), arr/read-field(w, t))
            e = d
            d = c
            c = rotl32(b, 30)
            b = a
            a = temp
            t = t + 1
        }

        h0 = add32(h0, a)
        h1 = add32(h1, b)
        h2 = add32(h2, c)
        h3 = add32(h3, d)
        h4 = add32(h4, e)

        block = block + 64
    }

    let out = sb/new(40)
    append-hex32!(out, h0)
    append-hex32!(out, h1)
    append-hex32!(out, h2)
    append-hex32!(out, h3)
    append-hex32!(out, h4)
    sb/to-string(out)
}

// =====================================================================
// SHA-256
// =====================================================================

// Run SHA-256 over a Vec<Int> of bytes, returning a Vec of 8 words.
/// Runs SHA-256 over a Vec<Int> of bytes, returning the digest as a Vec of 8 words.
fn sha256-digest-words(raw-bytes) {
    let bytes = pad-message(raw-bytes)
    let total = length(bytes)

    let k = sha256-k()

    let mut h0 = 0x6A09E667
    let mut h1 = 0xBB67AE85
    let mut h2 = 0x3C6EF372
    let mut h3 = 0xA54FF53A
    let mut h4 = 0x510E527F
    let mut h5 = 0x9B05688C
    let mut h6 = 0x1F83D9AB
    let mut h7 = 0x5BE0CD19

    let w = arr/new-array(64)

    let mut block = 0
    while block < total {
        let mut t = 0
        while t < 16 {
            arr/write-field(w, t, word-be(bytes, block + t * 4))
            t = t + 1
        }
        t = 16
        while t < 64 {
            let w15 = arr/read-field(w, t - 15)
            let w2 = arr/read-field(w, t - 2)
            let s0 = rotr32(w15, 7) ^ rotr32(w15, 18) ^ (w15 >>> 3)
            let s1 = rotr32(w2, 17) ^ rotr32(w2, 19) ^ (w2 >>> 10)
            let v = add32(add32(arr/read-field(w, t - 16), s0), add32(arr/read-field(w, t - 7), s1))
            arr/write-field(w, t, v)
            t = t + 1
        }

        let mut a = h0
        let mut b = h1
        let mut c = h2
        let mut d = h3
        let mut e = h4
        let mut f = h5
        let mut g = h6
        let mut hh = h7

        t = 0
        while t < 64 {
            let big-s1 = rotr32(e, 6) ^ rotr32(e, 11) ^ rotr32(e, 25)
            let ch = (e & f) ^ ((e ^ MASK32) & g)
            let temp1 = add32(add32(add32(hh, big-s1), add32(ch, k[t])), arr/read-field(w, t))
            let big-s0 = rotr32(a, 2) ^ rotr32(a, 13) ^ rotr32(a, 22)
            let maj = (a & b) ^ (a & c) ^ (b & c)
            let temp2 = add32(big-s0, maj)

            hh = g
            g = f
            f = e
            e = add32(d, temp1)
            d = c
            c = b
            b = a
            a = add32(temp1, temp2)
            t = t + 1
        }

        h0 = add32(h0, a)
        h1 = add32(h1, b)
        h2 = add32(h2, c)
        h3 = add32(h3, d)
        h4 = add32(h4, e)
        h5 = add32(h5, f)
        h6 = add32(h6, g)
        h7 = add32(h7, hh)

        block = block + 64
    }

    [h0, h1, h2, h3, h4, h5, h6, h7]
}

/// Concatenates a Vec of 32-bit words into a big-endian lowercase hex String.
fn words-to-hex(words) {
    let out = sb/new(64)
    let mut i = 0
    while i < length(words) {
        append-hex32!(out, words[i])
        i = i + 1
    }
    sb/to-string(out)
}

/// Computes the SHA-256 hash of `input` (String or Vec<Int>), returning a 64-char lowercase hex String.
fn sha256(input) {
    words-to-hex(sha256-digest-words(to-bytes(input)))
}

// SHA-256 round constants.
/// Returns the 64 SHA-256 round constants.
fn sha256-k() {
    [
        0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5,
        0x3956C25B, 0x59F111F1, 0x923F82A4, 0xAB1C5ED5,
        0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3,
        0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174,
        0xE49B69C1, 0xEFBE4786, 0x0FC19DC6, 0x240CA1CC,
        0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA,
        0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7,
        0xC6E00BF3, 0xD5A79147, 0x06CA6351, 0x14292967,
        0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13,
        0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85,
        0xA2BFE8A1, 0xA81A664B, 0xC24B8B70, 0xC76C51A3,
        0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070,
        0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5,
        0x391C0CB3, 0x4ED8AA4A, 0x5B9CCA4F, 0x682E6FF3,
        0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208,
        0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2
    ]
}

// =====================================================================
// SHA-512  (64-bit words emulated as {hi, lo} pairs)
// =====================================================================
//
// Beagle ints are 62-bit and don't wrap, so a true 64-bit word can't be
// held in a single int with reliable masking on shifts. We represent
// each 64-bit word as a W64 struct of two 32-bit halves (hi = upper 32
// bits, lo = lower 32 bits), and implement every 64-bit operation SHA-512
// needs over those halves:
//
//   xor64 / and64 / not64  : independent on each half
//   add64                  : add halves, carry the lo overflow into hi
//   shr64(x,n)             : logical right shift across the 64-bit pair
//   shl64(x,n)             : left shift across the pair
//   rotr64(x,n)            : right rotation = shr64 | shl64(64-n)
//
// The block is 128 bytes, words are big-endian, there are 80 rounds, and
// the message-length field is 128 bits (we only fill the low 64).

/// A 64-bit word emulated as two 32-bit halves (`hi` = upper 32 bits, `lo` = lower 32 bits).
struct W64 {
    hi
    lo
}

/// Builds a W64 from `hi` and `lo`, masking each to 32 bits.
fn w64(hi, lo) {
    W64 { hi: hi & MASK32, lo: lo & MASK32 }
}

/// Bitwise XOR of two W64 values.
fn xor64(a, b) {
    W64 { hi: a.hi ^ b.hi, lo: a.lo ^ b.lo }
}

/// Bitwise AND of two W64 values.
fn and64(a, b) {
    W64 { hi: a.hi & b.hi, lo: a.lo & b.lo }
}

/// Bitwise NOT (complement) of a W64 value.
fn not64(a) {
    W64 { hi: a.hi ^ MASK32, lo: a.lo ^ MASK32 }
}

/// Adds two W64 values modulo 2^64, carrying the low-half overflow into the high half.
fn add64(a, b) {
    let lo = a.lo + b.lo
    let carry = lo / 4294967296
    let hi = (a.hi + b.hi + carry) & MASK32
    W64 { hi: hi, lo: lo & MASK32 }
}

// logical right shift by n (0 <= n < 64).
/// Logical right shift of a W64 by `n` bits (0 <= n < 64).
fn shr64(x, n) {
    if n == 0 {
        x
    } else {
        if n < 32 {
            // lo gets bits shifted down plus low bits of hi spilling in
            let lo = ((x.lo >>> n) | (x.hi << (32 - n))) & MASK32
            let hi = (x.hi >>> n) & MASK32
            W64 { hi: hi, lo: lo }
        } else {
            // n >= 32: hi becomes 0, lo is hi shifted down
            let lo = (x.hi >>> (n - 32)) & MASK32
            W64 { hi: 0, lo: lo }
        }
    }
}

// left shift by n (0 <= n < 64).
/// Left shift of a W64 by `n` bits (0 <= n < 64).
fn shl64(x, n) {
    if n == 0 {
        x
    } else {
        if n < 32 {
            let hi = ((x.hi << n) | (x.lo >>> (32 - n))) & MASK32
            let lo = (x.lo << n) & MASK32
            W64 { hi: hi, lo: lo }
        } else {
            let hi = (x.lo << (n - 32)) & MASK32
            W64 { hi: hi, lo: 0 }
        }
    }
}

// rotate right by n (0 <= n < 64).
/// Rotates a W64 right by `n` bits (0 <= n < 64).
fn rotr64(x, n) {
    xor64(shr64(x, n), shl64(x, 64 - n))
}

// Read a big-endian 64-bit word from bytes at index i.
/// Reads a big-endian 64-bit word from `bytes` at index `i` as a W64.
fn word-be64(bytes, i) {
    let hi = ((bytes[i] << 24) | (bytes[i + 1] << 16) | (bytes[i + 2] << 8) | bytes[i + 3]) & MASK32
    let lo = ((bytes[i + 4] << 24) | (bytes[i + 5] << 16) | (bytes[i + 6] << 8) | bytes[i + 7]) & MASK32
    W64 { hi: hi, lo: lo }
}

// Padding for SHA-512: block size 128, 128-bit big-endian length field.
// Our messages are well under 2^64 bits, so the top 64 bits are zero.
/// SHA-512 message padding: block size 128 with a 128-bit big-endian length
/// field (the high 64 bits are always zero for our inputs).
fn pad-message-128(bytes) {
    let msg-len = length(bytes)
    let bit-len = msg-len * 8
    let mut out = bytes
    out = push(out, 0x80)
    while (length(out) % 128) != 112 {
        out = push(out, 0)
    }
    // high 64 bits of the 128-bit length: zero for our inputs.
    let mut z = 0
    while z < 8 {
        out = push(out, 0)
        z = z + 1
    }
    // low 64 bits, big-endian.
    let low = bit-len & MASK32
    let high = (bit-len / 4294967296) & MASK32
    out = push(out, (high >>> 24) & 0xFF)
    out = push(out, (high >>> 16) & 0xFF)
    out = push(out, (high >>> 8) & 0xFF)
    out = push(out, high & 0xFF)
    out = push(out, (low >>> 24) & 0xFF)
    out = push(out, (low >>> 16) & 0xFF)
    out = push(out, (low >>> 8) & 0xFF)
    out = push(out, low & 0xFF)
    out
}

