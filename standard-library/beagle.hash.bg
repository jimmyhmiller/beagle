        w64(0xD807AA98, 0xA3030242), w64(0x12835B01, 0x45706FBE),
        w64(0x243185BE, 0x4EE4B28C), w64(0x550C7DC3, 0xD5FFB4E2),
        w64(0x72BE5D74, 0xF27B896F), w64(0x80DEB1FE, 0x3B1696B1),
        w64(0x9BDC06A7, 0x25C71235), w64(0xC19BF174, 0xCF692694),
        w64(0xE49B69C1, 0x9EF14AD2), w64(0xEFBE4786, 0x384F25E3),
        w64(0x0FC19DC6, 0x8B8CD5B5), w64(0x240CA1CC, 0x77AC9C65),
        w64(0x2DE92C6F, 0x592B0275), w64(0x4A7484AA, 0x6EA6E483),
        w64(0x5CB0A9DC, 0xBD41FBD4), w64(0x76F988DA, 0x831153B5),
        w64(0x983E5152, 0xEE66DFAB), w64(0xA831C66D, 0x2DB43210),
        w64(0xB00327C8, 0x98FB213F), w64(0xBF597FC7, 0xBEEF0EE4),
        w64(0xC6E00BF3, 0x3DA88FC2), w64(0xD5A79147, 0x930AA725),
        w64(0x06CA6351, 0xE003826F), w64(0x14292967, 0x0A0E6E70),
        w64(0x27B70A85, 0x46D22FFC), w64(0x2E1B2138, 0x5C26C926),
        w64(0x4D2C6DFC, 0x5AC42AED), w64(0x53380D13, 0x9D95B3DF),
        w64(0x650A7354, 0x8BAF63DE), w64(0x766A0ABB, 0x3C77B2A8),
        w64(0x81C2C92E, 0x47EDAEE6), w64(0x92722C85, 0x1482353B),
        w64(0xA2BFE8A1, 0x4CF10364), w64(0xA81A664B, 0xBC423001),
        w64(0xC24B8B70, 0xD0F89791), w64(0xC76C51A3, 0x0654BE30),
        w64(0xD192E819, 0xD6EF5218), w64(0xD6990624, 0x5565A910),
        w64(0xF40E3585, 0x5771202A), w64(0x106AA070, 0x32BBD1B8),
        w64(0x19A4C116, 0xB8D2D0C8), w64(0x1E376C08, 0x5141AB53),
        w64(0x2748774C, 0xDF8EEB99), w64(0x34B0BCB5, 0xE19B48A8),
        w64(0x391C0CB3, 0xC5C95A63), w64(0x4ED8AA4A, 0xE3418ACB),
        w64(0x5B9CCA4F, 0x7763E373), w64(0x682E6FF3, 0xD6B2B8A3),
        w64(0x748F82EE, 0x5DEFB2FC), w64(0x78A5636F, 0x43172F60),
        w64(0x84C87814, 0xA1F0AB72), w64(0x8CC70208, 0x1A6439EC),
        w64(0x90BEFFFA, 0x23631E28), w64(0xA4506CEB, 0xDE82BDE9),
        w64(0xBEF9A3F7, 0xB2C67915), w64(0xC67178F2, 0xE372532B),
        w64(0xCA273ECE, 0xEA26619C), w64(0xD186B8C7, 0x21C0C207),
        w64(0xEADA7DD6, 0xCDE0EB1E), w64(0xF57D4F7F, 0xEE6ED178),
        w64(0x06F067AA, 0x72176FBA), w64(0x0A637DC5, 0xA2C898A6),
        w64(0x113F9804, 0xBEF90DAE), w64(0x1B710B35, 0x131C471B),
        w64(0x28DB77F5, 0x23047D84), w64(0x32CAAB7B, 0x40C72493),
        w64(0x3C9EBE0A, 0x15C9BEBC), w64(0x431D67C4, 0x9C100D4C),
        w64(0x4CC5D4BE, 0xCB3E42B6), w64(0x597F299C, 0xFC657E2A),
        w64(0x5FCB6FAB, 0x3AD6FAEC), w64(0x6C44198C, 0x4A475817)
    ]
}

// Run SHA-512 over a Vec<Int> of bytes, returning a Vec of 8 W64.
/// Runs SHA-512 over a Vec<Int> of bytes, returning the digest as a Vec of 8 W64.
fn sha512-digest-words(raw-bytes) {
    let bytes = pad-message-128(raw-bytes)
    let total = length(bytes)
    let k = sha512-k()

    let mut h0 = w64(0x6A09E667, 0xF3BCC908)
    let mut h1 = w64(0xBB67AE85, 0x84CAA73B)
    let mut h2 = w64(0x3C6EF372, 0xFE94F82B)
    let mut h3 = w64(0xA54FF53A, 0x5F1D36F1)
    let mut h4 = w64(0x510E527F, 0xADE682D1)
    let mut h5 = w64(0x9B05688C, 0x2B3E6C1F)
    let mut h6 = w64(0x1F83D9AB, 0xFB41BD6B)
    let mut h7 = w64(0x5BE0CD19, 0x137E2179)

    let w = arr/new-array(80)

    let mut block = 0
    while block < total {
        let mut t = 0
        while t < 16 {
            arr/write-field(w, t, word-be64(bytes, block + t * 8))
            t = t + 1
        }
        t = 16
        while t < 80 {
            let w15 = arr/read-field(w, t - 15)
            let w2 = arr/read-field(w, t - 2)
            let s0 = xor64(xor64(rotr64(w15, 1), rotr64(w15, 8)), shr64(w15, 7))
            let s1 = xor64(xor64(rotr64(w2, 19), rotr64(w2, 61)), shr64(w2, 6))
            let v = add64(add64(arr/read-field(w, t - 16), s0), add64(arr/read-field(w, t - 7), s1))
            arr/write-field(w, t, v)
            t = t + 1
        }

        let mut a = h0
        let mut b = h1
        let mut c = h2
        let mut d = h3
        let mut e = h4
        let mut f = h5
        let mut g = h6
        let mut hh = h7

        t = 0
        while t < 80 {
            let big-s1 = xor64(xor64(rotr64(e, 14), rotr64(e, 18)), rotr64(e, 41))
            let ch = xor64(and64(e, f), and64(not64(e), g))
            let temp1 = add64(add64(add64(hh, big-s1), add64(ch, k[t])), arr/read-field(w, t))
            let big-s0 = xor64(xor64(rotr64(a, 28), rotr64(a, 34)), rotr64(a, 39))
            let maj = xor64(xor64(and64(a, b), and64(a, c)), and64(b, c))
            let temp2 = add64(big-s0, maj)

            hh = g
            g = f
            f = e
            e = add64(d, temp1)
            d = c
            c = b
            b = a
            a = add64(temp1, temp2)
            t = t + 1
        }

        h0 = add64(h0, a)
        h1 = add64(h1, b)
        h2 = add64(h2, c)
        h3 = add64(h3, d)
        h4 = add64(h4, e)
        h5 = add64(h5, f)
        h6 = add64(h6, g)
        h7 = add64(h7, hh)

        block = block + 128
    }

    [h0, h1, h2, h3, h4, h5, h6, h7]
}

/// Concatenates a Vec of W64 into a big-endian lowercase hex String.
fn words64-to-hex(words) {
    let out = sb/new(128)
    let mut i = 0
    while i < length(words) {
        append-hex32!(out, words[i].hi)
        append-hex32!(out, words[i].lo)
        i = i + 1
    }
    sb/to-string(out)
}

/// Computes the SHA-512 hash of `input` (String or Vec<Int>), returning a 128-char lowercase hex String.
fn sha512(input) {
    words64-to-hex(sha512-digest-words(to-bytes(input)))
}

// SHA-512 digest as a Vec of 64 bytes (big-endian), for HMAC.
/// SHA-512 digest of `raw-bytes` as a Vec of 64 bytes (big-endian), for HMAC.
fn sha512-digest-bytes(raw-bytes) {
    let words = sha512-digest-words(raw-bytes)
    let mut out = []
    let mut i = 0
    while i < length(words) {
        let hi = words[i].hi
        let lo = words[i].lo
        out = push(out, (hi >>> 24) & 0xFF)
        out = push(out, (hi >>> 16) & 0xFF)
        out = push(out, (hi >>> 8) & 0xFF)
        out = push(out, hi & 0xFF)
        out = push(out, (lo >>> 24) & 0xFF)
        out = push(out, (lo >>> 16) & 0xFF)
        out = push(out, (lo >>> 8) & 0xFF)
        out = push(out, lo & 0xFF)
        i = i + 1
    }
    out
}

// =====================================================================
// HMAC
// =====================================================================

// Convert 8 SHA-256 words into a Vec of 32 bytes (big-endian).
/// Converts 8 SHA-256 words into a Vec of 32 bytes (big-endian).
fn words-to-bytes(words) {
    let mut out = []
    let mut i = 0
    while i < length(words) {
        let word = words[i]
        out = push(out, (word >>> 24) & 0xFF)
        out = push(out, (word >>> 16) & 0xFF)
        out = push(out, (word >>> 8) & 0xFF)
        out = push(out, word & 0xFF)
        i = i + 1
    }
    out
}

/// Returns a new byte Vec with the bytes of `b` appended to `a`.
fn concat-bytes(a, b) {
    let mut out = a
    let mut i = 0
    while i < length(b) {
        out = push(out, b[i])
        i = i + 1
    }
    out
}

// Hex of an arbitrary byte vector.
/// Returns the lowercase hex String of an arbitrary byte Vec.
fn bytes-to-hex(bytes) {
    let out = sb/new(length(bytes) * 2)
    let mut i = 0
    while i < length(bytes) {
        append-hex8!(out, bytes[i])
        i = i + 1
    }
    sb/to-string(out)
}

// Generic HMAC over a raw-bytes digest function. `digest-bytes` maps
// Vec<Int> -> Vec<Int> (the raw hash output); `block-size` is the hash's
// internal block size in bytes. Returns the raw HMAC bytes.
/// Generic HMAC over a raw-bytes digest function. `digest-bytes` maps
/// Vec<Int> -> Vec<Int> (the raw hash output); `block-size` is the hash's
/// internal block size in bytes. Returns the raw HMAC bytes.
fn hmac-bytes(digest-bytes, block-size, key, msg) {
    let mut key-bytes = to-bytes(key)
    if length(key-bytes) > block-size {
        key-bytes = digest-bytes(key-bytes)
    }
    while length(key-bytes) < block-size {
        key-bytes = push(key-bytes, 0)
    }

    let mut o-key-pad = []
    let mut i-key-pad = []
    let mut i = 0
    while i < block-size {
        o-key-pad = push(o-key-pad, key-bytes[i] ^ 0x5C)
        i-key-pad = push(i-key-pad, key-bytes[i] ^ 0x36)
        i = i + 1
    }

    let msg-bytes = to-bytes(msg)
    let inner = digest-bytes(concat-bytes(i-key-pad, msg-bytes))
    digest-bytes(concat-bytes(o-key-pad, inner))
}

/// Computes HMAC-SHA-256 of `msg` under `key`, returning a 64-char lowercase hex String.
fn hmac-sha256(key, msg) {
    let block-size = 64
    let mut key-bytes = to-bytes(key)
    // If key longer than block size, hash it first.
    if length(key-bytes) > block-size {
        key-bytes = words-to-bytes(sha256-digest-words(key-bytes))
    }
    // Pad key to block size with zeros.
    while length(key-bytes) < block-size {
        key-bytes = push(key-bytes, 0)
    }

    let mut o-key-pad = []
    let mut i-key-pad = []
    let mut i = 0
    while i < block-size {
        o-key-pad = push(o-key-pad, key-bytes[i] ^ 0x5C)
        i-key-pad = push(i-key-pad, key-bytes[i] ^ 0x36)
        i = i + 1
    }

    let msg-bytes = to-bytes(msg)
    let inner = sha256-digest-words(concat-bytes(i-key-pad, msg-bytes))
    let inner-bytes = words-to-bytes(inner)
    let outer = sha256-digest-words(concat-bytes(o-key-pad, inner-bytes))
    words-to-hex(outer)
}

/// Computes HMAC-MD5 of `msg` under `key`, returning a 32-char lowercase hex String.
fn hmac-md5(key, msg) {
    // MD5 block size is 64 bytes.
    bytes-to-hex(hmac-bytes(md5-digest-bytes, 64, key, msg))
}

/// Computes HMAC-SHA-512 of `msg` under `key`, returning a 128-char lowercase hex String.
fn hmac-sha512(key, msg) {
    // SHA-512 block size is 128 bytes.
    bytes-to-hex(hmac-bytes(sha512-digest-bytes, 128, key, msg))
}

// =====================================================================
// Non-cryptographic checksums (CRC-32, FNV-1a)
// =====================================================================

/// Computes the standard CRC-32 (IEEE 802.3, reflected polynomial 0xEDB88320)
/// of `input` (a String, hashed as its UTF-8 bytes, or a Vec<Int> of byte
/// values), returning the unsigned 32-bit checksum as an Int. crc32("") == 0.
fn crc32(input) {
    let bytes = to-bytes(input)
    let n = length(bytes)
    let mut crc = MASK32
    let mut i = 0
    while i < n {
        crc = crc ^ bytes[i]
        let mut k = 0
        while k < 8 {
            if (crc & 1) == 1 {
                crc = (crc >>> 1) ^ 0xEDB88320
            } else {
                crc = crc >>> 1
            }
            k = k + 1
        }
        i = i + 1
    }
    (crc ^ MASK32) & MASK32
}

/// Computes the 32-bit FNV-1a hash of `input` (a String, hashed as its UTF-8
/// bytes, or a Vec<Int> of byte values), returning the unsigned 32-bit hash as
/// an Int. Offset basis 2166136261, prime 16777619: for each byte, XOR into the
/// hash then multiply by the prime (masked to 32 bits). fnv1a-32("") == 2166136261.
fn fnv1a-32(input) {
    let bytes = to-bytes(input)
    let n = length(bytes)
    let mut hash = 2166136261
    let mut i = 0
    while i < n {
        hash = (hash ^ bytes[i]) & MASK32
        hash = (hash * 16777619) & MASK32
        i = i + 1
    }
    hash
}

/// Demo entry point: prints sample MD5/SHA-1/SHA-256/SHA-512/HMAC digests.
